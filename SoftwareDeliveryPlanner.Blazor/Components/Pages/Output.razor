@page "/output"
@using SoftwareDeliveryPlanner.Data
@using SoftwareDeliveryPlanner.Models
@using SoftwareDeliveryPlanner.Services
@inject IDbContextFactory<PlannerDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Delivery Plan</PageTitle>

<h3 style="margin-bottom: 20px;">📤 Delivery Plan</h3>

<div class="mb-3">
    <button class="btn btn-success" @onclick="ExportToCsv" data-testid="output-export-csv">📥 Export to CSV</button>
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="output-refresh">🔄 Refresh</button>
</div>

<table class="table table-striped table-hover" data-testid="output-table">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Task ID</th>
            <th>Service</th>
            <th>Devs</th>
            <th>Start</th>
            <th>Finish</th>
            <th>Days</th>
            <th>Est</th>
            <th>Strict Date</th>
            <th>Status</th>
            <th>Risk</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in output)
        {
            <tr>
                <td>@item["num"]</td>
                <td>@item["task_id"]</td>
                <td>@item["service_name"]</td>
                <td>@item["assigned_dev"]</td>
                <td>@item["planned_start"]</td>
                <td>@item["planned_finish"]</td>
                <td>@item["duration"]</td>
                <td>@item["dev_estimation"]</td>
                <td>@item["strict_date"]</td>
                <td>
                    <span class="badge bg-@GetStatusColor(item["status"]?.ToString())">
                        @item["status"]
                    </span>
                </td>
                <td>
                    <span class="badge bg-@GetRiskColor(item["delivery_risk"]?.ToString())">
                        @item["delivery_risk"]
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Dictionary<string, object?>> output = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadOutput();
    }

    private async Task LoadOutput()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var scheduler = new SchedulingEngine(db);
        output = scheduler.GetOutputPlan();
    }

    private string GetStatusColor(string? status)
    {
        return status switch
        {
            "Completed" => "success",
            "In Progress" => "info",
            _ => "secondary"
        };
    }

    private string GetRiskColor(string? risk)
    {
        return risk switch
        {
            "On Track" => "success",
            "At Risk" => "warning",
            "Late" => "danger",
            _ => "secondary"
        };
    }

    private async Task ExportToCsv()
    {
        var csv = "Num,Task ID,Service,Dev,Start,Finish,Days,Est,Strict,Status,Risk\n";
        
        foreach (var item in output)
        {
            var name = item["service_name"]?.ToString()?.Replace(",", ";") ?? "";
            csv += $"{item["num"]},{item["task_id"]},{name},{item["assigned_dev"]},{item["planned_start"]},{item["planned_finish"]},{item["duration"]},{item["dev_estimation"]},{item["strict_date"]},{item["status"]},{item["delivery_risk"]}\n";
        }

        var fileName = $"delivery_plan_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("BlazorDownloadFile", fileName, csv, "text/csv");
    }

    private async Task RefreshData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var scheduler = new SchedulingEngine(db);
        scheduler.RunScheduler();
        await LoadOutput();
    }
}
