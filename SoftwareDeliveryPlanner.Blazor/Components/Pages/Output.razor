@page "/output"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Output.Queries
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator
@inject IJSRuntime JS

<PageTitle>Delivery Plan</PageTitle>

<h3 style="margin-bottom: 20px;">📤 Delivery Plan</h3>

<div class="mb-3">
    <button class="btn btn-success" @onclick="ExportToCsv" data-testid="output-export-csv">📥 Export to CSV</button>
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="output-refresh">🔄 Refresh</button>
    <span class="ms-2" data-testid="output-export-status">@exportStatus</span>
</div>

<table class="table table-striped table-hover" data-testid="output-table">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Task ID</th>
            <th>Service</th>
            <th>Devs</th>
            <th>Start</th>
            <th>Finish</th>
            <th>Days</th>
            <th>Est</th>
            <th>Strict Date</th>
            <th>Status</th>
            <th>Risk</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in output)
        {
            <tr>
                <td>@item["num"]</td>
                <td>@item["task_id"]</td>
                <td>@item["service_name"]</td>
                <td>@item["assigned_dev"]</td>
                <td>@item["planned_start"]</td>
                <td>@item["planned_finish"]</td>
                <td>@item["duration"]</td>
                <td>@item["dev_estimation"]</td>
                <td>@item["strict_date"]</td>
                <td>
                    <span class="badge bg-@GetStatusColor(item["status"]?.ToString())">
                        @item["status"]
                    </span>
                </td>
                <td>
                    <span class="badge bg-@GetRiskColor(item["delivery_risk"]?.ToString())">
                        @item["delivery_risk"]
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Dictionary<string, object?>> output = new();
    private string exportStatus = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadOutput();
    }

    private async Task LoadOutput()
    {
        output = await Mediator.Send(new GetOutputPlanQuery());
    }

    private string GetStatusColor(string? status)
    {
        return status switch
        {
            DomainConstants.TaskStatus.Completed => "success",
            DomainConstants.TaskStatus.InProgress => "info",
            _ => "secondary"
        };
    }

    private string GetRiskColor(string? risk)
    {
        return risk switch
        {
            DomainConstants.DeliveryRisk.OnTrack => "success",
            DomainConstants.DeliveryRisk.AtRisk => "warning",
            DomainConstants.DeliveryRisk.Late => "danger",
            _ => "secondary"
        };
    }

    private async Task ExportToCsv()
    {
        try
        {
            exportStatus = string.Empty;
            if (output.Count == 0)
            {
                exportStatus = "No data to export";
                return;
            }

            var csv = "Num,Task ID,Service,Dev,Start,Finish,Days,Est,Strict,Status,Risk\n";

            foreach (var item in output)
            {
                var num = GetCsvValue(item, "num");
                var taskId = GetCsvValue(item, "task_id");
                var service = GetCsvValue(item, "service_name").Replace(",", ";").Replace("\r", " ").Replace("\n", " ");
                var assignedDev = GetCsvValue(item, "assigned_dev");
                var plannedStart = GetCsvValue(item, "planned_start");
                var plannedFinish = GetCsvValue(item, "planned_finish");
                var duration = GetCsvValue(item, "duration");
                var estimation = GetCsvValue(item, "dev_estimation");
                var strictDate = GetCsvValue(item, "strict_date");
                var status = GetCsvValue(item, "status");
                var risk = GetCsvValue(item, "delivery_risk");

                csv += $"{num},{taskId},{service},{assignedDev},{plannedStart},{plannedFinish},{duration},{estimation},{strictDate},{status},{risk}\n";
            }

            var fileName = $"delivery_plan_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JS.InvokeVoidAsync("BlazorDownloadFile", fileName, csv, "text/csv");
            exportStatus = $"Exported {output.Count} rows";
        }
        catch
        {
            exportStatus = "Export failed";
        }
    }

    private static string GetCsvValue(Dictionary<string, object?> item, string key)
    {
        return item.TryGetValue(key, out var value) ? value?.ToString() ?? string.Empty : string.Empty;
    }

    private async Task RefreshData()
    {
        await Mediator.Send(new RunSchedulerCommand());
        await LoadOutput();
    }
}
