@page "/timeline"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Timeline.Queries
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using SoftwareDeliveryPlanner.Application.Abstractions
@using SoftwareDeliveryPlanner.Models
@inject IMediator Mediator

<PageTitle>Employee Timeline</PageTitle>

<h3 style="margin-bottom: 20px;">🗓️ Employee Timeline</h3>

<div class="row mb-3">
    <div class="col-md-3">
        <label>Employee:</label>
        <select class="form-control" @onchange="OnResourceChanged" data-testid="timeline-resource">
            @foreach (var r in resources)
            {
                <option value="@r.ResourceId">@r.ResourceName</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label>Start Date:</label>
        <input class="form-control" type="date" @bind="startDate" data-testid="timeline-start-date" />
    </div>
    <div class="col-md-3">
        <label>End Date:</label>
        <input class="form-control" type="date" @bind="endDate" data-testid="timeline-end-date" />
    </div>
    <div class="col-md-3">
        <label>&nbsp;</label>
        <button class="btn btn-primary w-100" @onclick="LoadTimeline" data-testid="timeline-refresh">🔄 Refresh</button>
    </div>
</div>

<div class="timeline-container" style="overflow-x: auto; padding: 10px;" data-testid="timeline-container">
    <div style="display: flex; gap: 5px; flex-wrap: wrap;">
        @foreach (var day in timelineDays)
        {
            <div style="
                width: 100px; 
                height: 80px; 
                border: 1px solid #ddd; 
                border-radius: 5px;
                padding: 5px;
                text-align: center;
                background: @day.BackgroundColor;
                font-size: 12px;">
                <div style="font-weight: bold;">@day.DateDisplay</div>
                <div style="margin-top: 5px;">@day.StatusText</div>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <div style="display: flex; gap: 20px; flex-wrap: wrap;">
        <div><span style="display: inline-block; width: 20px; height: 20px; background: #d4edda; border: 1px solid #ccc;"></span> Working Day</div>
        <div><span style="display: inline-block; width: 20px; height: 20px; background: #f8f9fa; border: 1px solid #ccc;"></span> Weekend</div>
        <div><span style="display: inline-block; width: 20px; height: 20px; background: #fff3cd; border: 1px solid #ccc;"></span> Holiday</div>
        <div><span style="display: inline-block; width: 20px; height: 20px; background: #cce5ff; border: 1px solid #ccc;"></span> Adjustment</div>
        <div><span style="display: inline-block; width: 20px; height: 20px; background: #d1ecf1; border: 1px solid #ccc;"></span> Task</div>
    </div>
</div>

@code {
    private List<TeamMember> resources = new();
    private List<TimelineDayDto> timelineDays = new();
    private string selectedResourceId = "";
    private DateTime startDate = DateTime.Today.AddDays(-7);
    private DateTime endDate = DateTime.Today.AddMonths(2);

    protected override async Task OnInitializedAsync()
    {
        resources = await Mediator.Send(new GetResourcesQuery());
        if (resources.Any())
        {
            selectedResourceId = resources.First().ResourceId;
            await LoadTimeline();
        }
    }

    private async Task OnResourceChanged(ChangeEventArgs e)
    {
        selectedResourceId = e.Value?.ToString() ?? "";
        await LoadTimeline();
    }

    private async Task LoadTimeline()
    {
        if (string.IsNullOrEmpty(selectedResourceId)) return;

        var data = await Mediator.Send(new GetTimelineQuery(selectedResourceId, startDate, endDate));
        timelineDays = data.Days;
    }
}
