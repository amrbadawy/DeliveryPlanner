@page "/holidays"
@using SoftwareDeliveryPlanner.Data
@using SoftwareDeliveryPlanner.Models
@using SoftwareDeliveryPlanner.Services
@inject IDbContextFactory<PlannerDbContext> DbFactory

<PageTitle>Holidays</PageTitle>

<h3 style="margin-bottom: 20px;">🎉 Holidays (Saudi Arabia 2026)</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="holidays-add">➕ Add Holiday</button>
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="holidays-refresh">🔄 Refresh</button>
</div>

@if (showModal)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="holidays-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingHoliday == null ? "Add New Holiday" : "Edit Holiday")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(modalError))
                    {
                        <div class="alert alert-danger" data-testid="holidays-error">@modalError</div>
                    }
                    <div class="mb-2">
                        <label>Holiday Name:</label>
                        <input class="form-control" @bind="holidayForm.HolidayName" data-testid="holidays-name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Date:</label>
                            <input class="form-control" type="date" @bind="holidayDateValue" data-testid="holidays-date" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Type:</label>
                            <select class="form-control" @bind="holidayForm.HolidayType" data-testid="holidays-type">
                                <option>National</option>
                                <option>Religious</option>
                                <option>Company</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label>Description:</label>
                        <textarea class="form-control" @bind="holidayForm.Notes" data-testid="holidays-notes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveHoliday" data-testid="holidays-save">Save</button>
                    <button class="btn btn-secondary" @onclick="CloseModal" data-testid="holidays-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="holidays-delete-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this holiday?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="ConfirmDelete" data-testid="holidays-delete-confirm">Delete</button>
                    <button class="btn btn-secondary" @onclick="CloseDeleteModal" data-testid="holidays-delete-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

<table class="table table-striped table-hover" data-testid="holidays-table">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Date</th>
            <th>Type</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var h in holidays)
        {
            <tr data-testid="holidays-row-@h.Id">
                <td>@h.HolidayName</td>
                <td>@h.HolidayDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge bg-@(h.HolidayType == "National" ? "primary" : "warning")">
                        @h.HolidayType
                    </span>
                </td>
                <td>@h.Notes</td>
                <td>
                    <button class="btn btn-sm btn-warning" @onclick="() => EditHoliday(h)" data-testid="holidays-edit-@h.Id">✏️</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteHoliday(h)" data-testid="holidays-delete-@h.Id">🗑️</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Holiday> holidays = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private Holiday? editingHoliday;
    private Holiday holidayForm = new();
    private DateTime holidayDateValue;
    private string modalError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadHolidays();
    }

    private async Task LoadHolidays()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        holidays = await db.Holidays.OrderBy(h => h.HolidayDate).ToListAsync();
    }

    private void ShowAddModal()
    {
        holidayForm = new Holiday { HolidayType = "National" };
        holidayDateValue = DateTime.Today;
        editingHoliday = null;
        modalError = string.Empty;
        showModal = true;
    }

    private void EditHoliday(Holiday h)
    {
        editingHoliday = h;
        holidayForm = new Holiday
        {
            Id = h.Id,
            HolidayName = h.HolidayName,
            HolidayType = h.HolidayType,
            Notes = h.Notes
        };
        holidayDateValue = h.HolidayDate;
        modalError = string.Empty;
        showModal = true;
    }

    private void DeleteHoliday(Holiday h)
    {
        editingHoliday = h;
        showDeleteConfirm = true;
    }

    private async Task SaveHoliday()
    {
        modalError = string.Empty;
        if (string.IsNullOrWhiteSpace(holidayForm.HolidayName))
        {
            modalError = "Holiday Name is required.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        holidayForm.HolidayDate = holidayDateValue;
        
        if (editingHoliday == null)
        {
            db.Holidays.Add(holidayForm);
        }
        else
        {
            var existing = await db.Holidays.FirstOrDefaultAsync(h => h.Id == editingHoliday.Id);
            if (existing != null)
            {
                existing.HolidayName = holidayForm.HolidayName;
                existing.HolidayDate = holidayForm.HolidayDate;
                existing.HolidayType = holidayForm.HolidayType;
                existing.Notes = holidayForm.Notes;
            }
        }

        await db.SaveChangesAsync();
        var scheduler = new SchedulingEngine(db);
        scheduler.RunScheduler();
        await LoadHolidays();
        CloseModal();
    }

    private async Task ConfirmDelete()
    {
        if (editingHoliday != null)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var h = await db.Holidays.FirstOrDefaultAsync(x => x.Id == editingHoliday.Id);
            if (h != null)
            {
                db.Holidays.Remove(h);
                await db.SaveChangesAsync();
                var scheduler = new SchedulingEngine(db);
                scheduler.RunScheduler();
            }
        }
        showDeleteConfirm = false;
        editingHoliday = null;
        await LoadHolidays();
    }

    private void CloseModal()
    {
        showModal = false;
        editingHoliday = null;
        modalError = string.Empty;
    }

    private void CloseDeleteModal()
    {
        showDeleteConfirm = false;
        editingHoliday = null;
    }

    private async Task RefreshData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var scheduler = new SchedulingEngine(db);
        scheduler.RunScheduler();
        await LoadHolidays();
    }
}
