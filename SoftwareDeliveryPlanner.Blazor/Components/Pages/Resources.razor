@page "/resources"
@using MediatR
@using FluentValidation
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using SoftwareDeliveryPlanner.Application.Resources.Commands
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Models
@inject IMediator Mediator

<PageTitle>Resources</PageTitle>

<h3 style="margin-bottom: 20px;">👥 Resources</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="resources-add">➕ Add Resource</button>
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="resources-refresh">🔄 Refresh</button>
</div>

@if (showModal)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="resources-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingResource == null ? "Add New Resource" : "Edit Resource")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(modalError))
                    {
                        <div class="alert alert-danger" data-testid="resources-error">@modalError</div>
                    }
                    <div class="mb-2">
                        <label>Resource ID:</label>
                        <input class="form-control" @bind="resourceForm.ResourceId" disabled="@(editingResource != null)" data-testid="resources-id" />
                    </div>
                    <div class="mb-2">
                        <label>Name:</label>
                        <input class="form-control" @bind="resourceForm.ResourceName" data-testid="resources-name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Role:</label>
                            <select class="form-control" @bind="resourceForm.Role" data-testid="resources-role">
                                <option>Developer</option>
                                <option>Senior Developer</option>
                                <option>Tech Lead</option>
                                <option>QA</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Team:</label>
                            <input class="form-control" @bind="resourceForm.Team" data-testid="resources-team" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Availability (%):</label>
                            <input class="form-control" type="number" @bind="resourceForm.AvailabilityPct" data-testid="resources-availability" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Daily Capacity:</label>
                            <input class="form-control" type="number" step="0.1" @bind="resourceForm.DailyCapacity" data-testid="resources-daily-capacity" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Start Date:</label>
                            <input class="form-control" type="date" @bind="startDateValue" data-testid="resources-start-date" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Active:</label>
                            <select class="form-control" @bind="resourceForm.Active" data-testid="resources-active">
                                <option value="Yes">Yes</option>
                                <option value="No">No</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label>Notes:</label>
                        <textarea class="form-control" @bind="resourceForm.Notes" data-testid="resources-notes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveResource" data-testid="resources-save">Save</button>
                    <button class="btn btn-secondary" @onclick="CloseModal" data-testid="resources-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="resources-delete-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this resource?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="ConfirmDelete" data-testid="resources-delete-confirm">Delete</button>
                    <button class="btn btn-secondary" @onclick="CloseDeleteModal" data-testid="resources-delete-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

<table class="table table-striped table-hover" data-testid="resources-table">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Role</th>
            <th>Team</th>
            <th>Availability %</th>
            <th>Capacity</th>
            <th>Start Date</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in resources)
        {
            <tr data-testid="resources-row-@r.ResourceId">
                <td>@r.ResourceId</td>
                <td>@r.ResourceName</td>
                <td>@r.Role</td>
                <td>@r.Team</td>
                <td>@r.AvailabilityPct%</td>
                <td>@r.DailyCapacity</td>
                <td>@r.StartDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge bg-@(r.Active == "Yes" ? "success" : "secondary")">
                        @(r.Active == "Yes" ? "Yes" : "No")
                    </span>
                </td>
                <td>
                    <button class="btn btn-sm btn-warning" @onclick="() => EditResource(r)" data-testid="resources-edit-@r.ResourceId">✏️</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteResource(r)" data-testid="resources-delete-@r.ResourceId">🗑️</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<TeamMember> resources = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private TeamMember? editingResource;
    private TeamMember resourceForm = new();
    private DateTime startDateValue;
    private string modalError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadResources();
    }

    private async Task LoadResources()
    {
        resources = await Mediator.Send(new GetResourcesQuery());
    }

    private async Task ShowAddModal()
    {
        var count = await Mediator.Send(new GetResourceCountQuery());
        resourceForm = new TeamMember
        {
            ResourceId = $"DEV-{(count + 1):D3}",
            Role = "Developer",
            Team = "Delivery",
            StartDate = DateTime.Today,
            Active = "Yes",
            AvailabilityPct = 100,
            DailyCapacity = 1
        };
        startDateValue = DateTime.Today;
        editingResource = null;
        modalError = string.Empty;
        showModal = true;
    }

    private void EditResource(TeamMember r)
    {
        editingResource = r;
        resourceForm = new TeamMember
        {
            Id = r.Id,
            ResourceId = r.ResourceId,
            ResourceName = r.ResourceName,
            Role = r.Role,
            Team = r.Team,
            AvailabilityPct = r.AvailabilityPct,
            DailyCapacity = r.DailyCapacity,
            StartDate = r.StartDate,
            Active = r.Active,
            Notes = r.Notes
        };
        startDateValue = r.StartDate;
        modalError = string.Empty;
        showModal = true;
    }

    private void DeleteResource(TeamMember r)
    {
        editingResource = r;
        showDeleteConfirm = true;
    }

    private async Task SaveResource()
    {
        modalError = string.Empty;
        try
        {
            var command = new UpsertResourceCommand(
                Id: resourceForm.Id,
                ResourceId: resourceForm.ResourceId,
                ResourceName: resourceForm.ResourceName,
                Role: resourceForm.Role,
                Team: resourceForm.Team,
                AvailabilityPct: resourceForm.AvailabilityPct,
                DailyCapacity: resourceForm.DailyCapacity,
                StartDate: startDateValue,
                Active: resourceForm.Active,
                Notes: resourceForm.Notes,
                IsNew: editingResource == null);

            await Mediator.Send(command);
            await LoadResources();
            CloseModal();
        }
        catch (ValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
    }

    private async Task ConfirmDelete()
    {
        if (editingResource != null)
        {
            await Mediator.Send(new DeleteResourceCommand(editingResource.Id));
        }
        showDeleteConfirm = false;
        editingResource = null;
        await LoadResources();
    }

    private void CloseModal()
    {
        showModal = false;
        editingResource = null;
        modalError = string.Empty;
    }

    private void CloseDeleteModal()
    {
        showDeleteConfirm = false;
        editingResource = null;
    }

    private async Task RefreshData()
    {
        await Mediator.Send(new RunSchedulerCommand());
        await LoadResources();
    }
}
