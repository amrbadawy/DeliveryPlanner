@page "/tasks"
@using SoftwareDeliveryPlanner.Data
@using SoftwareDeliveryPlanner.Models
@using SoftwareDeliveryPlanner.Services
@inject IDbContextFactory<PlannerDbContext> DbFactory

<PageTitle>Task Register</PageTitle>

<h3 style="margin-bottom: 20px;">📋 Task Register</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="tasks-add">➕ Add Service</button>
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="tasks-refresh">🔄 Refresh</button>
</div>

@if (showModal)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="tasks-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingTask == null ? "Add New Service" : "Edit Service")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label>Service ID:</label>
                        <input class="form-control" @bind="taskForm.TaskId" disabled="@(editingTask != null)" data-testid="tasks-task-id" />
                    </div>
                    <div class="mb-2">
                        <label>Service Name:</label>
                        <input class="form-control" @bind="taskForm.ServiceName" data-testid="tasks-service-name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Estimation (days):</label>
                            <input class="form-control" type="number" @bind="taskForm.DevEstimation" data-testid="tasks-dev-estimation" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Max Developers:</label>
                            <input class="form-control" type="number" step="0.5" @bind="taskForm.MaxDev" data-testid="tasks-max-dev" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Priority (1-10):</label>
                            <input class="form-control" type="number" @bind="taskForm.Priority" data-testid="tasks-priority" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Strict Date:</label>
                            <input class="form-control" type="date" @bind="strictDateValue" data-testid="tasks-strict-date" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveTask" data-testid="tasks-save">Save</button>
                    <button class="btn btn-secondary" @onclick="CloseModal" data-testid="tasks-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="tasks-delete-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this service?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="ConfirmDelete" data-testid="tasks-delete-confirm">Delete</button>
                    <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false" data-testid="tasks-delete-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

<table class="table table-striped table-hover" data-testid="tasks-table">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Service</th>
            <th>Est</th>
            <th>Max Dev</th>
            <th>Priority</th>
            <th>Start</th>
            <th>Finish</th>
            <th>Days</th>
            <th>Status</th>
            <th>Risk</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in tasks)
        {
            <tr>
                <td>@task.TaskId</td>
                <td>@task.ServiceName</td>
                <td>@task.DevEstimation</td>
                <td>@task.MaxDev</td>
                <td>@task.Priority</td>
                <td>@task.PlannedStart?.ToString("yyyy-MM-dd")</td>
                <td>@task.PlannedFinish?.ToString("yyyy-MM-dd")</td>
                <td>@task.Duration</td>
                <td>
                    <span class="badge bg-@(task.Status == "Completed" ? "success" : task.Status == "In Progress" ? "info" : "secondary")">
                        @task.Status
                    </span>
                </td>
                <td>
                    <span class="badge bg-@(task.DeliveryRisk == "On Track" ? "success" : task.DeliveryRisk == "At Risk" ? "warning" : "danger")">
                        @task.DeliveryRisk
                    </span>
                </td>
                <td>
                    <button class="btn btn-sm btn-warning" @onclick="() => EditTask(task)" data-testid="tasks-edit-@task.TaskId">✏️</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteTask(task)" data-testid="tasks-delete-@task.TaskId">🗑️</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<TaskItem> tasks = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private TaskItem? editingTask;
    private TaskItem taskForm = new();
    private DateTime? strictDateValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        tasks = await db.Tasks.OrderBy(t => t.SchedulingRank ?? 999).ToListAsync();
    }

    private void ShowAddModal()
    {
        taskForm = new TaskItem { TaskId = GenerateTaskId(), Priority = 5, MaxDev = 1 };
        strictDateValue = null;
        editingTask = null;
        showModal = true;
    }

    private string GenerateTaskId()
    {
        using var db = DbFactory.CreateDbContext();
        var count = db.Tasks.Count() + 1;
        return $"SVC-{count:D3}";
    }

    private void EditTask(TaskItem task)
    {
        editingTask = task;
        taskForm = new TaskItem
        {
            Id = task.Id,
            TaskId = task.TaskId,
            ServiceName = task.ServiceName,
            DevEstimation = task.DevEstimation,
            MaxDev = task.MaxDev,
            Priority = task.Priority,
            StrictDate = task.StrictDate
        };
        strictDateValue = task.StrictDate;
        showModal = true;
    }

    private void DeleteTask(TaskItem task)
    {
        editingTask = task;
        showDeleteConfirm = true;
    }

    private async Task SaveTask()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        taskForm.StrictDate = strictDateValue;
        
        if (editingTask == null)
        {
            taskForm.CreatedAt = DateTime.Now;
            taskForm.UpdatedAt = DateTime.Now;
            db.Tasks.Add(taskForm);
        }
        else
        {
            var existing = await db.Tasks.FirstOrDefaultAsync(t => t.Id == editingTask.Id);
            if (existing != null)
            {
                existing.ServiceName = taskForm.ServiceName;
                existing.DevEstimation = taskForm.DevEstimation;
                existing.MaxDev = taskForm.MaxDev;
                existing.Priority = taskForm.Priority;
                existing.StrictDate = taskForm.StrictDate;
                existing.UpdatedAt = DateTime.Now;
            }
        }

        await db.SaveChangesAsync();
        var scheduler = new SchedulingEngine(db);
        scheduler.RunScheduler();
        await LoadTasks();
        CloseModal();
    }

    private async Task ConfirmDelete()
    {
        if (editingTask != null)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var task = await db.Tasks.FirstOrDefaultAsync(t => t.Id == editingTask.Id);
            if (task != null)
            {
                db.Tasks.Remove(task);
                await db.SaveChangesAsync();
                var scheduler = new SchedulingEngine(db);
                scheduler.RunScheduler();
            }
        }
        showDeleteConfirm = false;
        editingTask = null;
        await LoadTasks();
    }

    private void CloseModal()
    {
        showModal = false;
        editingTask = null;
    }

    private async Task RefreshData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var scheduler = new SchedulingEngine(db);
        scheduler.RunScheduler();
        await LoadTasks();
    }
}
