@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar" style="background: #2c3e50;">
        <div class="brand" style="padding: 20px; color: white; font-size: 18px; font-weight: bold; text-align: center; border-bottom: 1px solid #34495e;">
            Software Delivery Planner
        </div>
        <NavMenu />
    </div>

    <main style="background: #f5f6fa;">
        <div class="top-row px-4" style="background: #3498db; color: white;">
            <span style="font-weight: 500;">Software Delivery Planner</span>
        </div>

        <article class="content px-4" style="padding: 20px;">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unexpected error has occurred
    <a href="." class="reload">Reload</a>
    <span class="dismiss">✕</span>
</div>