@page "/heatmap"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Planning.Queries
@using SoftwareDeliveryPlanner.Application.Settings.Queries
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using SoftwareDeliveryPlanner.Domain
@using SoftwareDeliveryPlanner.Domain.Services
@using SoftwareDeliveryPlanner.Web.Services
@using SoftwareDeliveryPlanner.Web.Services.Heatmap
@inject IMediator Mediator
@inject ResourceFilterState ResourceFilter
@implements IDisposable

<PageTitle>Workload Heatmap</PageTitle>

<ToastNotification @ref="toast" TestId="heatmap-toast" />

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-grid-3x3-gap me-2"></i>Resource Workload</h3>
        <p class="page-subtitle">Visualize team utilization across weeks</p>
    </div>
    <div>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" disabled="@isRefreshing" data-testid="heatmap-refresh">
            @if (isRefreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

@if (!isLoaded)
{
    <SkeletonLoader Variant="table" Rows="6" Columns="8" TestId="heatmap-skeleton" />
}
else if (!string.IsNullOrEmpty(loadError))
{
    <div class="empty-state" data-testid="heatmap-error">
        <div class="empty-icon"><i class="bi bi-exclamation-triangle text-danger"></i></div>
        <h5>Unable to load workload heatmap</h5>
        <p>@loadError</p>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" data-testid="heatmap-error-retry">
            <i class="bi bi-arrow-clockwise"></i> Retry
        </button>
    </div>
}
else
{
    <div class="heatmap-layout">
        <ResourceFilterSidebar />
        <div class="heatmap-layout-main">
            @if (heatmap is null || !heatmap.WeekStarts.Any())
            {
                <div class="empty-state" data-testid="heatmap-empty">
                    <div class="empty-icon"><i class="bi bi-grid-3x3-gap"></i></div>
                    <h5>No heatmap data</h5>
                    <p>Run the scheduler to generate task assignments, then refresh.</p>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="heatmap-scroll" data-testid="heatmap-table-container">
                        <table class="heatmap-table" data-testid="heatmap-table">
                <thead>
                    <tr>
                        <th class="heatmap-resource-header">Resource</th>
                        @foreach (var week in FilteredWeekStarts)
                        {
                            var weekEnd = week.AddDays(6);
                            var wn = WeekNumberCalculator.GetWeekOfYear(week, weekNumberingCode, workingWeekCode);
                            <th class="heatmap-week-header">
                                <div class="hw-num">W@(wn)</div>
                                <div class="hw-range">@week.ToString("dd MMM") - @weekEnd.ToString("dd MMM")</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resourceName in FilteredResourceNames)
                    {
                        <tr>
                            <td class="heatmap-resource-cell">@resourceName</td>
                            @foreach (var week in FilteredWeekStarts)
                            {
                                var cell = FilteredCells.FirstOrDefault(c => c.ResourceName == resourceName && c.WeekStart == week);
                                var pct = cell?.UtilizationPct ?? 0;
                                <td class="heatmap-cell" style="background-color: @HeatmapColorPalette.GetCellColor(pct);" title="@resourceName — W@(WeekNumberCalculator.GetWeekOfYear(week, weekNumberingCode, workingWeekCode)) (@week.ToString("dd MMM") - @week.AddDays(6).ToString("dd MMM")) — @pct.ToString("F1")%">
                                    @pct.ToString("F0")%
                                </td>
                            }
                        </tr>
                    }
                </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="heatmap-legend mt-3" data-testid="heatmap-legend">
                <span class="legend-label">Utilization:</span>
                <span class="legend-item"><span class="legend-swatch" style="background-color: var(--color-bg-secondary);"></span>0%</span>
                <span class="legend-item"><span class="legend-swatch" style="background-color: var(--color-info-light);"></span>1–50%</span>
                <span class="legend-item"><span class="legend-swatch" style="background-color: var(--color-success-light);"></span>51–80%</span>
                <span class="legend-item"><span class="legend-swatch" style="background-color: var(--color-warning-light);"></span>81–100%</span>
                <span class="legend-item"><span class="legend-swatch" style="background-color: var(--color-danger-light);"></span>&gt;100%</span>
            </div>
        </div>
    </div>
}

@code {
    private WorkloadHeatmapDto? heatmap;
    private bool isLoaded;
    private bool isRefreshing;
    private string? loadError;
    private ToastNotification toast = default!;
    private string workingWeekCode = DomainConstants.WorkingWeek.SunThu;
    private string weekNumberingCode = DomainConstants.WeekNumbering.Default;
    private Dictionary<string, ResourceFilterState.ResourceFilterItem> resourceMap = new(StringComparer.OrdinalIgnoreCase);

    private List<WorkloadCellDto> FilteredCells =>
        heatmap?.Cells
            .Where(c => resourceMap.TryGetValue(c.ResourceId, out var item) && ResourceFilter.Matches(item))
            .ToList()
        ?? new List<WorkloadCellDto>();

    private List<string> FilteredResourceNames =>
        FilteredCells
            .Select(c => c.ResourceName)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();

    private List<DateTime> FilteredWeekStarts => heatmap?.WeekStarts ?? new List<DateTime>();

    protected override async Task OnInitializedAsync()
    {
        ResourceFilter.OnChange += OnFilterChanged;
        var settingsResult = await Mediator.Send(new GetSettingsQuery());
        if (settingsResult.IsSuccess)
        {
            if (!string.IsNullOrEmpty(settingsResult.Value.GlobalWorkingWeek))
                workingWeekCode = settingsResult.Value.GlobalWorkingWeek;
            if (!string.IsNullOrEmpty(settingsResult.Value.WeekNumbering))
                weekNumberingCode = settingsResult.Value.WeekNumbering;
        }
        try
        {
            await LoadData();
        }
        catch (Exception ex)
        {
            loadError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isLoaded = true;
        }
    }

    private async Task LoadData()
    {
        var result = await Mediator.Send(new GetWorkloadHeatmapQuery());
        heatmap = result.Value;

        var resourcesResult = await Mediator.Send(new GetResourcesForFilteringQuery());
        resourceMap = resourcesResult.IsSuccess
            ? resourcesResult.Value.ToDictionary(
                r => r.ResourceId,
                r => new ResourceFilterState.ResourceFilterItem(r.ResourceId, r.ResourceName, r.Role, r.SeniorityLevel),
                StringComparer.OrdinalIgnoreCase)
            : new Dictionary<string, ResourceFilterState.ResourceFilterItem>(StringComparer.OrdinalIgnoreCase);
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        try
        {
            await LoadData();
            loadError = null;
            toast.Show("Heatmap refreshed.");
        }
        catch (Exception ex)
        {
            loadError = $"Unexpected error: {ex.Message}";
            toast.Show($"Heatmap error: {ex.Message}", "error");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private void OnFilterChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ResourceFilter.OnChange -= OnFilterChanged;
    }
}
