@page "/calendar"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Calendar.Queries
@using SoftwareDeliveryPlanner.Domain.Models
@inject IMediator Mediator

<PageTitle>Calendar</PageTitle>

<h3 style="margin-bottom: 20px;">📅 Calendar</h3>

<div class="mb-3">
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="calendar-refresh">🔄 Refresh</button>
</div>

<table class="table table-striped table-hover table-sm" data-testid="calendar-table">
    <thead class="table-dark">
        <tr>
            <th>Date</th>
            <th>Day</th>
            <th>Working Day</th>
            <th>Holiday</th>
            <th>Name</th>
            <th>Base Capacity</th>
            <th>Reserved</th>
            <th>Remaining</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in calendar.Take(90))
        {
            <tr style="background: @(c.IsHoliday ? "#fff3cd" : c.IsWorkingDay ? "#d4edda" : "#f8f9fa")">
                <td>@c.CalendarDate.ToString("yyyy-MM-dd")</td>
                <td>@c.DayName</td>
                <td>
                    <span class="badge bg-@(c.IsWorkingDay ? "success" : "secondary")">
                        @(c.IsWorkingDay ? "Yes" : "No")
                    </span>
                </td>
                <td>
                    <span class="badge bg-@(c.IsHoliday ? "warning" : "secondary")">
                        @(c.IsHoliday ? "Yes" : "No")
                    </span>
                </td>
                <td>@c.HolidayName</td>
                <td>@c.EffectiveCapacity.ToString("F1")</td>
                <td>@c.ReservedCapacity.ToString("F1")</td>
                <td>@c.RemainingCapacity.ToString("F1")</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<CalendarDay> calendar = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCalendar();
    }

    private async Task LoadCalendar()
    {
        calendar = await Mediator.Send(new GetCalendarQuery());
    }

    private async Task RefreshData()
    {
        await LoadCalendar();
    }
}
