@page "/calendar"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Calendar.Queries
@using SoftwareDeliveryPlanner.Domain.Models
@inject IMediator Mediator

<PageTitle>Calendar</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-calendar3 me-2"></i>Calendar</h3>
        <p class="page-subtitle">View working days, holidays, and capacity overview</p>
    </div>
    <div>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" data-testid="calendar-refresh">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
</div>

@if (!isLoaded)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading calendar...</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" data-testid="calendar-table">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Day</th>
                        <th>Working Day</th>
                        <th>Holiday</th>
                        <th>Name</th>
                        <th>Base Capacity</th>
                        <th>Reserved</th>
                        <th>Remaining</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in calendar.Take(90))
                    {
                        <tr class="@(c.IsHoliday ? "day-holiday" : c.IsWorkingDay ? "day-working" : "day-weekend")">
                            <td>@c.CalendarDate.ToString("yyyy-MM-dd")</td>
                            <td>@c.DayName</td>
                            <td>
                                <span class="badge bg-@(c.IsWorkingDay ? "success" : "secondary")">
                                    @(c.IsWorkingDay ? "Yes" : "No")
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-@(c.IsHoliday ? "warning" : "secondary")">
                                    @(c.IsHoliday ? "Yes" : "No")
                                </span>
                            </td>
                            <td>@c.HolidayName</td>
                            <td>@c.EffectiveCapacity.ToString("F1")</td>
                            <td>@c.ReservedCapacity.ToString("F1")</td>
                            <td>@c.RemainingCapacity.ToString("F1")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<CalendarDay> calendar = new();
    private bool isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCalendar();
        isLoaded = true;
    }

    private async Task LoadCalendar()
    {
        var result = await Mediator.Send(new GetCalendarQuery());
        calendar = result.Value;
    }

    private async Task RefreshData()
    {
        await LoadCalendar();
    }
}
