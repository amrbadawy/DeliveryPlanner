@page "/calendar"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Calendar.Queries
@using SoftwareDeliveryPlanner.Domain.Models
@inject IMediator Mediator

<PageTitle>Calendar</PageTitle>

<!-- ── Toast (shared component) ───────────────────────────── -->
<ToastNotification @ref="toast" TestId="calendar-toast" />

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-calendar3 me-2"></i>Calendar</h3>
        <p class="page-subtitle">View working days, holidays, and capacity overview</p>
    </div>
    <div class="d-flex gap-2">
        @if (isLoaded && calendar.Any())
        {
            <button class="btn btn-outline-primary btn-sm" @onclick="JumpToToday" data-testid="calendar-jump-today">
                <i class="bi bi-geo-alt"></i> Today
            </button>
        }
        <button class="btn btn-outline-secondary" @onclick="RefreshData" disabled="@isRefreshing" data-testid="calendar-refresh">
            @if (isRefreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

@if (!isLoaded)
{
    <SkeletonLoader Variant="table" Rows="8" Columns="7" TestId="calendar-skeleton" />
}
else if (!calendar.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-calendar-x"></i></div>
        <h5>No calendar data</h5>
        <p>Click Refresh to generate the calendar.</p>
    </div>
}
else
{
    <!-- Filter bar -->
    <div class="card border-0 shadow-sm mb-3 filter-bar" data-testid="calendar-filter-bar">
        <div class="card-body py-2">
            <div class="row align-items-center g-2">
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @bind="selectedMonth" aria-label="Filter by month" data-testid="calendar-filter-month">
                        <option value="0">All Months</option>
                        @foreach (var m in availableMonths)
                        {
                            <option value="@m.Key">@m.Value</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="selectedDayType" aria-label="Filter by day type" data-testid="calendar-filter-type">
                        <option value="">All Days</option>
                        <option value="working">Working Days</option>
                        <option value="weekend">Weekends</option>
                        <option value="holiday">Holidays</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ClearFilters" data-testid="calendar-clear-filters">Clear</button>
                </div>
                <div class="col-md-5 text-muted small text-end">
                    Page @currentPage of @TotalPages (@FilteredCalendar.Count total days)
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" data-testid="calendar-table">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Day</th>
                        <th>Working Day</th>
                        <th>Holiday</th>
                        <th>Name</th>
                        <th>Base Capacity</th>
                        <th>Reserved</th>
                        <th>Remaining</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in PagedCalendar)
                    {
                        var isToday = c.CalendarDate.Date == DateTime.Today;
                        var rowClass = isToday ? "calendar-today" : (c.IsHoliday ? "day-holiday" : c.IsWorkingDay ? "day-working" : "day-weekend");
                        <tr class="@rowClass">
                            <td>
                                @if (isToday) { <i class="bi bi-geo-alt-fill text-primary me-1"></i> }
                                @c.CalendarDate.ToString("yyyy-MM-dd")
                            </td>
                            <td>@c.DayName</td>
                            <td>
                                <span class="badge bg-@(c.IsWorkingDay ? "success" : "secondary")">
                                    @(c.IsWorkingDay ? "Yes" : "No")
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-@(c.IsHoliday ? "warning" : "secondary")">
                                    @(c.IsHoliday ? "Yes" : "No")
                                </span>
                            </td>
                            <td>@c.HolidayName</td>
                            <td>@c.EffectiveCapacity.ToString("F1")</td>
                            <td>@c.ReservedCapacity.ToString("F1")</td>
                            <td>
                                <span class="@GetCapacityClass(c)">
                                    @c.RemainingCapacity.ToString("F1")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="pagination-bar" data-testid="calendar-pagination">
            <div>
                Page @currentPage of @TotalPages (@FilteredCalendar.Count total days)
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage <= 1)" @onclick="PrevPage" data-testid="calendar-prev">
                    <i class="bi bi-chevron-left"></i> Previous
                </button>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage >= TotalPages)" @onclick="NextPage" data-testid="calendar-next">
                    Next <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<CalendarDay> calendar = new();
    private List<CalendarDay> _filteredCache = new();
    private bool isLoaded = false;
    private bool isRefreshing = false;
    private ToastNotification toast = default!;
    private int currentPage = 1;
    private const int pageSize = 30;

    // Filters
    private int _selectedMonth = 0;
    private string _selectedDayType = string.Empty;

    private int selectedMonth
    {
        get => _selectedMonth;
        set { _selectedMonth = value; InvalidateFilterCache(); }
    }

    private string selectedDayType
    {
        get => _selectedDayType;
        set { _selectedDayType = value; InvalidateFilterCache(); }
    }

    private List<CalendarDay> FilteredCalendar => _filteredCache;

    private void InvalidateFilterCache()
    {
        IEnumerable<CalendarDay> result = calendar;

        if (_selectedMonth > 0)
        {
            var year = _selectedMonth / 100;
            var month = _selectedMonth % 100;
            result = result.Where(c => c.CalendarDate.Year == year && c.CalendarDate.Month == month);
        }

        if (!string.IsNullOrEmpty(_selectedDayType))
        {
            result = _selectedDayType switch
            {
                "working" => result.Where(c => c.IsWorkingDay),
                "weekend" => result.Where(c => !c.IsWorkingDay && !c.IsHoliday),
                "holiday" => result.Where(c => c.IsHoliday),
                _ => result
            };
        }

        _filteredCache = result.ToList();
    }

    private int TotalPages => _filteredCache.Count == 0 ? 1 : (int)Math.Ceiling((double)_filteredCache.Count / pageSize);

    private IEnumerable<CalendarDay> PagedCalendar =>
        _filteredCache.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private Dictionary<int, string> availableMonths
    {
        get
        {
            return calendar
                .Select(c => new { c.CalendarDate.Year, c.CalendarDate.Month })
                .Distinct()
                .OrderBy(x => x.Year).ThenBy(x => x.Month)
                .ToDictionary(
                    x => x.Year * 100 + x.Month,
                    x => new DateTime(x.Year, x.Month, 1).ToString("MMM yyyy"));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCalendar();
        isLoaded = true;
    }

    private async Task LoadCalendar()
    {
        var result = await Mediator.Send(new GetCalendarQuery());
        calendar = result.Value;
        InvalidateFilterCache();
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        try
        {
            await LoadCalendar();
            currentPage = 1;
            toast.Show("Calendar refreshed.");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private void JumpToToday()
    {
        _selectedMonth = 0;
        _selectedDayType = string.Empty;
        InvalidateFilterCache();
        var todayIndex = _filteredCache.FindIndex(c => c.CalendarDate.Date >= DateTime.Today);
        if (todayIndex >= 0)
            currentPage = (todayIndex / pageSize) + 1;
        else
            currentPage = TotalPages;
    }

    private void ClearFilters()
    {
        _selectedMonth = 0;
        _selectedDayType = string.Empty;
        InvalidateFilterCache();
        currentPage = 1;
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private string GetCapacityClass(CalendarDay c)
    {
        if (!c.IsWorkingDay) return "";
        if (c.EffectiveCapacity <= 0) return "";

        var pct = c.RemainingCapacity / c.EffectiveCapacity * 100;
        return pct switch
        {
            <= 10 => "fw-bold text-danger",
            <= 50 => "fw-semibold text-warning",
            _ => "text-success"
        };
    }
}
