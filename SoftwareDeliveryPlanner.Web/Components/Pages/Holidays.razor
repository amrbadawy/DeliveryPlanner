@page "/holidays"
@using MediatR
@using FluentValidation
@using SoftwareDeliveryPlanner.Application.Holidays.Queries
@using SoftwareDeliveryPlanner.Application.Holidays.Commands
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Application.Abstractions
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator
@inject SoftwareDeliveryPlanner.Web.Services.AutoScheduleService autoSchedule
@implements IDisposable
<PageTitle>Holidays</PageTitle>

<!-- ── Header ─────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-calendar2-heart me-2"></i>Holidays</h3>
        <p class="page-subtitle">Manage official holidays that affect the delivery schedule</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="holidays-add">
            <i class="bi bi-plus-lg"></i> Add Holiday
        </button>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" disabled="@isRefreshing" data-testid="holidays-refresh">
            @if (isRefreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
        @if (holidays.Any())
        {
            <button class="btn btn-outline-info" @onclick="ShowCopyModal" data-testid="holidays-copy">
                <i class="bi bi-copy"></i> Copy to Year
            </button>
        }
    </div>
</div>

<!-- ── Toast (shared component) ───────────────────────────── -->
<ToastNotification @ref="toast" TestId="holidays-toast" />

<!-- ── KPI Summary Bar ────────────────────────────────────── -->
@if (!isLoading && holidays.Any())
{
    <div class="row g-3 mb-4" data-testid="holidays-kpi">
        <div class="col-md-4">
            <div class="kpi-card p-3 text-center">
                <div class="kpi-label">Total Holidays</div>
                <div class="kpi-value kpi-text-primary">@holidays.Count</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi-card kpi-danger p-3 text-center">
                <div class="kpi-label">Working Days Lost</div>
                <div class="kpi-value kpi-text-danger">@totalWorkingDaysLost</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi-card kpi-success p-3 text-center">
                <div class="kpi-label">Next Holiday</div>
                <div class="kpi-value kpi-value-sm kpi-text-success">
                    @if (nextHoliday != null)
                    {
                        <span>@nextHoliday.HolidayName</span>
                        <br /><small class="text-muted">@nextHoliday.StartDate.ToString("MMM dd, yyyy")</small>
                    }
                    else
                    {
                        <span class="text-muted">None upcoming</span>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Filters ─────────────────────────────────────────────── -->
@if (!isLoading && holidays.Any())
{
    <div class="card border-0 shadow-sm mb-3 filter-bar" data-testid="holidays-filter-bar">
        <div class="card-body py-2">
            <div class="row align-items-center g-2">
                <div class="col-md-4">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input class="form-control" placeholder="Search holidays..." value="@searchInput" @oninput="OnSearchInput" aria-label="Search holidays" data-testid="holidays-search" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @bind="selectedYear" aria-label="Filter by year" data-testid="holidays-year-filter">
                        <option value="0">All Years</option>
                        @foreach (var y in availableYears)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @bind="selectedType" aria-label="Filter by type" data-testid="holidays-type-filter">
                        <option value="">All Types</option>
                        <option value="National">National</option>
                        <option value="Religious">Religious</option>
                        <option value="Company">Company</option>
                    </select>
                </div>
                <div class="col-md-2 text-muted small text-end">
                    @filteredHolidays.Count of @holidays.Count
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Loading State ───────────────────────────────────────── -->
@if (isLoading)
{
    <SkeletonLoader Variant="kpi" Columns="3" TestId="holidays-skeleton-kpi" />
    <SkeletonLoader Variant="table" Rows="5" Columns="6" TestId="holidays-skeleton-table" />
}
<!-- ── Empty State ─────────────────────────────────────────── -->
else if (!holidays.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-calendar-x"></i></div>
        <h5>No holidays configured</h5>
        <p>Add holidays to accurately calculate delivery schedules.</p>
        <button class="btn btn-primary" @onclick="ShowAddModal">
            <i class="bi bi-plus-lg"></i> Add First Holiday
        </button>
    </div>
}
<!-- ── Table ───────────────────────────────────────────────── -->
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" data-testid="holidays-table">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => ApplySort("HolidayName")' aria-sort="@AriaSort("HolidayName")">Name @SortIndicator("HolidayName")</th>
                        <th role="button" @onclick='() => ApplySort("StartDate")' aria-sort="@AriaSort("StartDate")">Start Date @SortIndicator("StartDate")</th>
                        <th role="button" @onclick='() => ApplySort("EndDate")' aria-sort="@AriaSort("EndDate")">End Date @SortIndicator("EndDate")</th>
                        <th>Duration</th>
                        <th role="button" @onclick='() => ApplySort("HolidayType")' aria-sort="@AriaSort("HolidayType")">Type @SortIndicator("HolidayType")</th>
                        <th>Notes</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in filteredHolidays)
                    {
                        var isPast = h.EndDate.Date < DateTime.Today;
                        <tr class="@(isPast ? "table-secondary opacity-75" : "")" data-testid="holidays-row-@h.Id">
                            <td>
                                @if (isPast) { <i class="bi bi-clock-history text-muted me-1"></i> }
                                @h.HolidayName
                            </td>
                            <td>@h.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@h.EndDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="badge bg-light text-dark">
                                    @h.DurationDays day@(h.DurationDays > 1 ? "s" : "")
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-@(h.HolidayType == DomainConstants.HolidayType.National ? "primary" : h.HolidayType == DomainConstants.HolidayType.Religious ? "warning text-dark" : "info")">
                                    @h.HolidayType
                                </span>
                            </td>
                            <td class="text-muted">@h.Notes</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => EditHoliday(h)" aria-label="Edit @h.HolidayName" data-testid="holidays-edit-@h.Id">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteHoliday(h)" aria-label="Delete @h.HolidayName" data-testid="holidays-delete-@h.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ── Add/Edit Modal ──────────────────────────────────────── -->
@if (showModal)
{
    <div class="modal d-block modal-backdrop-custom" role="dialog" aria-modal="true" aria-labelledby="holidays-modal-title" data-testid="holidays-modal">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="holidays-modal-title">
                        <i class="bi bi-@(editingHoliday == null ? "plus-circle" : "pencil-square")"></i>
                        @(editingHoliday == null ? "Add New Holiday" : "Edit Holiday")
                    </h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(modalError))
                    {
                        <div class="alert alert-danger" data-testid="holidays-error">
                            <i class="bi bi-exclamation-triangle"></i> @modalError
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Holiday Name <span class="required-indicator">*</span></label>
                        <input class="form-control @(fieldErrors.ContainsKey("HolidayName") ? "is-invalid" : "")"
                               @bind="formName" data-testid="holidays-name" />
                        @if (fieldErrors.ContainsKey("HolidayName"))
                        {
                            <div class="invalid-feedback">@fieldErrors["HolidayName"]</div>
                        }
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Start Date <span class="required-indicator">*</span></label>
                            <input class="form-control @(fieldErrors.ContainsKey("StartDate") ? "is-invalid" : "")"
                                   type="date" @bind="formStartDate" @bind:event="onchange" data-testid="holidays-start-date" />
                            @if (fieldErrors.ContainsKey("StartDate"))
                            {
                                <div class="invalid-feedback">@fieldErrors["StartDate"]</div>
                            }
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">End Date <span class="required-indicator">*</span></label>
                            <input class="form-control @(fieldErrors.ContainsKey("EndDate") ? "is-invalid" : "")"
                                   type="date" @bind="formEndDate" @bind:event="onchange" data-testid="holidays-end-date" />
                            @if (fieldErrors.ContainsKey("EndDate"))
                            {
                                <div class="invalid-feedback">@fieldErrors["EndDate"]</div>
                            }
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Type</label>
                            <select class="form-select" @bind="formType" data-testid="holidays-type">
                                <option>National</option>
                                <option>Religious</option>
                                <option>Company</option>
                            </select>
                        </div>
                    </div>

                    <!-- ── Impact Preview ─────────────────────────── -->
                    @if (formStartDate <= formEndDate)
                    {
                        var days = (formEndDate - formStartDate).Days + 1;
                        var workingDays = CountWorkingDaysInRange(formStartDate, formEndDate);
                        var allWeekend = workingDays == 0 && days > 0;

                        <div class="card bg-light border-0 mb-3" data-testid="holidays-impact">
                            <div class="card-body py-2">
                                <div class="row text-center">
                                    <div class="col">
                                        <small class="text-muted">Calendar Days</small>
                                        <div class="fw-bold">@days</div>
                                    </div>
                                    <div class="col">
                                        <small class="text-muted">Working Days Affected</small>
                                        <div class="fw-bold text-danger">@workingDays</div>
                                    </div>
                                </div>
                                @if (allWeekend)
                                {
                                    <div class="text-center mt-2">
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-exclamation-triangle"></i> All selected dates fall on weekends (Fri/Sat) - no working days affected
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Notes</label>
                        <textarea class="form-control" rows="2" @bind="formNotes" data-testid="holidays-notes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveHoliday" disabled="@isSaving" data-testid="holidays-save">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        <i class="bi bi-check-lg"></i> Save
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseModal" disabled="@isSaving" data-testid="holidays-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Delete Confirm (shared component) ───────────────────── -->
@if (showDeleteConfirm)
{
    <ConfirmDialog
        Visible="true"
        TestId="holidays-delete-modal"
        Title="Confirm Delete"
        Message="@($"Are you sure you want to delete \"{editingHoliday?.HolidayName}\"?")"
        IsProcessing="isDeleting"
        OnConfirm="ConfirmDelete"
        OnCancel="CloseDeleteModal" />
}

<!-- ── Copy to Year Modal ──────────────────────────────────── -->
@if (showCopyModal)
{
    <div class="modal d-block modal-backdrop-custom" role="dialog" aria-modal="true" aria-labelledby="holidays-copy-title" data-testid="holidays-copy-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="holidays-copy-title"><i class="bi bi-copy"></i> Copy Holidays to Year</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="() => showCopyModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">From Year</label>
                            <select class="form-select" @bind="copyFromYear">
                                @foreach (var y in availableYears)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">To Year</label>
                            <input class="form-control" type="number" @bind="copyToYear" min="2020" max="2050" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="DoCopyToYear" disabled="@isCopying" data-testid="holidays-copy-confirm">
                        @if (isCopying)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        <i class="bi bi-copy"></i> Copy
                    </button>
                    <button class="btn btn-secondary" @onclick="() => showCopyModal = false" disabled="@isCopying">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── State ────────────────────────────────────────────────
    private List<Holiday> holidays = new();
    private bool isLoading = true;
    private bool showModal;
    private bool showDeleteConfirm;
    private bool showCopyModal;
    private Holiday? editingHoliday;
    private string modalError = string.Empty;
    private Dictionary<string, string> fieldErrors = new();
    private ToastNotification toast = default!;
    private bool isSaving = false;
    private bool isDeleting = false;
    private bool isRefreshing = false;
    private bool isCopying = false;

    // Form fields
    private string formName = string.Empty;
    private DateTime formStartDate;
    private DateTime formEndDate;
    private string formType = DomainConstants.HolidayType.National;
    private string? formNotes;

    // Filters
    private string searchTerm = string.Empty;
    private string searchInput = string.Empty;
    private System.Threading.Timer? _debounceTimer;
    private int selectedYear;
    private string selectedType = string.Empty;

    // Sort
    private string sortColumn = string.Empty;
    private bool sortAscending = true;

    // Copy
    private int copyFromYear;
    private int copyToYear;

    // KPI computed
    private int totalWorkingDaysLost;
    private Holiday? nextHoliday;

    // ── Computed ──────────────────────────────────────────────

    private IEnumerable<int> availableYears =>
        holidays.Select(h => h.StartDate.Year).Distinct().OrderBy(y => y);

    private IReadOnlyList<Holiday> filteredHolidays
    {
        get
        {
            var q = holidays.AsEnumerable();
            if (selectedYear > 0)
                q = q.Where(h => h.StartDate.Year == selectedYear);
            if (!string.IsNullOrEmpty(selectedType))
                q = q.Where(h => h.HolidayType == selectedType);
            if (!string.IsNullOrWhiteSpace(searchTerm))
                q = q.Where(h => h.HolidayName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                    || (h.Notes ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(sortColumn))
            {
                q = sortColumn switch
                {
                    "HolidayName" => sortAscending ? q.OrderBy(h => h.HolidayName) : q.OrderByDescending(h => h.HolidayName),
                    "StartDate" => sortAscending ? q.OrderBy(h => h.StartDate) : q.OrderByDescending(h => h.StartDate),
                    "EndDate" => sortAscending ? q.OrderBy(h => h.EndDate) : q.OrderByDescending(h => h.EndDate),
                    "HolidayType" => sortAscending ? q.OrderBy(h => h.HolidayType) : q.OrderByDescending(h => h.HolidayType),
                    _ => q
                };
            }

            return q.ToList();
        }
    }

    // ── Lifecycle ────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadHolidays();
        isLoading = false;
    }

    private async Task LoadHolidays()
    {
        var result = await Mediator.Send(new GetHolidaysQuery());
        holidays = result.Value;
        ComputeKpis();
    }

    private void ComputeKpis()
    {
        totalWorkingDaysLost = holidays.Sum(h => CountWorkingDaysInRange(h.StartDate, h.EndDate));
        nextHoliday = holidays.Where(h => h.EndDate.Date >= DateTime.Today).OrderBy(h => h.StartDate).FirstOrDefault();
        if (availableYears.Any())
            copyFromYear = availableYears.Max();
        copyToYear = (availableYears.Any() ? availableYears.Max() : DateTime.Today.Year) + 1;
    }

    /// <summary>Client-side working-day counter (Sun-Thu). Used for impact preview and KPI.</summary>
    private int CountWorkingDaysInRange(DateTime start, DateTime end)
    {
        int count = 0;
        var current = start.Date;
        while (current <= end.Date)
        {
            var dow = (int)current.DayOfWeek;
            if (dow != 5 && dow != 6) count++;
            current = current.AddDays(1);
        }
        return count;
    }

    // ── Add / Edit ───────────────────────────────────────────

    private void ShowAddModal()
    {
        editingHoliday = null;
        formName = string.Empty;
        formStartDate = DateTime.Today;
        formEndDate = DateTime.Today;
        formType = DomainConstants.HolidayType.National;
        formNotes = null;
        modalError = string.Empty;
        fieldErrors.Clear();
        showModal = true;
    }

    private void EditHoliday(Holiday h)
    {
        editingHoliday = h;
        formName = h.HolidayName;
        formStartDate = h.StartDate;
        formEndDate = h.EndDate;
        formType = h.HolidayType;
        formNotes = h.Notes;
        modalError = string.Empty;
        fieldErrors.Clear();
        showModal = true;
    }

    private async Task SaveHoliday()
    {
        modalError = string.Empty;
        fieldErrors.Clear();
        isSaving = true;
        try
        {
            var command = new UpsertHolidayCommand(
                Id: editingHoliday?.Id ?? 0,
                HolidayName: formName,
                StartDate: formStartDate,
                EndDate: formEndDate,
                HolidayType: formType,
                Notes: formNotes,
                IsNew: editingHoliday == null);

            var result = await Mediator.Send(command);
            await LoadHolidays();
            var message = editingHoliday == null ? "Holiday added successfully." : "Holiday updated successfully.";
            CloseModal();
            toast.Show(message);
            await AutoScheduleIfEnabled();
        }
        catch (ValidationException ex)
        {
            foreach (var err in ex.Errors)
            {
                if (!string.IsNullOrWhiteSpace(err.PropertyName) && !fieldErrors.ContainsKey(err.PropertyName))
                    fieldErrors[err.PropertyName] = err.ErrorMessage;
            }
            modalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── Delete ───────────────────────────────────────────────

    private void DeleteHoliday(Holiday h)
    {
        editingHoliday = h;
        showDeleteConfirm = true;
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        try
        {
            if (editingHoliday != null)
            {
                var result = await Mediator.Send(new DeleteHolidayCommand(editingHoliday.Id));
                toast.Show($"Holiday \"{editingHoliday.HolidayName}\" deleted.");
            }
            showDeleteConfirm = false;
            editingHoliday = null;
            StateHasChanged();
            await Task.Yield();
            await LoadHolidays();
            await AutoScheduleIfEnabled();
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void CloseModal()
    {
        showModal = false;
        editingHoliday = null;
        modalError = string.Empty;
        fieldErrors.Clear();
    }

    private void CloseDeleteModal()
    {
        showDeleteConfirm = false;
        editingHoliday = null;
    }

    // ── Copy to Year ─────────────────────────────────────────

    private void ShowCopyModal()
    {
        showCopyModal = true;
    }

    private async Task DoCopyToYear()
    {
        isCopying = true;
        try
        {
            var result = await Mediator.Send(new CopyHolidaysToYearCommand(copyFromYear, copyToYear));
            var copied = result.Value;
            showCopyModal = false;
            await LoadHolidays();
            toast.Show(copied > 0
                ? $"Copied {copied} holiday(s) from {copyFromYear} to {copyToYear}."
                : $"No holidays copied (target year may already have overlapping dates).");
        }
        finally
        {
            isCopying = false;
        }
    }

    // ── Refresh ──────────────────────────────────────────────

    private async Task RefreshData()
    {
        isRefreshing = true;
        try
        {
            var result = await Mediator.Send(new RunSchedulerCommand());
            await LoadHolidays();
            toast.Show("Schedule refreshed.");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    // ── Search Debounce ──────────────────────────────────────

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchInput = e.Value?.ToString() ?? string.Empty;
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(_ =>
            InvokeAsync(() => { searchTerm = searchInput; StateHasChanged(); }),
            null, 300, System.Threading.Timeout.Infinite);
    }

    // ── Sort ───────────────────────────────────────────────────

    private void ApplySort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? "▲" : "▼";
    }

    private string AriaSort(string column) =>
        sortColumn != column ? "none" : sortAscending ? "ascending" : "descending";

    private async Task AutoScheduleIfEnabled()
    {
        if (autoSchedule.IsEnabled)
        {
            await Mediator.Send(new RunSchedulerCommand());
            await LoadHolidays();
        }
    }

    public void Dispose() => _debounceTimer?.Dispose();
}
