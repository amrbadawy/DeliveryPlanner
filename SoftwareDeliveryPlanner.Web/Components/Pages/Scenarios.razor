@page "/scenarios"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Scenarios.Commands
@using SoftwareDeliveryPlanner.Application.Scenarios.Queries
@using SoftwareDeliveryPlanner.Domain.Models
@inject IMediator Mediator
@inject NavigationManager NavigationManager

<PageTitle>What-If Scenarios</PageTitle>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-layers me-2"></i>What-If Scenarios</h3>
        <p class="page-subtitle">Save snapshots of the current plan and compare KPIs side by side</p>
    </div>
    <div>
        <button class="btn btn-primary" @onclick="OpenSaveModal" data-testid="scenarios-save">
            <i class="bi bi-camera me-1"></i> Save Current Plan
        </button>
    </div>
</div>

@if (errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null" data-testid="scenarios-alert-dismiss"></button>
    </div>
}

<!-- Save Modal -->
@if (showSaveModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" data-testid="scenarios-save-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Save Current Plan as Scenario</h5>
                    <button type="button" class="btn-close" @onclick="CloseSaveModal" data-testid="scenarios-modal-close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Scenario Name</label>
                        <input type="text" class="form-control" @bind="newScenarioName" data-testid="scenarios-name-input" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes (optional)</label>
                        <textarea class="form-control" rows="3" @bind="newScenarioNotes" data-testid="scenarios-notes-input"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseSaveModal" data-testid="scenarios-save-cancel">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveScenario" disabled="@isSaving" data-testid="scenarios-save-confirm">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Scenarios Table -->
<div class="card border-0 shadow-sm mb-4" data-testid="scenarios-table">
    <div class="card-body">
        @if (scenarios is null)
        {
            <div class="text-center py-4">
                <span class="spinner-border spinner-border-sm"></span> Loading...
            </div>
        }
        else if (!scenarios.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-layers fs-1 d-block mb-2"></i>
                No scenarios saved yet. Click "Save Current Plan" to create your first snapshot.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Created</th>
                            <th class="text-center">Total Tasks</th>
                            <th class="text-center">On Track</th>
                            <th class="text-center">At Risk</th>
                            <th class="text-center">Late</th>
                            <th class="text-center">Latest Finish</th>
                            <th class="text-center">Total Est.</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in scenarios)
                        {
                            <tr>
                                <td><strong>@s.ScenarioName</strong>@if (!string.IsNullOrEmpty(s.Notes)) { <br /><small class="text-muted">@s.Notes</small> }</td>
                                <td>@s.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="text-center">@s.TotalTasks</td>
                                <td class="text-center"><span class="badge bg-success">@s.OnTrackCount</span></td>
                                <td class="text-center"><span class="badge bg-warning text-dark">@s.AtRiskCount</span></td>
                                <td class="text-center"><span class="badge bg-danger">@s.LateCount</span></td>
                                <td class="text-center">@(s.LatestFinish?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td class="text-center">@s.TotalEstimation.ToString("F1")</td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => ViewScenarioGantt(s.Id)" data-testid="scenarios-view-@s.Id"
                                            title="View Gantt Chart">
                                        <i class="bi bi-bar-chart-steps"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteScenario(s.Id)" data-testid="scenarios-delete-@s.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Comparison Section -->
@if (scenarios is not null && scenarios.Count >= 2)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-arrow-left-right me-2"></i>Compare Scenarios</h5>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Scenario A</label>
                    <select class="form-select" @bind="compareAId" data-testid="scenarios-compare-a">
                        <option value="0">— Select —</option>
                        @foreach (var s in scenarios)
                        {
                            <option value="@s.Id">@s.ScenarioName (@s.CreatedAt.ToString("MMM dd"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Scenario B</label>
                    <select class="form-select" @bind="compareBId" data-testid="scenarios-compare-b">
                        <option value="0">— Select —</option>
                        @foreach (var s in scenarios)
                        {
                            <option value="@s.Id">@s.ScenarioName (@s.CreatedAt.ToString("MMM dd"))</option>
                        }
                    </select>
                </div>
            </div>

            @if (CompareA is not null && CompareB is not null)
            {
                <div class="row g-3 mt-3" data-testid="scenarios-comparison">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header"><strong>@CompareA.ScenarioName</strong></div>
                            <div class="card-body">
                                <div class="row text-center">
                                    <div class="col"><small class="text-muted">On Track</small><div class="fw-bold text-success">@CompareA.OnTrackCount</div></div>
                                    <div class="col"><small class="text-muted">At Risk</small><div class="fw-bold text-warning">@CompareA.AtRiskCount</div></div>
                                    <div class="col"><small class="text-muted">Late</small><div class="fw-bold text-danger">@CompareA.LateCount</div></div>
                                    <div class="col"><small class="text-muted">Finish</small><div class="fw-bold">@(CompareA.LatestFinish?.ToString("MMM dd") ?? "—")</div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header"><strong>@CompareB.ScenarioName</strong></div>
                            <div class="card-body">
                                <div class="row text-center">
                                    <div class="col"><small class="text-muted">On Track</small><div class="fw-bold text-success">@CompareB.OnTrackCount</div></div>
                                    <div class="col"><small class="text-muted">At Risk</small><div class="fw-bold text-warning">@CompareB.AtRiskCount</div></div>
                                    <div class="col"><small class="text-muted">Late</small><div class="fw-bold text-danger">@CompareB.LateCount</div></div>
                                    <div class="col"><small class="text-muted">Finish</small><div class="fw-bold">@(CompareB.LatestFinish?.ToString("MMM dd") ?? "—")</div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Delta row -->
                <div class="card border-0 shadow-sm mt-3" data-testid="scenarios-delta">
                    <div class="card-body text-center">
                        <h6>Difference (B vs A)</h6>
                        <div class="row">
                            <div class="col">
                                <small class="text-muted">On Track</small>
                                <div class="fw-bold @(DeltaClass(OnTrackDelta, true))">@FormatDelta(OnTrackDelta)</div>
                            </div>
                            <div class="col">
                                <small class="text-muted">At Risk</small>
                                <div class="fw-bold @(DeltaClass(AtRiskDelta, false))">@FormatDelta(AtRiskDelta)</div>
                            </div>
                            <div class="col">
                                <small class="text-muted">Late</small>
                                <div class="fw-bold @(DeltaClass(LateDelta, false))">@FormatDelta(LateDelta)</div>
                            </div>
                            <div class="col">
                                <small class="text-muted">Total Est.</small>
                                <div class="fw-bold @(DeltaClass(EstDelta, false))">@FormatDelta(EstDelta)</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<PlanScenario>? scenarios;
    private bool showSaveModal;
    private string newScenarioName = string.Empty;
    private string? newScenarioNotes;
    private bool isSaving;
    private string? errorMessage;

    private int compareAId;
    private int compareBId;

    private PlanScenario? CompareA => scenarios?.FirstOrDefault(s => s.Id == compareAId);
    private PlanScenario? CompareB => scenarios?.FirstOrDefault(s => s.Id == compareBId);

    private int OnTrackDelta => (CompareB?.OnTrackCount ?? 0) - (CompareA?.OnTrackCount ?? 0);
    private int AtRiskDelta => (CompareB?.AtRiskCount ?? 0) - (CompareA?.AtRiskCount ?? 0);
    private int LateDelta => (CompareB?.LateCount ?? 0) - (CompareA?.LateCount ?? 0);
    private double EstDelta => (CompareB?.TotalEstimation ?? 0) - (CompareA?.TotalEstimation ?? 0);

    protected override async Task OnInitializedAsync()
    {
        await LoadScenarios();
    }

    private async Task LoadScenarios()
    {
        var result = await Mediator.Send(new GetScenariosQuery());
        if (result.IsSuccess)
            scenarios = result.Value;
    }

    private void OpenSaveModal()
    {
        newScenarioName = string.Empty;
        newScenarioNotes = null;
        showSaveModal = true;
    }

    private void CloseSaveModal() => showSaveModal = false;

    private async Task SaveScenario()
    {
        if (string.IsNullOrWhiteSpace(newScenarioName)) return;

        isSaving = true;
        errorMessage = null;

        try
        {
            var result = await Mediator.Send(new SaveScenarioCommand(newScenarioName, newScenarioNotes));
            if (result.IsFailure)
            {
                errorMessage = result.Error.Message;
            }
            else
            {
                showSaveModal = false;
                await LoadScenarios();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteScenario(int id)
    {
        await Mediator.Send(new DeleteScenarioCommand(id));
        await LoadScenarios();
    }

    private void ViewScenarioGantt(int id)
    {
        NavigationManager.NavigateTo($"/scenarios/{id}/gantt");
    }

    private static string FormatDelta(int delta) => delta switch
    {
        > 0 => $"+{delta}",
        < 0 => delta.ToString(),
        _ => "0"
    };

    private static string FormatDelta(double delta) => delta switch
    {
        > 0 => $"+{delta:F1}",
        < 0 => delta.ToString("F1"),
        _ => "0"
    };

    private static string DeltaClass(int delta, bool positiveIsGood) => delta switch
    {
        > 0 => positiveIsGood ? "text-success" : "text-danger",
        < 0 => positiveIsGood ? "text-danger" : "text-success",
        _ => "text-muted"
    };

    private static string DeltaClass(double delta, bool positiveIsGood) => delta switch
    {
        > 0 => positiveIsGood ? "text-success" : "text-danger",
        < 0 => positiveIsGood ? "text-danger" : "text-success",
        _ => "text-muted"
    };
}
