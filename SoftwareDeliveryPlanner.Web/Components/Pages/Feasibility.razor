@page "/feasibility"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Planning.Queries
@using SoftwareDeliveryPlanner.Application.Abstractions
@inject IMediator Mediator

<PageTitle>Capacity Feasibility</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-clipboard-check me-2"></i>Capacity Feasibility</h3>
        <p class="page-subtitle">Whether tasks with strict deadlines can be met given current resources</p>
    </div>
    <div>
        <button class="btn btn-outline-secondary" @onclick="LoadData" disabled="@isLoading" data-testid="feasibility-refresh">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

@if (isLoading)
{
    <SkeletonLoader Variant="table" Rows="5" Columns="6" TestId="feasibility-skeleton" />
}
else if (!results.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5" data-testid="feasibility-empty">
            <i class="bi bi-info-circle text-muted" style="font-size:3rem;"></i>
            <h5 class="mt-3">No tasks with strict deadlines</h5>
            <p class="text-muted">Add tasks with a strict date to see feasibility analysis.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0" data-testid="feasibility-table">
                <thead class="table-light">
                    <tr>
                        <th>Task ID</th>
                        <th>Service Name</th>
                        <th>Feasible</th>
                        <th>Earliest Finish</th>
                        <th>Slack Days</th>
                        <th>Bottleneck</th>
                        <th>Recommendation</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in results)
                    {
                        <tr data-testid="feasibility-row-@r.TaskId">
                            <td><strong>@r.TaskId</strong></td>
                            <td>@r.ServiceName</td>
                            <td>
                                <span class="badge bg-@(r.IsFeasible ? "success" : "danger")">
                                    @(r.IsFeasible ? "Feasible" : "Infeasible")
                                </span>
                            </td>
                            <td>@(r.EarliestFinish?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td>
                                <span class="@(r.SlackDays < 0 ? "text-danger fw-semibold" : r.SlackDays < 5 ? "text-warning" : "text-success")">
                                    @r.SlackDays
                                </span>
                            </td>
                            <td><small class="text-muted">@(r.Bottleneck ?? "—")</small></td>
                            <td><small>@(r.Recommendation ?? "—")</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<FeasibilityResultDto> results = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var result = await Mediator.Send(new GetFeasibilityQuery());
            results = result.IsSuccess ? result.Value : new();
        }
        finally
        {
            isLoading = false;
        }
    }
}
