@page "/resources"
@using MediatR
@using FluentValidation
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using SoftwareDeliveryPlanner.Application.Resources.Commands
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator

<PageTitle>Resources</PageTitle>

<h3 style="margin-bottom: 20px;">👥 Resources</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="resources-add">➕ Add Resource</button>
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="resources-refresh">🔄 Refresh</button>
</div>

<!-- Search / Filter bar -->
<div class="row mb-3 g-2" data-testid="resources-filter-bar">
    <div class="col-md-4">
        <input class="form-control" placeholder="Search by ID or name..." @bind="searchTerm" @bind:event="oninput" data-testid="resources-search" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="roleFilter" data-testid="resources-filter-role">
            <option value="">All Roles</option>
            <option value="@DomainConstants.ResourceRole.Developer">@DomainConstants.ResourceRole.Developer</option>
            <option value="@DomainConstants.ResourceRole.SeniorDeveloper">@DomainConstants.ResourceRole.SeniorDeveloper</option>
            <option value="@DomainConstants.ResourceRole.TechLead">@DomainConstants.ResourceRole.TechLead</option>
            <option value="@DomainConstants.ResourceRole.QA">@DomainConstants.ResourceRole.QA</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="activeFilter" data-testid="resources-filter-active">
            <option value="">All</option>
            <option value="@DomainConstants.ActiveStatus.Yes">Active</option>
            <option value="@DomainConstants.ActiveStatus.No">Inactive</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters" data-testid="resources-clear-filters">Clear</button>
    </div>
</div>

@if (showModal)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="resources-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingResource == null ? "Add New Resource" : "Edit Resource")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(modalError))
                    {
                        <div class="alert alert-danger" data-testid="resources-error">@modalError</div>
                    }
                    <div class="mb-2">
                        <label>Resource ID:</label>
                        <input class="form-control" @bind="resourceForm.ResourceId" disabled="@(editingResource != null)" data-testid="resources-id" />
                    </div>
                    <div class="mb-2">
                        <label>Name:</label>
                        <input class="form-control" @bind="resourceForm.ResourceName" data-testid="resources-name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Role:</label>
                            <select class="form-control" @bind="resourceForm.Role" data-testid="resources-role">
                                <option>Developer</option>
                                <option>Senior Developer</option>
                                <option>Tech Lead</option>
                                <option>QA</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Team:</label>
                            <input class="form-control" @bind="resourceForm.Team" data-testid="resources-team" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Availability (%):</label>
                            <input class="form-control" type="number" @bind="resourceForm.AvailabilityPct" data-testid="resources-availability" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Daily Capacity:</label>
                            <input class="form-control" type="number" step="0.1" @bind="resourceForm.DailyCapacity" data-testid="resources-daily-capacity" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Start Date:</label>
                            <input class="form-control" type="date" @bind="startDateValue" data-testid="resources-start-date" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Active:</label>
                            <select class="form-control" @bind="resourceForm.Active" data-testid="resources-active">
                                <option value="Yes">Yes</option>
                                <option value="No">No</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label>Notes:</label>
                        <textarea class="form-control" @bind="resourceForm.Notes" data-testid="resources-notes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveResource" data-testid="resources-save">Save</button>
                    <button class="btn btn-secondary" @onclick="CloseModal" data-testid="resources-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <ConfirmDialog
        Visible="true"
        TestId="resources-delete-modal"
        Title="Confirm Delete"
        Message="Are you sure you want to delete this resource?"
        OnConfirm="ConfirmDelete"
        OnCancel="CloseDeleteModal" />
}

<ToastNotification @ref="toast" TestId="resources-toast" />

<table class="table table-striped table-hover" data-testid="resources-table">
    <thead class="table-dark">
        <tr>
            <th role="button" @onclick='() => ApplySort("ResourceId")' data-testid="resources-sort-id">ID @SortIndicator("ResourceId")</th>
            <th role="button" @onclick='() => ApplySort("ResourceName")' data-testid="resources-sort-name">Name @SortIndicator("ResourceName")</th>
            <th role="button" @onclick='() => ApplySort("Role")' data-testid="resources-sort-role">Role @SortIndicator("Role")</th>
            <th role="button" @onclick='() => ApplySort("Team")' data-testid="resources-sort-team">Team @SortIndicator("Team")</th>
            <th role="button" @onclick='() => ApplySort("AvailabilityPct")' data-testid="resources-sort-avail">Availability % @SortIndicator("AvailabilityPct")</th>
            <th role="button" @onclick='() => ApplySort("DailyCapacity")' data-testid="resources-sort-cap">Capacity @SortIndicator("DailyCapacity")</th>
            <th role="button" @onclick='() => ApplySort("StartDate")' data-testid="resources-sort-start">Start Date @SortIndicator("StartDate")</th>
            <th role="button" @onclick='() => ApplySort("Active")' data-testid="resources-sort-active">Active @SortIndicator("Active")</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in FilteredResources)
        {
            <tr data-testid="resources-row-@r.ResourceId">
                <td>@r.ResourceId</td>
                <td>@r.ResourceName</td>
                <td>@r.Role</td>
                <td>@r.Team</td>
                <td>@r.AvailabilityPct%</td>
                <td>@r.DailyCapacity</td>
                <td>@r.StartDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge bg-@(r.Active == DomainConstants.ActiveStatus.Yes ? "success" : "secondary")">
                        @(r.Active == DomainConstants.ActiveStatus.Yes ? DomainConstants.ActiveStatus.Yes : DomainConstants.ActiveStatus.No)
                    </span>
                </td>
                <td>
                    <button class="btn btn-sm btn-warning" @onclick="() => EditResource(r)" data-testid="resources-edit-@r.ResourceId">✏️</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteResource(r)" data-testid="resources-delete-@r.ResourceId">🗑️</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!FilteredResources.Any() && resources.Any())
{
    <div class="text-center text-muted py-3" data-testid="resources-no-results">No resources match the current filters.</div>
}

@code {
    private List<TeamMember> resources = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private TeamMember? editingResource;
    private ResourceFormModel resourceForm = new();
    private DateTime startDateValue;
    private string modalError = string.Empty;
    private ToastNotification toast = default!;

    // Search/Sort/Filter state
    private string searchTerm = string.Empty;
    private string roleFilter = string.Empty;
    private string activeFilter = string.Empty;
    private string sortColumn = string.Empty;
    private bool sortAscending = true;

    private class ResourceFormModel
    {
        public int Id { get; set; }
        public string ResourceId { get; set; } = string.Empty;
        public string ResourceName { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public string Team { get; set; } = string.Empty;
        public double AvailabilityPct { get; set; } = 100;
        public double DailyCapacity { get; set; } = 1;
        public DateTime StartDate { get; set; }
        public string Active { get; set; } = "Yes";
        public string? Notes { get; set; }
    }

    private IEnumerable<TeamMember> FilteredResources
    {
        get
        {
            IEnumerable<TeamMember> result = resources;

            // Search
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim();
                result = result.Where(r =>
                    r.ResourceId.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    r.ResourceName.Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            // Filter by role
            if (!string.IsNullOrEmpty(roleFilter))
                result = result.Where(r => r.Role == roleFilter);

            // Filter by active status
            if (!string.IsNullOrEmpty(activeFilter))
                result = result.Where(r => r.Active == activeFilter);

            // Sort
            if (!string.IsNullOrEmpty(sortColumn))
            {
                result = sortColumn switch
                {
                    "ResourceId" => sortAscending ? result.OrderBy(r => r.ResourceId) : result.OrderByDescending(r => r.ResourceId),
                    "ResourceName" => sortAscending ? result.OrderBy(r => r.ResourceName) : result.OrderByDescending(r => r.ResourceName),
                    "Role" => sortAscending ? result.OrderBy(r => r.Role) : result.OrderByDescending(r => r.Role),
                    "Team" => sortAscending ? result.OrderBy(r => r.Team) : result.OrderByDescending(r => r.Team),
                    "AvailabilityPct" => sortAscending ? result.OrderBy(r => r.AvailabilityPct) : result.OrderByDescending(r => r.AvailabilityPct),
                    "DailyCapacity" => sortAscending ? result.OrderBy(r => r.DailyCapacity) : result.OrderByDescending(r => r.DailyCapacity),
                    "StartDate" => sortAscending ? result.OrderBy(r => r.StartDate) : result.OrderByDescending(r => r.StartDate),
                    "Active" => sortAscending ? result.OrderBy(r => r.Active) : result.OrderByDescending(r => r.Active),
                    _ => result
                };
            }

            return result;
        }
    }

    private void ApplySort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? "▲" : "▼";
    }

    private void ClearFilters()
    {
        searchTerm = string.Empty;
        roleFilter = string.Empty;
        activeFilter = string.Empty;
        sortColumn = string.Empty;
        sortAscending = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadResources();
    }

    private async Task LoadResources()
    {
        var result = await Mediator.Send(new GetResourcesQuery());
        resources = result.Value;
    }

    private async Task ShowAddModal()
    {
        var countResult = await Mediator.Send(new GetResourceCountQuery());
        var count = countResult.Value;
        resourceForm = new ResourceFormModel
        {
            ResourceId = $"DEV-{(count + 1):D3}",
            Role = DomainConstants.ResourceRole.Developer,
            Team = DomainConstants.DefaultTeam,
            StartDate = DateTime.Today,
            Active = DomainConstants.ActiveStatus.Yes,
            AvailabilityPct = 100,
            DailyCapacity = 1
        };
        startDateValue = DateTime.Today;
        editingResource = null;
        modalError = string.Empty;
        showModal = true;
    }

    private void EditResource(TeamMember r)
    {
        editingResource = r;
        resourceForm = new ResourceFormModel
        {
            Id = r.Id,
            ResourceId = r.ResourceId,
            ResourceName = r.ResourceName,
            Role = r.Role,
            Team = r.Team,
            AvailabilityPct = r.AvailabilityPct,
            DailyCapacity = r.DailyCapacity,
            StartDate = r.StartDate,
            Active = r.Active,
            Notes = r.Notes
        };
        startDateValue = r.StartDate;
        modalError = string.Empty;
        showModal = true;
    }

    private void DeleteResource(TeamMember r)
    {
        editingResource = r;
        showDeleteConfirm = true;
    }

    private async Task SaveResource()
    {
        modalError = string.Empty;
        try
        {
            var command = new UpsertResourceCommand(
                Id: resourceForm.Id,
                ResourceId: resourceForm.ResourceId,
                ResourceName: resourceForm.ResourceName,
                Role: resourceForm.Role,
                Team: resourceForm.Team,
                AvailabilityPct: resourceForm.AvailabilityPct,
                DailyCapacity: resourceForm.DailyCapacity,
                StartDate: startDateValue,
                Active: resourceForm.Active,
                Notes: resourceForm.Notes,
                IsNew: editingResource == null);

            var result = await Mediator.Send(command);
            await LoadResources();
            CloseModal();
            toast.Show(editingResource == null ? "Resource added successfully." : "Resource updated successfully.");
        }
        catch (ValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
    }

    private async Task ConfirmDelete()
    {
        if (editingResource != null)
        {
            var result = await Mediator.Send(new DeleteResourceCommand(editingResource.Id));
            toast.Show($"Resource \"{editingResource.ResourceName}\" deleted.");
        }
        showDeleteConfirm = false;
        editingResource = null;
        await LoadResources();
    }

    private void CloseModal()
    {
        showModal = false;
        editingResource = null;
        modalError = string.Empty;
    }

    private void CloseDeleteModal()
    {
        showDeleteConfirm = false;
        editingResource = null;
    }

    private async Task RefreshData()
    {
        var result = await Mediator.Send(new RunSchedulerCommand());
        await LoadResources();
        toast.Show("Schedule refreshed.");
    }
}
