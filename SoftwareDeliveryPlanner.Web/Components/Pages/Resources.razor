@page "/resources"
@using MediatR
@using FluentValidation
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using SoftwareDeliveryPlanner.Application.Resources.Commands
@using SoftwareDeliveryPlanner.Application.Roles.Queries
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator
@inject SoftwareDeliveryPlanner.Web.Services.AutoScheduleService autoSchedule
@implements IDisposable
<PageTitle>Resources</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-people me-2"></i>Resources</h3>
        <p class="page-subtitle">Manage team members and their availability</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="resources-add">
            <i class="bi bi-plus-lg"></i> Add Resource
        </button>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" disabled="@isRefreshing" data-testid="resources-refresh">
            @if (isRefreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

<!-- Search / Filter bar -->
<div class="card border-0 shadow-sm mb-3 filter-bar" data-testid="resources-filter-bar">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control" placeholder="Search by ID or name..." value="@searchInput" @oninput="OnSearchInput" aria-label="Search resources" data-testid="resources-search" />
                </div>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="roleFilter" aria-label="Filter by role" data-testid="resources-filter-role">
                    <option value="">All Roles</option>
                    @foreach (var role in activeRoles)
                    {
                        <option value="@role.Code">@role.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="activeFilter" aria-label="Filter by active status" data-testid="resources-filter-active">
                    <option value="">All</option>
                    <option value="@DomainConstants.ActiveStatus.Yes">Active</option>
                    <option value="@DomainConstants.ActiveStatus.No">Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ClearFilters" data-testid="resources-clear-filters">Clear</button>
            </div>
            <div class="col-md-2 text-end text-muted small">
                @FilteredResources.Count() of @resources.Count resources
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal d-block modal-backdrop-custom" role="dialog" aria-modal="true" aria-labelledby="resources-modal-title" data-testid="resources-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="resources-modal-title">@(editingResource == null ? "Add New Resource" : "Edit Resource")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(modalError))
                    {
                        <div class="alert alert-danger" data-testid="resources-error">@modalError</div>
                    }
                    <div class="mb-2">
                        <label class="form-label">Resource ID:<span class="required-indicator">*</span></label>
                        <input class="form-control @(fieldErrors.ContainsKey("ResourceId") ? "is-invalid" : "")" @bind="resourceForm.ResourceId" disabled="@(editingResource != null)" data-testid="resources-id" />
                        @if (fieldErrors.ContainsKey("ResourceId"))
                        {
                            <div class="invalid-feedback">@fieldErrors["ResourceId"]</div>
                        }
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Name:<span class="required-indicator">*</span></label>
                        <input class="form-control @(fieldErrors.ContainsKey("ResourceName") ? "is-invalid" : "")" @bind="resourceForm.ResourceName" data-testid="resources-name" />
                        @if (fieldErrors.ContainsKey("ResourceName"))
                        {
                            <div class="invalid-feedback">@fieldErrors["ResourceName"]</div>
                        }
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Role:</label>
                            <select class="form-select" @bind="resourceForm.Role" data-testid="resources-role">
                                @foreach (var role in activeRoles)
                                {
                                    <option value="@role.Code">@role.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Team:</label>
                            <input class="form-control" @bind="resourceForm.Team" data-testid="resources-team" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Availability (%):</label>
                            <input class="form-control @(fieldErrors.ContainsKey("AvailabilityPct") ? "is-invalid" : "")" type="number" min="0" max="100" @bind="resourceForm.AvailabilityPct" data-testid="resources-availability" />
                            @if (fieldErrors.ContainsKey("AvailabilityPct"))
                            {
                                <div class="invalid-feedback">@fieldErrors["AvailabilityPct"]</div>
                            }
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Daily Capacity:</label>
                            <input class="form-control @(fieldErrors.ContainsKey("DailyCapacity") ? "is-invalid" : "")" type="number" min="0" step="0.1" @bind="resourceForm.DailyCapacity" data-testid="resources-daily-capacity" />
                            @if (fieldErrors.ContainsKey("DailyCapacity"))
                            {
                                <div class="invalid-feedback">@fieldErrors["DailyCapacity"]</div>
                            }
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Start Date:</label>
                            <input class="form-control" type="date" @bind="startDateValue" data-testid="resources-start-date" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Active:</label>
                            <select class="form-select" @bind="resourceForm.Active" data-testid="resources-active">
                                <option value="Yes">Yes</option>
                                <option value="No">No</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Notes:</label>
                        <textarea class="form-control" @bind="resourceForm.Notes" data-testid="resources-notes"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Seniority Level:</label>
                            <select class="form-select" @bind="resourceForm.SeniorityLevel" data-testid="resources-seniority">
                                <option value="">Any</option>
                                <option value="@DomainConstants.Seniority.Junior">Junior</option>
                                <option value="@DomainConstants.Seniority.Mid">Mid</option>
                                <option value="@DomainConstants.Seniority.Senior">Senior</option>
                                <option value="@DomainConstants.Seniority.Principal">Principal</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Working Week:</label>
                            <select class="form-select" @bind="resourceForm.WorkingWeek" data-testid="resources-working-week">
                                <option value="">Global Default</option>
                                <option value="@DomainConstants.WorkingWeek.MonFri">Mon–Fri</option>
                                <option value="@DomainConstants.WorkingWeek.SunThu">Sun–Thu</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveResource" disabled="@isSaving" data-testid="resources-save">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Save
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseModal" disabled="@isSaving" data-testid="resources-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <ConfirmDialog
        Visible="true"
        TestId="resources-delete-modal"
        Title="Confirm Delete"
        Message="Are you sure you want to delete this resource?"
        IsProcessing="isDeleting"
        OnConfirm="ConfirmDelete"
        OnCancel="CloseDeleteModal" />
}

<ToastNotification @ref="toast" TestId="resources-toast" />

@if (!isLoaded)
{
    <SkeletonLoader Variant="table" Rows="5" Columns="6" TestId="resources-skeleton" />
}
else if (!resources.Any())
{
    <div class="empty-state" data-testid="resources-empty">
        <div class="empty-icon"><i class="bi bi-people"></i></div>
        <h5>No resources configured</h5>
        <p>Add team members to start planning your delivery schedule.</p>
        <button class="btn btn-primary" @onclick="ShowAddModal">
            <i class="bi bi-plus-lg"></i> Add First Resource
        </button>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0" data-testid="resources-table">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => ApplySort("ResourceId")' aria-sort="@AriaSort("ResourceId")" data-testid="resources-sort-id">ID @SortIndicator("ResourceId")</th>
                        <th role="button" @onclick='() => ApplySort("ResourceName")' aria-sort="@AriaSort("ResourceName")" data-testid="resources-sort-name">Name @SortIndicator("ResourceName")</th>
                        <th role="button" @onclick='() => ApplySort("Role")' aria-sort="@AriaSort("Role")" data-testid="resources-sort-role">Role @SortIndicator("Role")</th>
                        <th role="button" @onclick='() => ApplySort("Team")' aria-sort="@AriaSort("Team")" data-testid="resources-sort-team">Team @SortIndicator("Team")</th>
                        <th role="button" @onclick='() => ApplySort("AvailabilityPct")' aria-sort="@AriaSort("AvailabilityPct")" data-testid="resources-sort-avail">Availability % @SortIndicator("AvailabilityPct")</th>
                        <th role="button" @onclick='() => ApplySort("DailyCapacity")' aria-sort="@AriaSort("DailyCapacity")" data-testid="resources-sort-cap">Capacity @SortIndicator("DailyCapacity")</th>
                        <th role="button" @onclick='() => ApplySort("StartDate")' aria-sort="@AriaSort("StartDate")" data-testid="resources-sort-start">Start Date @SortIndicator("StartDate")</th>
                        <th role="button" @onclick='() => ApplySort("Active")' aria-sort="@AriaSort("Active")" data-testid="resources-sort-active">Active @SortIndicator("Active")</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in FilteredResources)
                    {
                        <tr data-testid="resources-row-@r.ResourceId">
                            <td>@r.ResourceId</td>
                            <td><a href="/resources/@r.ResourceId" data-testid="resources-link-@r.ResourceId">@r.ResourceName</a></td>
                            <td>@r.Role</td>
                            <td>@r.Team</td>
                            <td>@r.AvailabilityPct%</td>
                            <td>@r.DailyCapacity</td>
                            <td>@r.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="badge bg-@(r.Active == DomainConstants.ActiveStatus.Yes ? "success" : "secondary")">
                                    @(r.Active == DomainConstants.ActiveStatus.Yes ? DomainConstants.ActiveStatus.Yes : DomainConstants.ActiveStatus.No)
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => EditResource(r)" aria-label="Edit @r.ResourceId" data-testid="resources-edit-@r.ResourceId"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteResource(r)" aria-label="Delete @r.ResourceId" data-testid="resources-delete-@r.ResourceId"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!FilteredResources.Any() && resources.Any())
    {
        <div class="text-center text-muted py-3" data-testid="resources-no-results">No resources match the current filters.</div>
    }
}

@code {
    private List<TeamMember> resources = new();
    private List<Role> allRoles = new();
    private List<Role> activeRoles = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private TeamMember? editingResource;
    private ResourceFormModel resourceForm = new();
    private DateTime startDateValue;
    private string modalError = string.Empty;
    private ToastNotification toast = default!;
    private bool isLoaded = false;
    private bool isSaving = false;
    private bool isDeleting = false;
    private bool isRefreshing = false;
    private Dictionary<string, string> fieldErrors = new();

    // Search/Sort/Filter state
    private string searchTerm = string.Empty;
    private string searchInput = string.Empty;
    private System.Threading.Timer? _debounceTimer;
    private string roleFilter = string.Empty;
    private string activeFilter = string.Empty;
    private string sortColumn = string.Empty;
    private bool sortAscending = true;

    private class ResourceFormModel
    {
        public int Id { get; set; }
        public string ResourceId { get; set; } = string.Empty;
        public string ResourceName { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public string Team { get; set; } = string.Empty;
        public double AvailabilityPct { get; set; } = 100;
        public double DailyCapacity { get; set; } = 1;
        public DateTime StartDate { get; set; }
        public string Active { get; set; } = "Yes";
        public string? Notes { get; set; }
        public string? SeniorityLevel { get; set; }
        public string? WorkingWeek { get; set; }
    }

    private IReadOnlyList<TeamMember> FilteredResources
    {
        get
        {
            IEnumerable<TeamMember> result = resources;

            // Search
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim();
                result = result.Where(r =>
                    r.ResourceId.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    r.ResourceName.Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            // Filter by role
            if (!string.IsNullOrEmpty(roleFilter))
                result = result.Where(r => r.Role == roleFilter);

            // Filter by active status
            if (!string.IsNullOrEmpty(activeFilter))
                result = result.Where(r => r.Active == activeFilter);

            // Sort
            if (!string.IsNullOrEmpty(sortColumn))
            {
                result = sortColumn switch
                {
                    "ResourceId" => sortAscending ? result.OrderBy(r => r.ResourceId) : result.OrderByDescending(r => r.ResourceId),
                    "ResourceName" => sortAscending ? result.OrderBy(r => r.ResourceName) : result.OrderByDescending(r => r.ResourceName),
                    "Role" => sortAscending ? result.OrderBy(r => r.Role) : result.OrderByDescending(r => r.Role),
                    "Team" => sortAscending ? result.OrderBy(r => r.Team) : result.OrderByDescending(r => r.Team),
                    "AvailabilityPct" => sortAscending ? result.OrderBy(r => r.AvailabilityPct) : result.OrderByDescending(r => r.AvailabilityPct),
                    "DailyCapacity" => sortAscending ? result.OrderBy(r => r.DailyCapacity) : result.OrderByDescending(r => r.DailyCapacity),
                    "StartDate" => sortAscending ? result.OrderBy(r => r.StartDate) : result.OrderByDescending(r => r.StartDate),
                    "Active" => sortAscending ? result.OrderBy(r => r.Active) : result.OrderByDescending(r => r.Active),
                    _ => result
                };
            }

            return result.ToList();
        }
    }

    private void ApplySort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? "▲" : "▼";
    }

    private string AriaSort(string column) =>
        sortColumn != column ? "none" : sortAscending ? "ascending" : "descending";

    private void ClearFilters()
    {
        searchTerm = string.Empty;
        searchInput = string.Empty;
        roleFilter = string.Empty;
        activeFilter = string.Empty;
        sortColumn = string.Empty;
        sortAscending = true;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchInput = e.Value?.ToString() ?? string.Empty;
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(_ =>
            InvokeAsync(() => { searchTerm = searchInput; StateHasChanged(); }),
            null, 300, System.Threading.Timeout.Infinite);
    }

    public void Dispose() => _debounceTimer?.Dispose();

    protected override async Task OnInitializedAsync()
    {
        await LoadResources();
        isLoaded = true;
    }

    private async Task LoadResources()
    {
        var activeRolesResult = await Mediator.Send(new GetRolesQuery(false));
        activeRoles = activeRolesResult.Value
            .Where(r => r.IsActive)
            .OrderBy(r => r.SortOrder)
            .ThenBy(r => r.DisplayName)
            .ToList();

        var allRolesResult = await Mediator.Send(new GetRolesQuery(true));
        allRoles = allRolesResult.Value
            .OrderBy(r => r.SortOrder)
            .ThenBy(r => r.DisplayName)
            .ToList();

        var result = await Mediator.Send(new GetResourcesQuery());
        resources = result.Value;
    }

    private async Task ShowAddModal()
    {
        var countResult = await Mediator.Send(new GetResourceCountQuery());
        var count = countResult.Value;
        resourceForm = new ResourceFormModel
        {
            ResourceId = $"DEV-{(count + 1):D3}",
            Role = activeRoles.FirstOrDefault()?.Code ?? DomainConstants.ResourceRole.Developer,
            Team = DomainConstants.DefaultTeam,
            StartDate = DateTime.Today,
            Active = DomainConstants.ActiveStatus.Yes,
            AvailabilityPct = 100,
            DailyCapacity = 1
        };
        startDateValue = DateTime.Today;
        editingResource = null;
        modalError = string.Empty;
        fieldErrors.Clear();
        showModal = true;
    }

    private void EditResource(TeamMember r)
    {
        if (!activeRoles.Any(role => role.Code == r.Role))
        {
            var inactiveRole = allRoles.FirstOrDefault(role => role.Code == r.Role);
            if (inactiveRole is not null)
                activeRoles = activeRoles.Concat([inactiveRole]).OrderBy(role => role.SortOrder).ThenBy(role => role.DisplayName).ToList();
        }

        editingResource = r;
        resourceForm = new ResourceFormModel
        {
            Id = r.Id,
            ResourceId = r.ResourceId,
            ResourceName = r.ResourceName,
            Role = r.Role,
            Team = r.Team,
            AvailabilityPct = r.AvailabilityPct,
            DailyCapacity = r.DailyCapacity,
            StartDate = r.StartDate,
            Active = r.Active,
            Notes = r.Notes,
            SeniorityLevel = r.SeniorityLevel,
            WorkingWeek = r.WorkingWeek
        };
        startDateValue = r.StartDate;
        modalError = string.Empty;
        fieldErrors.Clear();
        showModal = true;
    }

    private void DeleteResource(TeamMember r)
    {
        editingResource = r;
        showDeleteConfirm = true;
    }

    private async Task SaveResource()
    {
        modalError = string.Empty;
        fieldErrors.Clear();
        isSaving = true;
        try
        {
            var command = new UpsertResourceCommand(
                Id: resourceForm.Id,
                ResourceId: resourceForm.ResourceId,
                ResourceName: resourceForm.ResourceName,
                Role: resourceForm.Role,
                Team: resourceForm.Team,
                AvailabilityPct: resourceForm.AvailabilityPct,
                DailyCapacity: resourceForm.DailyCapacity,
                StartDate: startDateValue,
                Active: resourceForm.Active,
                Notes: resourceForm.Notes,
                IsNew: editingResource == null,
                SeniorityLevel: string.IsNullOrEmpty(resourceForm.SeniorityLevel) ? null : resourceForm.SeniorityLevel,
                WorkingWeek: string.IsNullOrEmpty(resourceForm.WorkingWeek) ? null : resourceForm.WorkingWeek);

            var result = await Mediator.Send(command);
            await LoadResources();
            var message = editingResource == null ? "Resource added successfully." : "Resource updated successfully.";
            CloseModal();
            toast.Show(message);
            await AutoScheduleIfEnabled();
        }
        catch (ValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
            foreach (var error in ex.Errors)
            {
                fieldErrors[error.PropertyName] = error.ErrorMessage;
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        try
        {
            if (editingResource != null)
            {
                var result = await Mediator.Send(new DeleteResourceCommand(editingResource.Id));
                toast.Show($"Resource \"{editingResource.ResourceName}\" deleted.");
            }
            showDeleteConfirm = false;
            editingResource = null;
            StateHasChanged();
            await Task.Yield();
            await LoadResources();
            await AutoScheduleIfEnabled();
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void CloseModal()
    {
        showModal = false;
        editingResource = null;
        modalError = string.Empty;
        fieldErrors.Clear();
    }

    private void CloseDeleteModal()
    {
        showDeleteConfirm = false;
        editingResource = null;
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        try
        {
            var result = await Mediator.Send(new RunSchedulerCommand());
            await LoadResources();
            toast.Show("Schedule refreshed.");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private async Task AutoScheduleIfEnabled()
    {
        if (autoSchedule.IsEnabled)
        {
            await Mediator.Send(new RunSchedulerCommand());
            await LoadResources();
        }
    }
}
