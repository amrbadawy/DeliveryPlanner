@page "/tasks"
@using MediatR
@using FluentValidation
@using SoftwareDeliveryPlanner.Application.Tasks.Queries
@using SoftwareDeliveryPlanner.Application.Tasks.Commands
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Models
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator

<PageTitle>Task Register</PageTitle>

<h3 style="margin-bottom: 20px;">📋 Task Register</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="tasks-add">➕ Add Service</button>
    <button class="btn btn-secondary" @onclick="RefreshData" data-testid="tasks-refresh">🔄 Refresh</button>
</div>

<!-- Search / Filter bar -->
<div class="row mb-3 g-2" data-testid="tasks-filter-bar">
    <div class="col-md-4">
        <input class="form-control" placeholder="Search by ID or name..." @bind="searchTerm" @bind:event="oninput" data-testid="tasks-search" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="statusFilter" data-testid="tasks-filter-status">
            <option value="">All Statuses</option>
            <option value="@DomainConstants.TaskStatus.NotStarted">@DomainConstants.TaskStatus.NotStarted</option>
            <option value="@DomainConstants.TaskStatus.InProgress">@DomainConstants.TaskStatus.InProgress</option>
            <option value="@DomainConstants.TaskStatus.Completed">@DomainConstants.TaskStatus.Completed</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="riskFilter" data-testid="tasks-filter-risk">
            <option value="">All Risks</option>
            <option value="@DomainConstants.DeliveryRisk.OnTrack">@DomainConstants.DeliveryRisk.OnTrack</option>
            <option value="@DomainConstants.DeliveryRisk.AtRisk">@DomainConstants.DeliveryRisk.AtRisk</option>
            <option value="@DomainConstants.DeliveryRisk.Late">@DomainConstants.DeliveryRisk.Late</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters" data-testid="tasks-clear-filters">Clear</button>
    </div>
</div>

@if (showModal)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);" data-testid="tasks-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingTask == null ? "Add New Service" : "Edit Service")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(modalError))
                    {
                        <div class="alert alert-danger" data-testid="tasks-error">@modalError</div>
                    }
                    <div class="mb-2">
                        <label>Service ID:</label>
                        <input class="form-control" @bind="taskForm.TaskId" disabled="@(editingTask != null)" data-testid="tasks-task-id" />
                    </div>
                    <div class="mb-2">
                        <label>Service Name:</label>
                        <input class="form-control" @bind="taskForm.ServiceName" data-testid="tasks-service-name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Estimation (days):</label>
                            <input class="form-control" type="number" @bind="taskForm.DevEstimation" data-testid="tasks-dev-estimation" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Max Developers:</label>
                            <input class="form-control" type="number" step="0.5" @bind="taskForm.MaxDev" data-testid="tasks-max-dev" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Priority (1-10):</label>
                            <input class="form-control" type="number" @bind="taskForm.Priority" data-testid="tasks-priority" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label>Strict Date:</label>
                            <input class="form-control" type="date" @bind="strictDateValue" data-testid="tasks-strict-date" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label>Depends On:</label>
                        <select class="form-select" multiple size="4" @onchange="OnDependencyChanged" data-testid="tasks-depends-on">
                            @foreach (var t in tasks.Where(t => t.TaskId != taskForm.TaskId))
                            {
                                <option value="@t.TaskId" selected="@(selectedDependencies.Contains(t.TaskId))">
                                    @t.TaskId — @t.ServiceName
                                </option>
                            }
                        </select>
                        @if (selectedDependencies.Any())
                        {
                            <small class="text-muted">Selected: @string.Join(", ", selectedDependencies)</small>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveTask" data-testid="tasks-save">Save</button>
                    <button class="btn btn-secondary" @onclick="CloseModal" data-testid="tasks-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <ConfirmDialog
        Visible="true"
        TestId="tasks-delete-modal"
        Title="Confirm Delete"
        Message="Are you sure you want to delete this service?"
        OnConfirm="ConfirmDelete"
        OnCancel="CloseDeleteModal" />
}

<ToastNotification @ref="toast" TestId="tasks-toast" />

<table class="table table-striped table-hover" data-testid="tasks-table">
    <thead class="table-dark">
        <tr>
            <th role="button" @onclick='() => ApplySort("TaskId")' data-testid="tasks-sort-id">ID @SortIndicator("TaskId")</th>
            <th role="button" @onclick='() => ApplySort("ServiceName")' data-testid="tasks-sort-name">Service @SortIndicator("ServiceName")</th>
            <th role="button" @onclick='() => ApplySort("DevEstimation")' data-testid="tasks-sort-est">Est @SortIndicator("DevEstimation")</th>
            <th>Max Dev</th>
            <th role="button" @onclick='() => ApplySort("Priority")' data-testid="tasks-sort-priority">Priority @SortIndicator("Priority")</th>
            <th role="button" @onclick='() => ApplySort("PlannedStart")' data-testid="tasks-sort-start">Start @SortIndicator("PlannedStart")</th>
            <th role="button" @onclick='() => ApplySort("PlannedFinish")' data-testid="tasks-sort-finish">Finish @SortIndicator("PlannedFinish")</th>
            <th>Days</th>
            <th role="button" @onclick='() => ApplySort("Status")' data-testid="tasks-sort-status">Status @SortIndicator("Status")</th>
            <th role="button" @onclick='() => ApplySort("DeliveryRisk")' data-testid="tasks-sort-risk">Risk @SortIndicator("DeliveryRisk")</th>
            <th>Deps</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in FilteredTasks)
        {
            <tr data-testid="tasks-row-@task.TaskId">
                <td>@task.TaskId</td>
                <td>@task.ServiceName</td>
                <td>@task.DevEstimation</td>
                <td>@task.MaxDev</td>
                <td>@task.Priority</td>
                <td>@task.PlannedStart?.ToString("yyyy-MM-dd")</td>
                <td>@task.PlannedFinish?.ToString("yyyy-MM-dd")</td>
                <td>@task.Duration</td>
                <td>
                    <span class="badge bg-@(task.Status == DomainConstants.TaskStatus.Completed ? "success" : task.Status == DomainConstants.TaskStatus.InProgress ? "info" : "secondary")">
                        @task.Status
                    </span>
                </td>
                <td>
                    <span class="badge bg-@(task.DeliveryRisk == DomainConstants.DeliveryRisk.OnTrack ? "success" : task.DeliveryRisk == DomainConstants.DeliveryRisk.AtRisk ? "warning" : "danger")">
                        @task.DeliveryRisk
                    </span>
                </td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(task.DependsOnTaskIds))
                    {
                        @foreach (var dep in task.DependsOnTaskIds.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <span class="badge bg-light text-dark me-1">@dep</span>
                        }
                    }
                </td>
                <td>
                    <button class="btn btn-sm btn-warning" @onclick="() => EditTask(task)" data-testid="tasks-edit-@task.TaskId">✏️</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteTask(task)" data-testid="tasks-delete-@task.TaskId">🗑️</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!FilteredTasks.Any() && tasks.Any())
{
    <div class="text-center text-muted py-3" data-testid="tasks-no-results">No tasks match the current filters.</div>
}

@code {
    private List<TaskItem> tasks = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private TaskItem? editingTask;
    private TaskItem taskForm = new();
    private DateTime? strictDateValue;
    private string modalError = string.Empty;
    private ToastNotification toast = default!;
    private HashSet<string> selectedDependencies = new();

    // Search/Sort/Filter state
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private string riskFilter = string.Empty;
    private string sortColumn = string.Empty;
    private bool sortAscending = true;

    private IEnumerable<TaskItem> FilteredTasks
    {
        get
        {
            IEnumerable<TaskItem> result = tasks;

            // Search
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim();
                result = result.Where(t =>
                    t.TaskId.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    t.ServiceName.Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            // Filter by status
            if (!string.IsNullOrEmpty(statusFilter))
                result = result.Where(t => t.Status == statusFilter);

            // Filter by risk
            if (!string.IsNullOrEmpty(riskFilter))
                result = result.Where(t => t.DeliveryRisk == riskFilter);

            // Sort
            if (!string.IsNullOrEmpty(sortColumn))
            {
                result = sortColumn switch
                {
                    "TaskId" => sortAscending ? result.OrderBy(t => t.TaskId) : result.OrderByDescending(t => t.TaskId),
                    "ServiceName" => sortAscending ? result.OrderBy(t => t.ServiceName) : result.OrderByDescending(t => t.ServiceName),
                    "DevEstimation" => sortAscending ? result.OrderBy(t => t.DevEstimation) : result.OrderByDescending(t => t.DevEstimation),
                    "Priority" => sortAscending ? result.OrderBy(t => t.Priority) : result.OrderByDescending(t => t.Priority),
                    "PlannedStart" => sortAscending ? result.OrderBy(t => t.PlannedStart) : result.OrderByDescending(t => t.PlannedStart),
                    "PlannedFinish" => sortAscending ? result.OrderBy(t => t.PlannedFinish) : result.OrderByDescending(t => t.PlannedFinish),
                    "Status" => sortAscending ? result.OrderBy(t => t.Status) : result.OrderByDescending(t => t.Status),
                    "DeliveryRisk" => sortAscending ? result.OrderBy(t => t.DeliveryRisk) : result.OrderByDescending(t => t.DeliveryRisk),
                    _ => result
                };
            }

            return result;
        }
    }

    private void ApplySort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? "▲" : "▼";
    }

    private void ClearFilters()
    {
        searchTerm = string.Empty;
        statusFilter = string.Empty;
        riskFilter = string.Empty;
        sortColumn = string.Empty;
        sortAscending = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        tasks = await Mediator.Send(new GetTasksQuery());
    }

    private async Task ShowAddModal()
    {
        var count = await Mediator.Send(new GetTaskCountQuery());
        taskForm = new TaskItem
        {
            TaskId = $"SVC-{(count + 1):D3}",
            Priority = 5,
            MaxDev = 1
        };
        strictDateValue = null;
        selectedDependencies = new();
        editingTask = null;
        modalError = string.Empty;
        showModal = true;
    }

    private void EditTask(TaskItem task)
    {
        editingTask = task;
        taskForm = new TaskItem
        {
            Id = task.Id,
            TaskId = task.TaskId,
            ServiceName = task.ServiceName,
            DevEstimation = task.DevEstimation,
            MaxDev = task.MaxDev,
            Priority = task.Priority,
            StrictDate = task.StrictDate,
            DependsOnTaskIds = task.DependsOnTaskIds
        };
        strictDateValue = task.StrictDate;
        selectedDependencies = string.IsNullOrWhiteSpace(task.DependsOnTaskIds)
            ? new HashSet<string>()
            : new HashSet<string>(task.DependsOnTaskIds.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        modalError = string.Empty;
        showModal = true;
    }

    private void DeleteTask(TaskItem task)
    {
        editingTask = task;
        showDeleteConfirm = true;
    }

    private async Task SaveTask()
    {
        modalError = string.Empty;
        try
        {
            var command = new UpsertTaskCommand(
                Id: taskForm.Id,
                TaskId: taskForm.TaskId,
                ServiceName: taskForm.ServiceName,
                DevEstimation: taskForm.DevEstimation,
                MaxDev: taskForm.MaxDev,
                Priority: taskForm.Priority,
                StrictDate: strictDateValue,
                DependsOnTaskIds: selectedDependencies.Any() ? string.Join(",", selectedDependencies) : null,
                IsNew: editingTask == null);

            await Mediator.Send(command);
            await LoadTasks();
            CloseModal();
            toast.Show(editingTask == null ? "Service added successfully." : "Service updated successfully.");
        }
        catch (ValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
    }

    private async Task ConfirmDelete()
    {
        if (editingTask != null)
        {
            await Mediator.Send(new DeleteTaskCommand(editingTask.Id));
            toast.Show($"Service \"{editingTask.ServiceName}\" deleted.");
        }
        showDeleteConfirm = false;
        editingTask = null;
        await LoadTasks();
    }

    private void CloseModal()
    {
        showModal = false;
        editingTask = null;
        modalError = string.Empty;
    }

    private void CloseDeleteModal()
    {
        showDeleteConfirm = false;
        editingTask = null;
    }

    private async Task RefreshData()
    {
        await Mediator.Send(new RunSchedulerCommand());
        await LoadTasks();
        toast.Show("Schedule refreshed.");
    }

    private void OnDependencyChanged(ChangeEventArgs e)
    {
        if (e.Value is string[] values)
        {
            selectedDependencies = new HashSet<string>(values);
        }
        else if (e.Value is string single)
        {
            selectedDependencies = string.IsNullOrWhiteSpace(single) ? new() : new HashSet<string> { single };
        }
    }
}
