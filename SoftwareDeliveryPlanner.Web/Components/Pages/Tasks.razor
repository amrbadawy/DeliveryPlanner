@page "/tasks"
@using MediatR
@using FluentValidation
@using SoftwareDeliveryPlanner.Application.Tasks.Queries
@using SoftwareDeliveryPlanner.Application.Tasks.Commands
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject SoftwareDeliveryPlanner.Web.Services.AutoScheduleService autoSchedule
@implements IDisposable
@using Microsoft.AspNetCore.Components

<PageTitle>Task Register</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-list-check me-2"></i>Task Register</h3>
        <p class="page-subtitle">Manage services and their delivery schedule</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="ShowAddModal" data-testid="tasks-add">
            <i class="bi bi-plus-lg"></i> Add Service
        </button>
        <button class="btn btn-outline-primary" @onclick="ShowBulkImportModal" data-testid="tasks-bulk-import">
            <i class="bi bi-upload"></i> Import CSV
        </button>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" disabled="@isRefreshing" data-testid="tasks-refresh">
            @if (isRefreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

<!-- Search / Filter bar -->
<div class="card border-0 shadow-sm mb-3 filter-bar" data-testid="tasks-filter-bar">
    <div class="card-body py-2">
        <div class="row align-items-center g-2">
            <div class="col-md-4">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control" placeholder="Search by ID or name..." value="@searchInput" @oninput="OnSearchInput" aria-label="Search tasks" data-testid="tasks-search" />
                </div>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="statusFilter" aria-label="Filter by status" data-testid="tasks-filter-status">
                    <option value="">All Statuses</option>
                    <option value="@DomainConstants.TaskStatus.NotStarted">@DomainConstants.TaskStatus.NotStarted</option>
                    <option value="@DomainConstants.TaskStatus.InProgress">@DomainConstants.TaskStatus.InProgress</option>
                    <option value="@DomainConstants.TaskStatus.Completed">@DomainConstants.TaskStatus.Completed</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="riskFilter" aria-label="Filter by risk" data-testid="tasks-filter-risk">
                    <option value="">All Risks</option>
                    <option value="@DomainConstants.DeliveryRisk.OnTrack">@DomainConstants.DeliveryRisk.OnTrack</option>
                    <option value="@DomainConstants.DeliveryRisk.AtRisk">@DomainConstants.DeliveryRisk.AtRisk</option>
                    <option value="@DomainConstants.DeliveryRisk.Late">@DomainConstants.DeliveryRisk.Late</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ClearFilters" data-testid="tasks-clear-filters">Clear</button>
            </div>
            <div class="col-md-2 text-muted small text-end">
                @FilteredTasks.Count() of @tasks.Count
                @if (scheduledFilter == "no")
                {
                    <span class="badge bg-warning text-dark ms-1" data-testid="tasks-unscheduled-filter-badge" title="Showing only unscheduled tasks (click Clear to reset)">Unscheduled only</span>
                }
            </div>
        </div>
    </div>
</div>

@if (isLoaded && tasks.Any() && (unscheduledTaskCount > 0 || resourceGapTaskCount > 0 || !schedulerHasRun))
{
    var hasIssues = unscheduledTaskCount > 0 || resourceGapTaskCount > 0;
    var filtersActive = !string.IsNullOrWhiteSpace(statusFilter) || !string.IsNullOrWhiteSpace(riskFilter) || !string.IsNullOrWhiteSpace(scheduledFilter) || !string.IsNullOrWhiteSpace(searchTerm);
    var scope = filtersActive ? " (across all tasks)" : "";
    <div class="alert @(hasIssues ? "alert-warning" : "alert-info") d-flex align-items-center mb-3" data-testid="task-warnings-banner">
        <i class="bi @(hasIssues ? "bi-exclamation-triangle-fill" : "bi-info-circle-fill") me-2"></i>
        <div>
            @{
                var parts = new List<string>();
                if (!schedulerHasRun)
                    parts.Add("No tasks are currently scheduled. Run the scheduler to generate a delivery plan and identify scheduling issues");
                if (unscheduledTaskCount > 0)
                    parts.Add($"{unscheduledTaskCount} task(s) are unscheduled and will not appear in the plan{scope}");
                if (resourceGapTaskCount > 0)
                    parts.Add($"{resourceGapTaskCount} task(s) have no matching active resources for required roles{scope}");
            }
            <span>@string.Join(". ", parts).</span>
        </div>
    </div>
}

@if (showModal)
{
    <div class="modal d-block modal-backdrop-custom" role="dialog" aria-modal="true" aria-labelledby="tasks-modal-title" data-testid="tasks-modal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="tasks-modal-title">@(editingTask == null ? "Add New Service" : "Edit Service")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(modalError))
                    {
                        <div class="alert alert-danger" data-testid="tasks-error">@modalError</div>
                    }
                    <div class="mb-2">
                        <label class="form-label">Service ID: <span class="required-indicator">*</span></label>
                        <input class="form-control @(fieldErrors.ContainsKey("TaskId") ? "is-invalid" : "")" @bind="taskForm.TaskId" disabled="@(editingTask != null)" data-testid="tasks-task-id" />
                        @if (fieldErrors.ContainsKey("TaskId"))
                        {
                            <div class="invalid-feedback">@fieldErrors["TaskId"]</div>
                        }
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Service Name: <span class="required-indicator">*</span></label>
                        <input class="form-control @(fieldErrors.ContainsKey("ServiceName") ? "is-invalid" : "")" @bind="taskForm.ServiceName" data-testid="tasks-service-name" />
                        @if (fieldErrors.ContainsKey("ServiceName"))
                        {
                            <div class="invalid-feedback">@fieldErrors["ServiceName"]</div>
                        }
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Priority (1-10):</label>
                            <input class="form-control @(fieldErrors.ContainsKey("Priority") ? "is-invalid" : "")" type="number" min="1" max="10" @bind="taskForm.Priority" data-testid="tasks-priority" />
                            @if (fieldErrors.ContainsKey("Priority"))
                            {
                                <div class="invalid-feedback">@fieldErrors["Priority"]</div>
                            }
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Strict Date:</label>
                            <input class="form-control @(fieldErrors.ContainsKey("StrictDate") ? "is-invalid" : "")" type="date" @bind="strictDateValue" data-testid="tasks-strict-date" />
                            @if (fieldErrors.ContainsKey("StrictDate"))
                            {
                                <div class="invalid-feedback">@fieldErrors["StrictDate"]</div>
                            }
                        </div>
                    </div>
                    <div class="mb-3" data-testid="effort-breakdown-section">
                        <label class="form-label fw-semibold">Effort Breakdown <span class="text-danger">*</span></label>
                        <table class="table table-sm table-bordered mb-2">
                            <thead class="table-light">
                                <tr><th>Role</th><th style="width:120px">Days</th><th style="width:100px">Max FTE</th><th style="width:120px">Overlap %</th><th style="width:130px">Min Seniority</th><th style="width:50px"></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in effortEntries)
                                {
                                    var isRequired = DomainConstants.ResourceRole.RequiredRoles.Contains(entry.Role);
                                    var isFirst = effortEntries.IndexOf(entry) == 0;
                                    <tr data-testid="effort-row-@entry.Role">
                                        <td>
                                            <span class="badge role-badge role-badge-@entry.Role.ToLowerInvariant() me-1">@entry.Role</span>
                                            <small class="text-muted">@DomainConstants.ResourceRole.GetDisplayName(entry.Role)</small>
                                            @if (isRequired) { <span class="text-danger ms-1">*</span> }
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" min="0.5" step="0.5"
                                                   @bind="entry.EstimationDays" data-testid="effort-days-@entry.Role" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" min="0.1" step="0.5"
                                                   @bind="entry.MaxFte" data-testid="effort-maxfte-@entry.Role" />
                                        </td>
                                        <td>
                                            @if (isFirst)
                                            { <span class="text-muted">&mdash;</span> }
                                            else
                                            { <input type="number" class="form-control form-control-sm" min="0" max="100" step="5"
                                                     @bind="entry.OverlapPct" data-testid="effort-overlap-@entry.Role" /> }
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="entry.MinSeniority" data-testid="effort-seniority-@entry.Role">
                                                <option value="">Any</option>
                                                <option value="@DomainConstants.Seniority.Junior">Junior</option>
                                                <option value="@DomainConstants.Seniority.Mid">Mid</option>
                                                <option value="@DomainConstants.Seniority.Senior">Senior</option>
                                                <option value="@DomainConstants.Seniority.Principal">Principal</option>
                                            </select>
                                        </td>
                                        <td>
                                            @if (!isRequired)
                                            { <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveEffortEntry(entry)"
                                                      data-testid="effort-remove-@entry.Role"><i class="bi bi-x"></i></button> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @{ var availableRoles = DomainConstants.ResourceRole.PipelineOrder.Where(r => !effortEntries.Any(e => e.Role == r)).ToList(); }
                        @if (availableRoles.Any())
                        {
                            <div class="d-flex gap-2 align-items-center">
                                <select class="form-select form-select-sm" style="width:auto" @bind="selectedRoleToAdd" data-testid="effort-add-role-select">
                                    <option value="">Add role...</option>
                                    @foreach (var role in availableRoles)
                                    { <option value="@role">@role &mdash; @DomainConstants.ResourceRole.GetDisplayName(role)</option> }
                                </select>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddEffortEntry"
                                        disabled="@string.IsNullOrEmpty(selectedRoleToAdd)" data-testid="effort-add-btn">
                                    <i class="bi bi-plus me-1"></i>Add
                                </button>
                            </div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phase</label>
                        <input type="text" class="form-control" @bind="editPhase" placeholder="e.g. Phase 1" data-testid="tasks-phase" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Preferred Resources <small class="text-muted">(optional)</small></label>
                        <input type="text" class="form-control" @bind="editPreferredResourceIds" placeholder="e.g. DEV-001, DEV-003" data-testid="tasks-preferred-resources" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Depends On:</label>
                        <div class="border rounded p-2" style="max-height:200px;overflow-y:auto" data-testid="tasks-depends-on">
                            @foreach (var t in tasks.Where(t => t.TaskId != taskForm.TaskId))
                            {
                                var detail = selectedDepDetails.FirstOrDefault(d => d.TaskId == t.TaskId);
                                var isChecked = detail != null;
                                <div class="mb-1">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="dep-@t.TaskId"
                                               checked="@isChecked" @onchange="() => ToggleDependency(t.TaskId)"
                                               data-testid="dep-check-@t.TaskId" />
                                        <label class="form-check-label" for="dep-@t.TaskId">
                                            @t.TaskId &mdash; @t.ServiceName
                                        </label>
                                    </div>
                                    @if (isChecked && detail != null)
                                    {
                                        <div class="d-flex gap-2 ms-4 mt-1 align-items-center">
                                            <select class="form-select form-select-sm" style="width:80px"
                                                    @bind="detail.Type" data-testid="dep-type-@t.TaskId">
                                                <option value="FS">FS</option>
                                                <option value="SS">SS</option>
                                                <option value="FF">FF</option>
                                            </select>
                                            <input type="number" class="form-control form-control-sm" style="width:90px"
                                                   min="0" @bind="detail.LagDays" placeholder="Lag days"
                                                   data-testid="dep-lag-@t.TaskId" />
                                            <small class="text-muted">lag days</small>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        @if (selectedDepDetails.Any())
                        {
                            <small class="text-muted mt-1 d-block">Selected: @string.Join(", ", selectedDepDetails.Select(d => $"{d.TaskId} ({d.Type})"))</small>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveTask" disabled="@isSaving" data-testid="tasks-save">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Save
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseModal" data-testid="tasks-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showBulkImport)
{
    <div class="modal d-block modal-backdrop-custom" role="dialog" aria-modal="true" data-testid="bulk-import-modal">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Bulk Import Services (CSV)</h5>
                    <button type="button" class="btn-close" @onclick="CloseBulkImport" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(bulkError))
                    {
                        <div class="alert alert-danger">@bulkError</div>
                    }
                    <p class="text-muted small">Paste CSV with headers: <code>TaskId,ServiceName,DevEstDEV,DevEstQA,Priority,StrictDate,DependsOnTaskIds</code></p>
                    <textarea class="form-control font-monospace" rows="8" @bind="csvText" placeholder="SVC-010,Auth Service,15,2,3,,&#10;SVC-011,User API,20,3,5,2026-06-01,SVC-010" data-testid="bulk-import-csv"></textarea>
                    @if (parsedRows.Any())
                    {
                        <div class="mt-3">
                            <h6>Preview (@parsedRows.Count rows)</h6>
                            <div class="table-responsive" style="max-height: 200px;">
                                <table class="table table-sm table-bordered mb-0">
                                    <thead class="table-light">
                                         <tr><th>ID</th><th>Name</th><th>DEV</th><th>QA</th><th>Priority</th><th>Strict</th><th>Deps</th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in parsedRows)
                                        {
                                            <tr>
                                                <td>@row.TaskId</td><td>@row.ServiceName</td>
                                                <td>@row.EffortBreakdown.FirstOrDefault(e => e.Role == "DEV")?.EstimationDays</td>
                                                <td>@row.EffortBreakdown.FirstOrDefault(e => e.Role == "QA")?.EstimationDays</td>
                                                <td>@row.Priority</td>
                                                <td>@(row.StrictDate?.ToString("yyyy-MM-dd") ?? "")</td><td>@(row.Dependencies != null ? string.Join(",", row.Dependencies.Select(d => d.PredecessorTaskId)) : "")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="ParseCsv" data-testid="bulk-import-preview">
                        <i class="bi bi-eye me-1"></i>Preview
                    </button>
                    <button class="btn btn-primary" @onclick="ImportCsv" disabled="@(isImporting || !parsedRows.Any())" data-testid="bulk-import-confirm">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Import @parsedRows.Count Services
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseBulkImport">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <ConfirmDialog
        Visible="true"
        TestId="tasks-delete-modal"
        Title="Confirm Delete"
        Message="Are you sure you want to delete this service?"
        IsProcessing="isDeleting"
        OnConfirm="ConfirmDelete"
        OnCancel="CloseDeleteModal" />
}

<ToastNotification @ref="toast" TestId="tasks-toast" />

@if (!isLoaded)
{
    <SkeletonLoader Variant="table" Rows="6" Columns="8" TestId="tasks-skeleton" />
}
else if (!tasks.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-list-check"></i></div>
        <h5>No services configured</h5>
        <p>Add services to start planning your delivery schedule.</p>
        <button class="btn btn-primary" @onclick="ShowAddModal">
            <i class="bi bi-plus-lg"></i> Add First Service
        </button>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0" data-testid="tasks-table">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => ApplySort("TaskId")' aria-sort="@AriaSort("TaskId")" data-testid="tasks-sort-id">ID @SortIndicator("TaskId")</th>
                        <th role="button" @onclick='() => ApplySort("ServiceName")' aria-sort="@AriaSort("ServiceName")" data-testid="tasks-sort-name">Service @SortIndicator("ServiceName")</th>
                        <th role="button" @onclick='() => ApplySort("TotalEstimationDays")' aria-sort="@AriaSort("TotalEstimationDays")" data-testid="tasks-sort-est">Total Est. @SortIndicator("TotalEstimationDays")</th>
                        <th>Phase</th>
                        <th role="button" @onclick='() => ApplySort("Priority")' aria-sort="@AriaSort("Priority")" data-testid="tasks-sort-priority">Priority @SortIndicator("Priority")</th>
                        <th role="button" @onclick='() => ApplySort("PlannedStart")' aria-sort="@AriaSort("PlannedStart")" data-testid="tasks-sort-start">Start @SortIndicator("PlannedStart")</th>
                        <th role="button" @onclick='() => ApplySort("PlannedFinish")' aria-sort="@AriaSort("PlannedFinish")" data-testid="tasks-sort-finish">Finish @SortIndicator("PlannedFinish")</th>
                        <th>Days</th>
                        <th role="button" @onclick='() => ApplySort("Status")' aria-sort="@AriaSort("Status")" data-testid="tasks-sort-status">Status @SortIndicator("Status")</th>
                        <th role="button" @onclick='() => ApplySort("DeliveryRisk")' aria-sort="@AriaSort("DeliveryRisk")" data-testid="tasks-sort-risk">Risk @SortIndicator("DeliveryRisk")</th>
                        <th>Deps</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in FilteredTasks)
                    {
                        <tr class="clickable-row @(dragTaskId == task.TaskId ? "dragging" : "") @(dragOverTaskId == task.TaskId ? "drag-over" : "")"
                            draggable="true"
                            @ondragstart="() => OnDragStart(task.TaskId)"
                            @ondragover:preventDefault="true"
                            @ondragover="() => OnDragOver(task.TaskId)"
                            @ondragleave="() => OnDragLeave()"
                            @ondrop="() => OnDrop(task)"
                            @ondragend="OnDragEnd"
                            @onclick="() => NavigateToTask(task.TaskId)"
                            data-testid="tasks-row-@task.TaskId">
                            <td>
                                <a href="/tasks/@task.TaskId" @onclick:stopPropagation data-testid="tasks-details-link-@task.TaskId">@task.TaskId</a>
                            </td>
                            <td>@task.ServiceName</td>
                            <td>
                                @task.TotalEstimationDays
                                @if (GetUncoveredRoles(task) is { Count: > 0 } uncovered)
                                {
                                    <span class="text-warning ms-1" title="No active resource for role(s): @string.Join(", ", uncovered)" data-testid="resource-gap-warning-@task.TaskId">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                    </span>
                                }
                            </td>
                            <td>@(task.Phase ?? "")</td>
                            <td>
                                @if (BadgeHelpers.ShowPriorityBadge(task.Priority))
                                {
                                    <span class="badge @BadgeHelpers.PriorityBadgeClass(task.Priority)">P@task.Priority</span>
                                }
                                else
                                {
                                    @task.Priority
                                }
                            </td>
                            <td>
                                @if (task.PlannedStart.HasValue && task.PlannedFinish.HasValue)
                                {
                                    @task.PlannedStart.Value.ToString("yyyy-MM-dd")
                                }
                                else if (schedulerHasRun)
                                {
                                    <span class="text-warning" title="This task was not scheduled. Check dependencies and resource availability." data-testid="unscheduled-warning-@task.TaskId">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>&mdash;
                                    </span>
                                }
                            </td>
                            <td>@task.PlannedFinish?.ToString("yyyy-MM-dd")@if ((!task.PlannedStart.HasValue || !task.PlannedFinish.HasValue) && schedulerHasRun) { <span>&mdash;</span> }</td>
                            <td>@if (task.Duration > 0 || !schedulerHasRun) { @task.Duration } else { <span>&mdash;</span> }</td>
                            <td>
                                <span class="badge @BadgeHelpers.StatusBg(task.Status)">
                                    @task.Status
                                </span>
                            </td>
                            <td>
                                <span class="badge @BadgeHelpers.RiskBadgeClass(task.DeliveryRisk)">
                                    @task.DeliveryRisk
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(task.DependsOnTaskIds))
                                {
                                    @foreach (var dep in task.DependsOnTaskIds.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                    {
                                        <span class="badge bg-light text-dark me-1">@dep</span>
                                    }
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-outline-info" href="/tasks/@task.TaskId" @onclick:stopPropagation aria-label="View @task.TaskId" data-testid="tasks-view-@task.TaskId"><i class="bi bi-eye"></i></a>
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => EditTask(task)" @onclick:stopPropagation aria-label="Edit @task.TaskId" data-testid="tasks-edit-@task.TaskId"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTask(task)" @onclick:stopPropagation aria-label="Delete @task.TaskId" data-testid="tasks-delete-@task.TaskId"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!FilteredTasks.Any() && tasks.Any())
    {
        <div class="text-center text-muted py-3" data-testid="tasks-no-results">No tasks match the current filters.</div>
    }
}

@code {
    private List<TaskItem> tasks = new();
    private List<TeamMember> resources = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private TaskItem? editingTask;
    private TaskFormModel taskForm = new();
    private DateTime? strictDateValue;
    private string modalError = string.Empty;
    private ToastNotification toast = default!;
    private List<SelectedDependencyDetail> selectedDepDetails = new();
    private bool isLoaded = false;
    private bool isSaving = false;
    private bool isDeleting = false;
    private bool isRefreshing = false;
    private Dictionary<string, string> fieldErrors = new();

    // Search/Sort/Filter state
    private string searchTerm = string.Empty;
    private string searchInput = string.Empty;
    private System.Threading.Timer? _debounceTimer;
    private string statusFilter = string.Empty;
    private string riskFilter = string.Empty;
    private string scheduledFilter = string.Empty; // "no" = unscheduled only
    private string sortColumn = string.Empty;
    private bool sortAscending = true;

    // Bulk import state
    private bool showBulkImport = false;
    private string csvText = string.Empty;
    private string bulkError = string.Empty;
    private bool isImporting = false;
    private List<BulkTaskRowDto> parsedRows = new();

    // Drag-and-drop state
    private string? dragTaskId;
    private string? dragOverTaskId;

    private List<EffortEntryModel> effortEntries = new();
    private string selectedRoleToAdd = "";
    private string editPhase = "";
    private string editPreferredResourceIds = "";

    // Plan readiness warning state
    private bool schedulerHasRun;
    private int unscheduledTaskCount;
    private int resourceGapTaskCount;
    private Dictionary<string, List<TeamMember>> activeResourcesByRole = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<int, List<string>> uncoveredRolesCache = new();

    private void ComputeWarnings()
    {
        schedulerHasRun = tasks.Any(t => t.PlannedStart.HasValue && t.PlannedFinish.HasValue);
        unscheduledTaskCount = schedulerHasRun ? tasks.Count(t => !t.PlannedStart.HasValue || !t.PlannedFinish.HasValue) : 0;

        activeResourcesByRole = resources
            .Where(r => r.Active == DomainConstants.ActiveStatus.Yes)
            .GroupBy(r => r.Role, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);

        // Cache uncovered roles per task to avoid recomputing during render
        uncoveredRolesCache.Clear();
        foreach (var task in tasks)
        {
            var uncovered = ComputeUncoveredRoles(task);
            if (uncovered.Count > 0)
                uncoveredRolesCache[task.Id] = uncovered;
        }

        resourceGapTaskCount = uncoveredRolesCache.Count;
    }

    private List<string> GetUncoveredRoles(TaskItem task)
    {
        return uncoveredRolesCache.TryGetValue(task.Id, out var roles) ? roles : [];
    }

    private List<string> ComputeUncoveredRoles(TaskItem task)
    {
        return task.EffortBreakdown
            .Where(eb =>
            {
                if (!activeResourcesByRole.TryGetValue(eb.Role, out var candidates) || candidates.Count == 0)
                    return true; // no resource for this role at all

                if (!string.IsNullOrEmpty(eb.MinSeniority)
                    && DomainConstants.Seniority.Rank.TryGetValue(eb.MinSeniority, out var requiredRank))
                {
                    // check if at least one resource meets seniority
                    return !candidates.Any(r =>
                        DomainConstants.Seniority.Rank.TryGetValue(r.SeniorityLevel, out var rRank) && rRank >= requiredRank);
                }

                return false;
            })
            .Select(eb => eb.Role)
            .ToList();
    }

    private class EffortEntryModel
    {
        public string Role { get; set; } = "";
        public double EstimationDays { get; set; }
        public double MaxFte { get; set; } = 1.0;
        public double OverlapPct { get; set; }
        public string? MinSeniority { get; set; }
    }

    private class TaskFormModel
    {
        public int Id { get; set; }
        public string TaskId { get; set; } = string.Empty;
        public string ServiceName { get; set; } = string.Empty;
        public int Priority { get; set; } = 5;
        public DateTime? StrictDate { get; set; }
        public string? DependsOnTaskIds { get; set; }
    }

    private class SelectedDependencyDetail
    {
        public string TaskId { get; set; } = "";
        public string Type { get; set; } = "FS";
        public int LagDays { get; set; } = 0;
    }

    private void AddEffortEntry()
    {
        if (!string.IsNullOrEmpty(selectedRoleToAdd) && !effortEntries.Any(e => e.Role == selectedRoleToAdd))
        {
            effortEntries.Add(new EffortEntryModel { Role = selectedRoleToAdd, EstimationDays = 1, OverlapPct = 0 });
            effortEntries = effortEntries.OrderBy(e => DomainConstants.ResourceRole.GetPipelineSortOrder(e.Role)).ToList();
            selectedRoleToAdd = "";
        }
    }

    private void RemoveEffortEntry(EffortEntryModel entry)
    {
        if (!DomainConstants.ResourceRole.RequiredRoles.Contains(entry.Role))
            effortEntries.Remove(entry);
    }

    private IReadOnlyList<TaskItem> FilteredTasks
    {
        get
        {
            IEnumerable<TaskItem> result = tasks;

            // Search
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim();
                result = result.Where(t =>
                    t.TaskId.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    t.ServiceName.Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            // Filter by status
            if (!string.IsNullOrEmpty(statusFilter))
                result = result.Where(t => t.Status == statusFilter);

            // Filter by risk
            if (!string.IsNullOrEmpty(riskFilter))
                result = result.Where(t => t.DeliveryRisk == riskFilter);

            // Filter by scheduling state
            if (scheduledFilter == "no")
                result = result.Where(t => !t.PlannedStart.HasValue || !t.PlannedFinish.HasValue);

            // Sort
            if (!string.IsNullOrEmpty(sortColumn))
            {
                result = sortColumn switch
                {
                    "TaskId" => sortAscending ? result.OrderBy(t => t.TaskId) : result.OrderByDescending(t => t.TaskId),
                    "ServiceName" => sortAscending ? result.OrderBy(t => t.ServiceName) : result.OrderByDescending(t => t.ServiceName),
                    "TotalEstimationDays" => sortAscending ? result.OrderBy(t => t.TotalEstimationDays) : result.OrderByDescending(t => t.TotalEstimationDays),
                    "Priority" => sortAscending ? result.OrderBy(t => t.Priority) : result.OrderByDescending(t => t.Priority),
                    "PlannedStart" => sortAscending ? result.OrderBy(t => t.PlannedStart) : result.OrderByDescending(t => t.PlannedStart),
                    "PlannedFinish" => sortAscending ? result.OrderBy(t => t.PlannedFinish) : result.OrderByDescending(t => t.PlannedFinish),
                    "Status" => sortAscending ? result.OrderBy(t => t.Status) : result.OrderByDescending(t => t.Status),
                    "DeliveryRisk" => sortAscending ? result.OrderBy(t => t.DeliveryRisk) : result.OrderByDescending(t => t.DeliveryRisk),
                    _ => result
                };
            }

            return result.ToList();
        }
    }

    private void ApplySort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? "▲" : "▼";
    }

    private string AriaSort(string column) =>
        sortColumn != column ? "none" : sortAscending ? "ascending" : "descending";

    private void ClearFilters()
    {
        searchTerm = string.Empty;
        searchInput = string.Empty;
        statusFilter = string.Empty;
        riskFilter = string.Empty;
        scheduledFilter = string.Empty;
        sortColumn = string.Empty;
        sortAscending = true;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchInput = e.Value?.ToString() ?? string.Empty;
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(_ =>
            InvokeAsync(() => { searchTerm = searchInput; StateHasChanged(); }),
            null, 300, System.Threading.Timeout.Infinite);
    }

    public void Dispose() => _debounceTimer?.Dispose();

    protected override async Task OnInitializedAsync()
    {
        // Read URL query params for pre-filtering (e.g., from dashboard KPI click)
        var uri = new Uri(NavigationManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (!string.IsNullOrEmpty(query["risk"]))
            riskFilter = query["risk"]!;
        if (!string.IsNullOrEmpty(query["status"]))
            statusFilter = query["status"]!;
        if (!string.IsNullOrEmpty(query["scheduled"]))
            scheduledFilter = query["scheduled"]!;

        await LoadTasks();
        isLoaded = true;

        var editTaskId = query["editTaskId"];
        if (!string.IsNullOrWhiteSpace(editTaskId))
        {
            var taskToEdit = tasks.FirstOrDefault(t => t.TaskId.Equals(editTaskId, StringComparison.OrdinalIgnoreCase));
            if (taskToEdit != null)
                EditTask(taskToEdit);
        }
    }

    private async Task LoadTasks()
    {
        var taskResult = await Mediator.Send(new GetTasksQuery());
        tasks = taskResult.Value;

        var resourceResult = await Mediator.Send(new GetResourcesQuery());
        resources = resourceResult.Value;

        ComputeWarnings();
    }

    private async Task ShowAddModal()
    {
        var countResult = await Mediator.Send(new GetTaskCountQuery());
        var count = countResult.Value;
        taskForm = new TaskFormModel
        {
            TaskId = $"SVC-{(count + 1):D3}",
            Priority = 5
        };
        strictDateValue = null;
        selectedDepDetails = new();
        editingTask = null;
        modalError = string.Empty;
        fieldErrors.Clear();
        effortEntries = new List<EffortEntryModel>
        {
            new() { Role = "DEV", EstimationDays = 1, OverlapPct = 0 },
            new() { Role = "QA", EstimationDays = 1, OverlapPct = 0 }
        };
        editPhase = "";
        editPreferredResourceIds = "";
        selectedRoleToAdd = "";
        showModal = true;
    }

    private void EditTask(TaskItem task)
    {
        editingTask = task;
        taskForm = new TaskFormModel
        {
            Id = task.Id,
            TaskId = task.TaskId,
            ServiceName = task.ServiceName,
            Priority = task.Priority,
            StrictDate = task.StrictDate,
            DependsOnTaskIds = task.DependsOnTaskIds
        };
        strictDateValue = task.StrictDate;
        selectedDepDetails = task.Dependencies.Select(d => new SelectedDependencyDetail
        {
            TaskId = d.PredecessorTaskId,
            Type = d.Type,
            LagDays = d.LagDays
        }).ToList();
        effortEntries = task.EffortBreakdown.Select(e => new EffortEntryModel
        {
            Role = e.Role,
            EstimationDays = e.EstimationDays,
            MaxFte = e.MaxFte,
            OverlapPct = e.OverlapPct,
            MinSeniority = e.MinSeniority
        }).OrderBy(e => DomainConstants.ResourceRole.GetPipelineSortOrder(e.Role)).ToList();
        editPhase = task.Phase ?? "";
        editPreferredResourceIds = task.PreferredResourceIds ?? "";
        selectedRoleToAdd = "";
        modalError = string.Empty;
        fieldErrors.Clear();
        showModal = true;
    }

    private void DeleteTask(TaskItem task)
    {
        editingTask = task;
        showDeleteConfirm = true;
    }

    private async Task SaveTask()
    {
        modalError = string.Empty;
        fieldErrors.Clear();
        isSaving = true;
        try
        {
            var breakdown = effortEntries.Select(e => new EffortBreakdownInput(e.Role, e.EstimationDays, e.OverlapPct, e.MaxFte, string.IsNullOrEmpty(e.MinSeniority) ? null : e.MinSeniority)).ToList();
            var command = new UpsertTaskCommand(
                Id: taskForm.Id,
                TaskId: taskForm.TaskId,
                ServiceName: taskForm.ServiceName,
                Priority: taskForm.Priority,
                EffortBreakdown: breakdown,
                StrictDate: strictDateValue,
                Dependencies: selectedDepDetails.Any() ? selectedDepDetails.Select(d => new DependencyInput(d.TaskId, d.Type, d.LagDays, 0)).ToList() : null,
                IsNew: editingTask == null,
                Phase: string.IsNullOrWhiteSpace(editPhase) ? null : editPhase,
                PreferredResourceIds: string.IsNullOrWhiteSpace(editPreferredResourceIds) ? null : editPreferredResourceIds);

            var result = await Mediator.Send(command);
            await LoadTasks();
            var message = editingTask == null ? "Service added successfully." : "Service updated successfully.";
            CloseModal();
            toast.Show(message);
            await AutoScheduleIfEnabled();
        }
        catch (ValidationException ex)
        {
            foreach (var err in ex.Errors)
            {
                if (!string.IsNullOrWhiteSpace(err.PropertyName) && !fieldErrors.ContainsKey(err.PropertyName))
                    fieldErrors[err.PropertyName] = err.ErrorMessage;
            }
            modalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        try
        {
            if (editingTask != null)
            {
                var result = await Mediator.Send(new DeleteTaskCommand(editingTask.Id));
                toast.Show($"Service \"{editingTask.ServiceName}\" deleted.");
            }
            showDeleteConfirm = false;
            editingTask = null;
            StateHasChanged();
            await Task.Yield();
            await LoadTasks();
            await AutoScheduleIfEnabled();
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void CloseModal()
    {
        showModal = false;
        editingTask = null;
        modalError = string.Empty;
        fieldErrors.Clear();
    }

    private void CloseDeleteModal()
    {
        showDeleteConfirm = false;
        editingTask = null;
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        try
        {
            var result = await Mediator.Send(new RunSchedulerCommand());
            await LoadTasks();
            toast.Show("Schedule refreshed.");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private void NavigateToTask(string taskId)
    {
        NavigationManager.NavigateTo($"/tasks/{taskId}");
    }

    private void ToggleDependency(string taskId)
    {
        var existing = selectedDepDetails.FirstOrDefault(d => d.TaskId == taskId);
        if (existing != null)
            selectedDepDetails.Remove(existing);
        else
            selectedDepDetails.Add(new SelectedDependencyDetail { TaskId = taskId });
    }

    private void ShowBulkImportModal()
    {
        csvText = string.Empty;
        bulkError = string.Empty;
        parsedRows.Clear();
        showBulkImport = true;
    }

    private void CloseBulkImport()
    {
        showBulkImport = false;
        parsedRows.Clear();
    }

    private void ParseCsv()
    {
        bulkError = string.Empty;
        parsedRows.Clear();
        try
        {
            var lines = csvText.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var startIndex = 0;
            if (lines.Length > 0 && lines[0].Contains("TaskId", StringComparison.OrdinalIgnoreCase))
                startIndex = 1;

            foreach (var line in lines.Skip(startIndex))
            {
                var parts = line.Split(',');
                if (parts.Length < 3) continue;
                var devEst = double.TryParse(parts[2].Trim(), out var estDev) ? estDev : 1;
                var qaEst = parts.Length > 3 && double.TryParse(parts[3].Trim(), out var estQa) ? estQa : 1;
                var bulkEffort = new List<EffortBreakdownInput>
                {
                    new("DEV", devEst, 0),
                    new("QA", qaEst, 0)
                };
                parsedRows.Add(new BulkTaskRowDto(
                    TaskId: parts[0].Trim(),
                    ServiceName: parts[1].Trim(),
                    Priority: parts.Length > 4 && int.TryParse(parts[4].Trim(), out var pri) ? pri : 5,
                    EffortBreakdown: bulkEffort,
                    StrictDate: parts.Length > 5 && DateTime.TryParse(parts[5].Trim(), out var sd) ? sd : null,
                    Dependencies: parts.Length > 6 && !string.IsNullOrWhiteSpace(parts[6].Trim())
                        ? parts[6].Trim().Split(',', StringSplitOptions.RemoveEmptyEntries).Select(id => new DependencyInput(id.Trim(), "FS", 0, 0)).ToList()
                        : null
                ));
            }
        }
        catch (Exception ex)
        {
            bulkError = $"Parse error: {ex.Message}";
        }
    }

    private async Task ImportCsv()
    {
        if (!parsedRows.Any()) return;
        isImporting = true;
        bulkError = string.Empty;
        try
        {
            var result = await Mediator.Send(new BulkImportTasksCommand(parsedRows));
            if (result.IsSuccess)
            {
            toast.Show($"Successfully imported {result.Value} services.");
            CloseBulkImport();
            await LoadTasks();
            await AutoScheduleIfEnabled();
            }
            else
            {
                bulkError = result.Error.Message;
            }
        }
        catch (FluentValidation.ValidationException ex)
        {
            bulkError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        finally
        {
            isImporting = false;
        }
    }

    private void OnDragStart(string taskId)
    {
        dragTaskId = taskId;
    }

    private void OnDragOver(string taskId)
    {
        dragOverTaskId = taskId;
    }

    private void OnDragLeave()
    {
        dragOverTaskId = null;
    }

    private async Task OnDrop(TaskItem targetTask)
    {
        dragOverTaskId = null;
        if (dragTaskId == null || dragTaskId == targetTask.TaskId) return;

        var draggedTask = tasks.FirstOrDefault(t => t.TaskId == dragTaskId);
        if (draggedTask == null) return;

        // Swap priorities
        var dragPriority = draggedTask.Priority;
        var targetPriority = targetTask.Priority;
        if (dragPriority == targetPriority) return;

        try
        {
            var dragBreakdown = draggedTask.EffortBreakdown.Select(e => new EffortBreakdownInput(e.Role, e.EstimationDays, e.OverlapPct, e.MaxFte)).ToList();
            await Mediator.Send(new UpsertTaskCommand(
                Id: draggedTask.Id, TaskId: draggedTask.TaskId, ServiceName: draggedTask.ServiceName,
                Priority: targetPriority, EffortBreakdown: dragBreakdown, StrictDate: draggedTask.StrictDate,
                Dependencies: draggedTask.Dependencies.Any() ? draggedTask.Dependencies.Select(d => new DependencyInput(d.PredecessorTaskId, d.Type, d.LagDays, d.OverlapPct)).ToList() : null,
                IsNew: false,
                Phase: draggedTask.Phase, PreferredResourceIds: draggedTask.PreferredResourceIds));

            var targetBreakdown = targetTask.EffortBreakdown.Select(e => new EffortBreakdownInput(e.Role, e.EstimationDays, e.OverlapPct, e.MaxFte)).ToList();
            await Mediator.Send(new UpsertTaskCommand(
                Id: targetTask.Id, TaskId: targetTask.TaskId, ServiceName: targetTask.ServiceName,
                Priority: dragPriority, EffortBreakdown: targetBreakdown, StrictDate: targetTask.StrictDate,
                Dependencies: targetTask.Dependencies.Any() ? targetTask.Dependencies.Select(d => new DependencyInput(d.PredecessorTaskId, d.Type, d.LagDays, d.OverlapPct)).ToList() : null,
                IsNew: false,
                Phase: targetTask.Phase, PreferredResourceIds: targetTask.PreferredResourceIds));

            await LoadTasks();
            toast.Show($"Priority swapped: {draggedTask.TaskId} ↔ {targetTask.TaskId}");
            await AutoScheduleIfEnabled();
        }
        catch (Exception)
        {
            toast.Show("Failed to update priorities.");
        }
    }

    private void OnDragEnd()
    {
        dragTaskId = null;
        dragOverTaskId = null;
    }

    private async Task AutoScheduleIfEnabled()
    {
        if (autoSchedule.IsEnabled)
        {
            await Mediator.Send(new RunSchedulerCommand());
            await LoadTasks();
        }
    }
}
