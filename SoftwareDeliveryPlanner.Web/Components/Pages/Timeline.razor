@page "/timeline"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Timeline.Queries
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using SoftwareDeliveryPlanner.Application.Abstractions
@using SoftwareDeliveryPlanner.Domain.Models
@inject IMediator Mediator

<PageTitle>Employee Timeline</PageTitle>

<!-- ── Toast (shared component) ───────────────────────────── -->
<ToastNotification @ref="toast" TestId="timeline-toast" />

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-calendar-range me-2"></i>Employee Timeline</h3>
        <p class="page-subtitle">View employee day-by-day schedule and status</p>
    </div>
</div>

@if (!isLoaded)
{
    <SkeletonLoader Variant="block" TestId="timeline-skeleton" />
}
else if (!resources.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-people"></i></div>
        <h5>No resources available</h5>
        <p>Add team members on the Resources page to view their timeline.</p>
        <a href="/resources" class="btn btn-primary">
            <i class="bi bi-people"></i> Go to Resources
        </a>
    </div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label">Employee:</label>
            <select class="form-select" @onchange="OnResourceChanged" aria-label="Select employee" data-testid="timeline-resource">
                @foreach (var r in resources)
                {
                    <option value="@r.ResourceId">@r.ResourceName</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Start Date:</label>
            <input class="form-control" type="date" @bind="startDate" aria-label="Start date" data-testid="timeline-start-date" />
        </div>
        <div class="col-md-3">
            <label class="form-label">End Date:</label>
            <input class="form-control" type="date" @bind="endDate" aria-label="End date" data-testid="timeline-end-date" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-primary w-100" @onclick="() => LoadTimeline(showToast: true)" disabled="@isRefreshing" data-testid="timeline-refresh">
                @if (isRefreshing)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-arrow-clockwise"></i>
                }
                Refresh
            </button>
        </div>
    </div>

    <div class="timeline-container" data-testid="timeline-container">
        <div class="timeline-tiles">
            @foreach (var day in timelineDays)
            {
                <div class="timeline-tile @GetDayCssClass(day.Status)">
                    <div class="timeline-tile-label">@day.Date.ToString("MMM") @day.DateDisplay</div>
                    <div class="timeline-tile-content">
                        @if (!string.IsNullOrEmpty(day.TaskId))
                        {
                            <a href="/tasks/@day.TaskId">@day.TaskName</a>
                        }
                        else
                        {
                            @day.StatusText
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <div class="timeline-legend">
            <div><span class="timeline-legend-swatch" style="background: var(--color-success-light);"></span> Working Day</div>
            <div><span class="timeline-legend-swatch" style="background: var(--color-neutral-light);"></span> Weekend</div>
            <div><span class="timeline-legend-swatch" style="background: var(--color-warning-light);"></span> Holiday</div>
            <div><span class="timeline-legend-swatch" style="background: var(--color-accent-light);"></span> Adjustment</div>
            <div><span class="timeline-legend-swatch" style="background: var(--color-info-light);"></span> Task</div>
        </div>
    </div>
}

@code {
    private List<TeamMember> resources = new();
    private List<TimelineDayDto> timelineDays = new();
    private string selectedResourceId = "";
    private DateTime startDate = DateTime.Today.AddDays(-7);
    private DateTime endDate = DateTime.Today.AddMonths(2);
    private bool isLoaded = false;
    private bool isRefreshing = false;
    private ToastNotification toast = default!;

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.Send(new GetResourcesQuery());
        resources = result.Value;
        if (resources.Any())
        {
            selectedResourceId = resources.First().ResourceId;
            await LoadTimeline();
        }
        isLoaded = true;
    }

    private async Task OnResourceChanged(ChangeEventArgs e)
    {
        selectedResourceId = e.Value?.ToString() ?? "";
        await LoadTimeline();
    }

    private async Task LoadTimeline(bool showToast = false)
    {
        if (string.IsNullOrEmpty(selectedResourceId)) return;
        isRefreshing = true;
        try
        {
            var result = await Mediator.Send(new GetTimelineQuery(selectedResourceId, startDate, endDate));
            var data = result.Value;
            timelineDays = data.Days;
            if (showToast) toast.Show($"Timeline loaded — {timelineDays.Count} day(s).");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private static string GetDayCssClass(TimelineDayStatus status) => status switch
    {
        TimelineDayStatus.Weekend => "day-weekend",
        TimelineDayStatus.Holiday => "day-holiday",
        TimelineDayStatus.Adjustment => "day-adjustment",
        TimelineDayStatus.Working => "day-task",
        TimelineDayStatus.Free => "day-working",
        _ => ""
    };
}
