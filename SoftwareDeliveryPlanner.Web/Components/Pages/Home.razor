@page "/"
@using MediatR
@using SoftwareDeliveryPlanner.Application.DeliveryInsights.Queries
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Application.Planning.Queries
@using SoftwareDeliveryPlanner.Application.Abstractions
@using SoftwareDeliveryPlanner.Domain
@using SoftwareDeliveryPlanner.Domain.Models
@inject IMediator Mediator
@inject INotificationOrchestrator NotificationService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard</PageTitle>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h3>
        <p class="page-subtitle">Overview of your delivery schedule and key metrics</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="RunScheduler" disabled="@isRunning" data-testid="btn-run-scheduler">
            @if (isRunning)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise me-1"></i>
            }
            Run Scheduler
        </button>
        <button class="btn btn-outline-info" @onclick="PreviewChanges" disabled="@isPreviewing" data-testid="btn-preview-changes">
            @if (isPreviewing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-eye me-1"></i>
            }
            Preview Changes
        </button>
    </div>
</div>

@if (!isLoaded)
{
    <SkeletonLoader Variant="kpi" Columns="4" TestId="dashboard-skeleton-kpi" />
    <SkeletonLoader Variant="kpi" Columns="3" TestId="dashboard-skeleton-status" />
    <SkeletonLoader Variant="block" TestId="dashboard-skeleton-stats" />
}
else
{
    @if (isPlanStale)
    {
        <div class="alert alert-warning d-flex align-items-center mb-3" role="alert" data-testid="stale-plan-warning">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>
                <strong>Plan may be outdated.</strong> Run the scheduler to refresh delivery dates and risk assessments.
            </div>
        </div>
    }

    @if (notifications.Any())
    {
        <div class="card border-0 shadow-sm mb-3 border-start border-danger border-3" data-testid="risk-notifications">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0"><i class="bi bi-bell-fill text-danger me-2"></i>Risk Alerts (@notifications.Count)</h6>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="DismissNotifications" data-testid="dismiss-notifications">
                        <i class="bi bi-check-all me-1"></i>Dismiss All
                    </button>
                </div>
                @foreach (var n in notifications.Take(5))
                {
                    <div class="d-flex align-items-center gap-2 py-1 border-bottom">
                        <i class="bi bi-arrow-right-circle text-danger"></i>
                        <span><strong>@n.ServiceName</strong> (@n.TaskId) moved from <span class="badge @BadgeHelpers.RiskBadgeClass(n.PreviousRisk)">@n.PreviousRisk</span> to <span class="badge @BadgeHelpers.RiskBadgeClass(n.CurrentRisk)">@n.CurrentRisk</span></span>
                        <small class="text-muted ms-auto">@n.CreatedAt.ToString("MMM dd HH:mm")</small>
                    </div>
                }
                @if (notifications.Count > 5)
                {
                    <small class="text-muted mt-2 d-block">...and @(notifications.Count - 5) more</small>
                }
            </div>
        </div>
    }

    <!-- KPI Row -->
    <div class="row g-3 mb-4">
        <div class="col">
            <div class="kpi-card p-3 kpi-clickable" @onclick='() => NavigateToTasks("", "")' @onkeydown="(e) => OnKpiKeyDown(e, string.Empty, string.Empty)" role="button" tabindex="0" title="View all tasks">
                <div class="kpi-label">Total Services</div>
                <div class="kpi-value kpi-text-primary">@totalServices</div>
            </div>
        </div>
        <div class="col">
            <div class="kpi-card kpi-success p-3">
                <div class="kpi-label">Total Estimation</div>
                <div class="kpi-value kpi-text-success">@totalEstimation <small class="text-muted kpi-sub">days</small></div>
            </div>
        </div>
        <div class="col">
            <div class="kpi-card kpi-info p-3">
                <div class="kpi-label">Active Resources</div>
                <div class="kpi-value kpi-text-info">@activeResources</div>
                <div class="text-muted kpi-sub-detail">Capacity: @totalCapacity.ToString("F1")</div>
            </div>
        </div>
        <div class="col">
            <div class="kpi-card kpi-warning p-3">
                <div class="kpi-label">Projected Finish</div>
                <div class="kpi-value kpi-value-sm kpi-text-warning">@overallFinish</div>
            </div>
        </div>
        <div class="col">
            <div class="kpi-card p-3 kpi-clickable @(overallocationCount > 0 ? "kpi-danger" : "")" @onclick='() => NavigationManager.NavigateTo("/overallocation")' role="button" tabindex="0" title="View overallocation alerts" data-testid="kpi-overallocation">
                <div class="kpi-label">Overallocations</div>
                <div class="kpi-value @(overallocationCount > 0 ? "kpi-text-danger" : "kpi-text-success")">@overallocationCount</div>
            </div>
        </div>
    </div>

    <!-- Status Row -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="kpi-card kpi-success p-3 kpi-clickable" @onclick='() => NavigateToTasks("risk", DomainConstants.DeliveryRisk.OnTrack)' @onkeydown='(e) => OnKpiKeyDown(e, "risk", DomainConstants.DeliveryRisk.OnTrack)' role="button" tabindex="0" title="View On Track tasks">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="kpi-label">On Track</div>
                        <div class="kpi-value kpi-text-success">@onTrack</div>
                    </div>
                    <i class="bi bi-check-circle kpi-icon kpi-icon-success"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card kpi-warning p-3 kpi-clickable" @onclick='() => NavigateToTasks("risk", DomainConstants.DeliveryRisk.AtRisk)' @onkeydown='(e) => OnKpiKeyDown(e, "risk", DomainConstants.DeliveryRisk.AtRisk)' role="button" tabindex="0" title="View At Risk tasks">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="kpi-label">At Risk</div>
                        <div class="kpi-value kpi-text-warning">@atRisk</div>
                    </div>
                    <i class="bi bi-exclamation-triangle kpi-icon kpi-icon-warning"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card kpi-danger p-3 kpi-clickable" @onclick='() => NavigateToTasks("risk", DomainConstants.DeliveryRisk.Late)' @onkeydown='(e) => OnKpiKeyDown(e, "risk", DomainConstants.DeliveryRisk.Late)' role="button" tabindex="0" title="View Late tasks">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="kpi-label">Late</div>
                        <div class="kpi-value kpi-text-danger">@late</div>
                    </div>
                    <i class="bi bi-x-circle kpi-icon kpi-icon-danger"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card p-3 @(unscheduled > 0 ? "kpi-warning kpi-clickable" : "")" @onclick='() => { if (unscheduled > 0) NavigateToTasks("scheduled", "no"); }' @onkeydown='(e) => { if (unscheduled > 0) OnKpiKeyDown(e, "scheduled", "no"); }' role="@(unscheduled > 0 ? "button" : "")" tabindex="@(unscheduled > 0 ? 0 : -1)" title="@(unscheduled > 0 ? "View unscheduled tasks" : "All tasks are scheduled")" data-testid="kpi-unscheduled">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="kpi-label">Unscheduled</div>
                        <div class="kpi-value @(unscheduled > 0 ? "kpi-text-warning" : "kpi-text-success")">@unscheduled</div>
                    </div>
                    <i class="bi bi-calendar-x kpi-icon @(unscheduled > 0 ? "kpi-icon-warning" : "kpi-icon-success")"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Preview Diff Card (collapsible) -->
    @if (previewDiff is not null)
    {
        <div class="card border-0 shadow-sm mb-4 border-start border-info border-3" data-testid="preview-diff-card">
            <div class="card-header border-bottom d-flex justify-content-between align-items-center">
                <span><i class="bi bi-eye me-2"></i>Schedule Preview Diff</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => previewDiff = null" data-testid="preview-diff-close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="card-body">
                <div class="d-flex gap-4 mb-3">
                    <div><span class="text-muted">Tasks Affected:</span> <strong class="text-primary">@previewDiff.TasksAffected</strong></div>
                    <div><span class="text-muted">Unchanged:</span> <strong>@previewDiff.TasksUnchanged</strong></div>
                    <div><span class="text-muted">New Allocations:</span> <strong>@previewDiff.NewAllocations</strong></div>
                </div>
                @if (previewDiff.TaskChanges.Any())
                {
                    <div class="table-responsive" style="max-height:300px;overflow-y:auto">
                        <table class="table table-sm table-bordered mb-0" data-testid="preview-diff-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Task</th>
                                    <th>Change</th>
                                    <th>Start</th>
                                    <th>Finish</th>
                                    <th>Risk</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var change in previewDiff.TaskChanges)
                                {
                                    <tr>
                                        <td><strong>@change.TaskId</strong> <small class="text-muted">@change.TaskName</small></td>
                                        <td><span class="badge bg-@ChangeTypeBadge(change.ChangeType)">@change.ChangeType</span></td>
                                        <td>
                                            @(change.OldStart?.ToString("MMM dd") ?? "—")
                                            @if (change.OldStart != change.NewStart)
                                            { <span class="text-primary"> &rarr; @(change.NewStart?.ToString("MMM dd") ?? "—")</span> }
                                        </td>
                                        <td>
                                            @(change.OldFinish?.ToString("MMM dd") ?? "—")
                                            @if (change.OldFinish != change.NewFinish)
                                            { <span class="text-primary"> &rarr; @(change.NewFinish?.ToString("MMM dd") ?? "—")</span> }
                                        </td>
                                        <td>
                                            @(change.OldRisk ?? "—")
                                            @if (change.OldRisk != change.NewRisk)
                                            { <span class="text-primary"> &rarr; @(change.NewRisk ?? "—")</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No task changes detected. The schedule is up to date.</p>
                }
            </div>
        </div>
    }

    <!-- Statistics Card -->
    <div class="card border-0 shadow-sm">
        <div class="card-header border-bottom">
            <i class="bi bi-graph-up me-2"></i>Statistics
        </div>
        <div class="card-body">
            <div class="d-flex align-items-center gap-4">
                <div>
                    <span class="text-muted">Avg Assigned Resources:</span>
                    <strong class="ms-1">@avgAssigned</strong>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(schedulerResult))
            {
                <div class="mt-2">
                    <span class="badge bg-light text-dark" data-testid="scheduler-result">
                        <i class="bi bi-info-circle me-1"></i> @schedulerResult
                    </span>
                </div>
            }
        </div>
    </div>

    <!-- Risk Trend Chart -->
    @if (riskTrend.Any())
    {
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header border-bottom">
                <i class="bi bi-graph-up-arrow me-2"></i>Risk Trend
            </div>
            <div class="card-body" data-testid="risk-trend-chart">
                <div class="d-flex align-items-end gap-1" style="height: 120px;" role="img" aria-label="Risk trend chart: @riskTrend.Count data points showing on-track, at-risk, and late task distribution over time">
                    @foreach (var point in riskTrend)
                    {
                        var total = Math.Max(point.Total, 1);
                        var onTrackPct = (double)point.OnTrack / total * 100;
                        var atRiskPct = (double)point.AtRisk / total * 100;
                        var latePct = (double)point.Late / total * 100;
                        <div class="d-flex flex-column flex-fill" style="height: 100%;" title="@point.RunTimestamp.ToString("MMM dd HH:mm")">
                            <div style="flex: @Pct(latePct); background: var(--color-danger); border-radius: 2px 2px 0 0;" class="mb-0"></div>
                            <div style="flex: @Pct(atRiskPct); background: var(--color-warning);" class="mb-0"></div>
                            <div style="flex: @Pct(onTrackPct); background: var(--color-success); border-radius: 0 0 2px 2px;" class="mb-0"></div>
                        </div>
                    }
                </div>
                <div class="d-flex justify-content-between mt-2 small text-muted">
    @if (riskTrend.Any() && riskTrend.Any(p => p.Total > 0))
                    {
                        <span>@riskTrend.First().RunTimestamp.ToString("MMM dd")</span>
                        <span>@riskTrend.Last().RunTimestamp.ToString("MMM dd")</span>
                    }
                </div>
                <div class="d-flex gap-3 mt-2 small">
                    <span><span class="badge" style="background: var(--color-success);">&nbsp;</span> On Track</span>
                    <span><span class="badge" style="background: var(--color-warning);">&nbsp;</span> At Risk</span>
                    <span><span class="badge" style="background: var(--color-danger);">&nbsp;</span> Late</span>
                </div>
            </div>
        </div>
    }
}

@code {
    private int totalServices = 0;
    private double totalEstimation = 0;
    private int activeResources = 0;
    private double totalCapacity = 0;
    private string overallFinish = "N/A";
    private int onTrack = 0;
    private int atRisk = 0;
    private int late = 0;
    private int unscheduled = 0;
    private double avgAssigned = 0;
    private int overallocationCount = 0;
    private string schedulerResult = "";
    private bool isLoaded = false;
    private bool isRunning = false;
    private bool isPreviewing = false;
    private bool isPlanStale = false;
    private List<RiskTrendPointDto> riskTrend = new();
    private List<RiskNotification> notifications = new();
    private ScheduleDiffDto? previewDiff;

    protected override async Task OnInitializedAsync()
    {
        await LoadKPIs();

        var lastRunResult = await Mediator.Send(new GetLastSchedulerRunQuery());
        isPlanStale = !lastRunResult.IsSuccess || lastRunResult.Value is null;

        var trendResult = await Mediator.Send(new GetRiskTrendQuery(10));
        if (trendResult.IsSuccess)
            riskTrend = trendResult.Value;

        notifications = await NotificationService.GetNotificationsAsync(true);

        isLoaded = true;
    }

    private async Task LoadKPIs()
    {
        var result = await Mediator.Send(new GetDashboardKpisQuery());
        var kpis = result.Value;
        totalServices = kpis.TotalServices;
        totalEstimation = kpis.TotalEstimation;
        activeResources = kpis.ActiveResources;
        totalCapacity = kpis.TotalCapacity;
        overallFinish = kpis.OverallFinish?.ToString("d") ?? "N/A";
        onTrack = kpis.OnTrack;
        atRisk = kpis.AtRisk;
        late = kpis.Late;
        unscheduled = kpis.Unscheduled;
        avgAssigned = kpis.AvgAssigned;
        overallocationCount = kpis.OverallocationCount;
    }

    private async Task RunScheduler()
    {
        isRunning = true;
        try
        {
            var result = await Mediator.Send(new RunSchedulerCommand());
            schedulerResult = result.Value;
            await LoadKPIs();
            isPlanStale = false;
        }
        finally
        {
            isRunning = false;
        }
    }

    private void NavigateToTasks(string filterType, string filterValue)
    {
        if (string.IsNullOrEmpty(filterType))
            NavigationManager.NavigateTo("/tasks");
        else
            NavigationManager.NavigateTo($"/tasks?{filterType}={Uri.EscapeDataString(filterValue)}");
    }

    private void OnKpiKeyDown(KeyboardEventArgs e, string filterType, string filterValue)
    {
        if (e.Key is "Enter" or " ")
            NavigateToTasks(filterType, filterValue);
    }

    private async Task PreviewChanges()
    {
        isPreviewing = true;
        try
        {
            var result = await Mediator.Send(new PreviewScheduleCommand());
            previewDiff = result.Value;
        }
        finally
        {
            isPreviewing = false;
        }
    }

    private static string ChangeTypeBadge(string changeType) => changeType switch
    {
        "Added" => "success",
        "NowLate" => "danger",
        "NoLongerLate" => "info",
        "Modified" => "warning",
        _ => "secondary"
    };

    /// <summary>Format a double for CSS using invariant culture (defense-in-depth).</summary>
    private static string Pct(double val) => val.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private async Task DismissNotifications()
    {
        await NotificationService.MarkAllAsReadAsync();
        notifications.Clear();
    }
}
