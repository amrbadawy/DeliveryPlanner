@page "/"
@using MediatR
@using SoftwareDeliveryPlanner.Application.DeliveryInsights.Queries
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@inject IMediator Mediator

<PageTitle>Dashboard</PageTitle>

<h3 style="margin-bottom: 20px;">📊 Dashboard</h3>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-header">Total Services</div>
            <div class="card-body">
                <h4 class="card-title">@totalServices</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-header">Total Estimation (days)</div>
            <div class="card-body">
                <h4 class="card-title">@totalEstimation</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-header">Active Resources</div>
            <div class="card-body">
                <h4 class="card-title">@activeResources</h4>
                <small>Capacity: @totalCapacity.ToString("F1")</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-header">Projected Finish</div>
            <div class="card-body">
                <h4 class="card-title">@overallFinish</h4>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-success text-white">✅ On Track</div>
            <div class="card-body">
                <h2 style="color: green;">@onTrack</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-warning text-white">⚠️ At Risk</div>
            <div class="card-body">
                <h2 style="color: orange;">@atRisk</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-danger text-white">🔴 Late</div>
            <div class="card-body">
                <h2 style="color: red;">@late</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">📈 Statistics</div>
            <div class="card-body">
                <p>Avg Assigned Developers: <strong>@avgAssigned</strong></p>
                <button class="btn btn-primary" @onclick="RunScheduler" data-testid="btn-run-scheduler">
                    🔄 Run Scheduler
                </button>
                <span style="margin-left: 10px;" data-testid="scheduler-result">@schedulerResult</span>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalServices = 0;
    private double totalEstimation = 0;
    private int activeResources = 0;
    private double totalCapacity = 0;
    private string overallFinish = "N/A";
    private int onTrack = 0;
    private int atRisk = 0;
    private int late = 0;
    private double avgAssigned = 0;
    private string schedulerResult = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadKPIs();
    }

    private async Task LoadKPIs()
    {
        var result = await Mediator.Send(new GetDashboardKpisQuery());
        var kpis = result.Value;
        totalServices = kpis.TotalServices;
        totalEstimation = kpis.TotalEstimation;
        activeResources = kpis.ActiveResources;
        totalCapacity = kpis.TotalCapacity;
        overallFinish = kpis.OverallFinish?.ToString() ?? "N/A";
        onTrack = kpis.OnTrack;
        atRisk = kpis.AtRisk;
        late = kpis.Late;
        avgAssigned = kpis.AvgAssigned;
    }

    private async Task RunScheduler()
    {
        var result = await Mediator.Send(new RunSchedulerCommand());
        schedulerResult = result.Value;
        await LoadKPIs();
    }
}
