@page "/"
@using MediatR
@using SoftwareDeliveryPlanner.Application.DeliveryInsights.Queries
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@inject IMediator Mediator

<PageTitle>Dashboard</PageTitle>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h3>
        <p class="page-subtitle">Overview of your delivery schedule and key metrics</p>
    </div>
    <div>
        <button class="btn btn-primary" @onclick="RunScheduler" data-testid="btn-run-scheduler">
            <i class="bi bi-arrow-clockwise me-1"></i> Run Scheduler
        </button>
    </div>
</div>

@if (!isLoaded)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-muted mt-2">Loading dashboard...</p>
    </div>
}
else
{
    <!-- KPI Row -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="kpi-card p-3">
                <div class="kpi-label">Total Services</div>
                <div class="kpi-value text-primary">@totalServices</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card kpi-success p-3">
                <div class="kpi-label">Total Estimation</div>
                <div class="kpi-value" style="color: var(--color-success);">@totalEstimation <small class="text-muted fw-normal" style="font-size: 0.875rem;">days</small></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card kpi-info p-3">
                <div class="kpi-label">Active Resources</div>
                <div class="kpi-value" style="color: var(--color-info);">@activeResources</div>
                <div class="text-muted" style="font-size: 0.75rem;">Capacity: @totalCapacity.ToString("F1")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card kpi-warning p-3">
                <div class="kpi-label">Projected Finish</div>
                <div class="kpi-value" style="color: var(--color-warning); font-size: 1.125rem;">@overallFinish</div>
            </div>
        </div>
    </div>

    <!-- Status Row -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="kpi-card kpi-success p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="kpi-label">On Track</div>
                        <div class="kpi-value" style="color: var(--color-success);">@onTrack</div>
                    </div>
                    <i class="bi bi-check-circle" style="font-size: 2rem; color: var(--color-success); opacity: 0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi-card kpi-warning p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="kpi-label">At Risk</div>
                        <div class="kpi-value" style="color: var(--color-warning);">@atRisk</div>
                    </div>
                    <i class="bi bi-exclamation-triangle" style="font-size: 2rem; color: var(--color-warning); opacity: 0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi-card kpi-danger p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="kpi-label">Late</div>
                        <div class="kpi-value" style="color: var(--color-danger);">@late</div>
                    </div>
                    <i class="bi bi-x-circle" style="font-size: 2rem; color: var(--color-danger); opacity: 0.3;"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Card -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-bottom">
            <i class="bi bi-graph-up me-2"></i>Statistics
        </div>
        <div class="card-body">
            <div class="d-flex align-items-center gap-4">
                <div>
                    <span class="text-muted">Avg Assigned Developers:</span>
                    <strong class="ms-1">@avgAssigned</strong>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(schedulerResult))
            {
                <div class="mt-2">
                    <span class="badge bg-light text-dark" data-testid="scheduler-result">
                        <i class="bi bi-info-circle me-1"></i> @schedulerResult
                    </span>
                </div>
            }
        </div>
    </div>
}

@code {
    private int totalServices = 0;
    private double totalEstimation = 0;
    private int activeResources = 0;
    private double totalCapacity = 0;
    private string overallFinish = "N/A";
    private int onTrack = 0;
    private int atRisk = 0;
    private int late = 0;
    private double avgAssigned = 0;
    private string schedulerResult = "";
    private bool isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadKPIs();
        isLoaded = true;
    }

    private async Task LoadKPIs()
    {
        var result = await Mediator.Send(new GetDashboardKpisQuery());
        var kpis = result.Value;
        totalServices = kpis.TotalServices;
        totalEstimation = kpis.TotalEstimation;
        activeResources = kpis.ActiveResources;
        totalCapacity = kpis.TotalCapacity;
        overallFinish = kpis.OverallFinish?.ToString() ?? "N/A";
        onTrack = kpis.OnTrack;
        atRisk = kpis.AtRisk;
        late = kpis.Late;
        avgAssigned = kpis.AvgAssigned;
    }

    private async Task RunScheduler()
    {
        var result = await Mediator.Send(new RunSchedulerCommand());
        schedulerResult = result.Value;
        await LoadKPIs();
    }
}
