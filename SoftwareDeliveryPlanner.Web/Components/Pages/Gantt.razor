@page "/gantt"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Abstractions
@using SoftwareDeliveryPlanner.Application.Tasks.Queries
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Application.Settings.Queries
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator
@inject NavigationManager NavigationManager

<PageTitle>Gantt Chart</PageTitle>

<!-- ── Toast (shared component) ───────────────────────────── -->
<ToastNotification @ref="toast" TestId="gantt-toast" />

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-bar-chart-steps me-2"></i>Gantt Chart</h3>
        <p class="page-subtitle">Visual timeline of task scheduling and progress</p>
    </div>
    <div>
        <button class="btn @(showCriticalPath ? "btn-danger" : "btn-outline-danger") me-2" @onclick="ToggleCriticalPath" aria-pressed="@showCriticalPath.ToString().ToLowerInvariant()" data-testid="gantt-critical-path-toggle">
            <i class="bi bi-lightning"></i> Critical Path
        </button>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" disabled="@isRefreshing" data-testid="gantt-refresh">
            @if (isRefreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

@if (!isLoaded)
{
    <SkeletonLoader Variant="block" TestId="gantt-skeleton" />
}
else if (!string.IsNullOrEmpty(loadError))
{
    <div class="empty-state" data-testid="gantt-error">
        <div class="empty-icon"><i class="bi bi-exclamation-triangle text-danger"></i></div>
        <h5>Unable to load Gantt chart</h5>
        <p>@loadError</p>
        <button class="btn btn-outline-secondary" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise"></i> Retry
        </button>
    </div>
}
else if (!scheduledTasks.Any())
{
    <div class="empty-state" data-testid="gantt-empty">
        <div class="empty-icon"><i class="bi bi-bar-chart-steps"></i></div>
        <h5>No scheduled tasks</h5>
        @if (totalTaskCount > 0)
        {
            <p>@totalTaskCount task(s) exist but none have planned dates yet. Click Refresh to run the scheduler and generate the Gantt chart.</p>
        }
        else
        {
            <p>Click Refresh to run the scheduler and generate the Gantt chart.</p>
        }
        <button class="btn btn-outline-secondary" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
}
else
{
    <div class="mb-2 text-muted" data-testid="gantt-range">
        Plan range: <strong>@planStart.ToString("dd MMM yyyy")</strong> to <strong>@planEnd.ToString("dd MMM yyyy")</strong>
        (@totalDays days)
        @if (excludedTaskCount > 0)
        {
            <span class="ms-2 badge bg-warning text-dark" data-testid="gantt-excluded-count" title="@excludedTaskCount task(s) are not scheduled and do not appear on the chart">
                <i class="bi bi-exclamation-triangle me-1"></i>Showing @scheduledTasks.Count of @totalTaskCount tasks (@excludedTaskCount not scheduled)
            </span>
        }
    </div>

    <!-- Legend -->
    <div class="gantt-legend mb-3" data-testid="gantt-legend">
        <div class="gantt-legend-section">
            <span class="gantt-legend-title">Roles:</span>
            @foreach (var role in DomainConstants.ResourceRole.PipelineOrder)
            {
                var isVisible = visibleRoles.Contains(role);
                <button class="gantt-legend-toggle @(isVisible ? "" : "gantt-legend-toggle-off")"
                        @onclick="() => ToggleRole(role)"
                        aria-pressed="@isVisible.ToString().ToLowerInvariant()"
                        title="@(isVisible ? "Click to hide" : "Click to show") @DomainConstants.ResourceRole.GetDisplayName(role)"
                        data-testid="gantt-role-toggle-@role.ToLowerInvariant()">
                    <span class="gantt-legend-swatch gantt-role-@role.ToLowerInvariant()"></span>
                    @DomainConstants.ResourceRole.GetDisplayName(role)
                </button>
            }
        </div>
        <div class="gantt-legend-section">
            <span class="gantt-legend-title">Segments:</span>
            <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-legend-estimated-swatch"></span> Estimated</span>
            <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-legend-allocated-swatch"></span> Allocated</span>
        </div>
        <div class="gantt-legend-section">
            <span class="gantt-legend-title">Status:</span>
            <span class="gantt-legend-item"><span class="gantt-status-dot gantt-status-completed"></span> Completed</span>
            <span class="gantt-legend-item"><span class="gantt-status-dot gantt-status-inprogress"></span> In Progress</span>
            <span class="gantt-legend-item"><span class="gantt-status-dot gantt-status-notstarted"></span> Not Started</span>
            <span class="gantt-legend-item"><span class="gantt-status-dot gantt-status-atrisk"></span> At Risk</span>
            <span class="gantt-legend-item"><span class="gantt-status-dot gantt-status-late"></span> Late</span>
            @if (showCriticalPath)
            {
                <span class="gantt-legend-item"><span class="gantt-status-dot gantt-status-critical"></span> Critical Path</span>
            }
        </div>
    </div>

    <!-- Timeline headers (months + weeks) -->
    <div class="gantt-container" data-testid="gantt-chart" role="region" aria-label="Gantt chart showing @scheduledTasks.Count scheduled tasks from @planStart.ToString("dd MMM yyyy") to @planEnd.ToString("dd MMM yyyy")">
        <div class="gantt-header gantt-header-months">
            <div class="gantt-label-col gantt-label-col-header"><strong>Task</strong></div>
            <div class="gantt-timeline-col">
                <div class="gantt-months">
                    @foreach (var month in GetMonthMarkers())
                    {
                        <div class="gantt-month" style="left: @Pct(month.LeftPct)%; width: @Pct(month.WidthPct)%;">
                            @month.Label
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="gantt-header gantt-header-weeks">
            <div class="gantt-label-col gantt-week-label-col"></div>
            <div class="gantt-timeline-col">
                <div class="gantt-weeks">
                    @foreach (var week in GetWeekMarkers())
                    {
                        <div class="gantt-week" style="left: @Pct(week.LeftPct)%; width: @Pct(week.WidthPct)%;" title="@week.FullLabel">
                            <span class="gantt-week-number">@week.Label</span>
                            <span class="gantt-week-dates">@week.DateRange</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Week grid lines *@
        @foreach (var week in GetWeekMarkers())
        {
            <div class="gantt-week-line" style="left: calc(240px + (100% - 240px) * @Pct(week.LeftPct) / 100);"></div>
        }

        <!-- Task rows (virtualized for 100+ task performance) -->
        <div class="gantt-rows-container">
        <Virtualize Items="scheduledTasks" Context="task" OverscanCount="5">
            @{
                var segments = GetSegmentsForTask(task.TaskId).Where(s => visibleRoles.Contains(s.Role)).ToList();
                var visibleSegments = segments.Take(MaxVisibleLanes).ToList();
                var hiddenCount = segments.Count - visibleSegments.Count;
                var laneCount = Math.Max(1, visibleSegments.Count);
                var shellHeight = laneCount * LaneHeight + LanePadding;
                var maxSegEnd = visibleSegments.Any() && task.PlannedFinish.HasValue
                    ? visibleSegments.Max(s => s.SegmentEnd)
                    : (task.PlannedFinish ?? DateTime.MinValue);
                var effectiveEnd = maxSegEnd > (task.PlannedFinish ?? DateTime.MinValue) ? maxSegEnd : task.PlannedFinish ?? DateTime.MinValue;
                var barStyle = GetBarStyle(task, shellHeight, effectiveEnd);
                var statusClass = GetStatusClass(task);
            }

            <div class="gantt-row" data-testid="gantt-row-@task.TaskId" role="group" aria-label="Task @task.TaskId: @task.ServiceName">
                <div class="gantt-label-col clickable-row" title="@task.ServiceName"
                     role="button" tabindex="0"
                     @onclick="() => NavigateToTask(task.TaskId)"
                     @onkeydown="(e) => OnGanttKeyDown(e, task.TaskId)">
                    <div class="gantt-label-content">
                        <span class="gantt-status-dot @statusClass" title="@task.Status @(task.DeliveryRisk != DomainConstants.DeliveryRisk.OnTrack ? $"({task.DeliveryRisk})" : "")"></span>
                        <span class="gantt-task-id">@task.TaskId</span>
                        <span class="gantt-task-name" title="@task.ServiceName">@Truncate(task.ServiceName, 20)</span>
                        @if (task.Priority is > 0 and <= 3)
                        {
                            <span class="gantt-priority-badge gantt-priority-high" title="Priority @task.Priority">P@task.Priority</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(task.DependsOnTaskIds))
                    {
                        <div class="gantt-dep-subtitle" title="Depends on: @task.DependsOnTaskIds">
                            <i class="bi bi-arrow-return-right"></i> @task.DependsOnTaskIds
                        </div>
                    }
                </div>
                <div class="gantt-timeline-col" style="min-height: @(shellHeight + 8)px;">
                    @if (task.PlannedStart.HasValue && task.PlannedFinish.HasValue)
                    {
                        @* Shell bar: transparent container for role segments *@
                        <div class="gantt-shell gantt-tooltip @(IsCriticalTask(task) ? "gantt-bar-critical" : "")" style="@barStyle"
                             data-tooltip="@task.TaskId: @task.ServiceName&#10;Status: @task.Status | Risk: @task.DeliveryRisk&#10;@task.PlannedStart?.ToString("dd MMM yyyy") — @task.PlannedFinish?.ToString("dd MMM yyyy") (@task.Duration d)"
                             role="button" tabindex="0"
                             aria-label="@task.TaskId bar: @task.PlannedStart?.ToString("dd MMM") to @task.PlannedFinish?.ToString("dd MMM"), @visibleSegments.Count role segments"
                             @onclick="() => NavigateToTask(task.TaskId)" @onclick:stopPropagation
                             @onkeydown="(e) => OnGanttKeyDown(e, task.TaskId)" @onkeydown:stopPropagation
                             data-testid="gantt-bar-@task.TaskId">

                            @* Role segments: full-height colored bars *@
                            @foreach (var seg in visibleSegments)
                            {
                                var segStyle = GetSegmentStyle(task, seg, effectiveEnd);
                                var estimatedLabel = seg.IsEstimated ? " (Estimated - no resources assigned)" : "";
                                var segTooltip = $"{seg.Role}: {DomainConstants.ResourceRole.GetDisplayName(seg.Role)}{estimatedLabel}\n" +
                                                 $"Start: {seg.SegmentStart:yyyy-MM-dd}\n" +
                                                 $"End: {seg.SegmentEnd:yyyy-MM-dd}\n" +
                                                 $"Duration: {seg.DurationDays}d\n" +
                                                 $"Max FTE: {seg.MaxFte}\n" +
                                                 (seg.IsEstimated ? "Resources: None (unallocated)" : $"Resources: {string.Join(", ", seg.AssignedResources.Select(r => r.ResourceName))}");
                                var laneIndex = visibleSegments.IndexOf(seg);
                                var segCssClass = $"gantt-segment gantt-tooltip gantt-role-{seg.Role.ToLowerInvariant()}{(seg.IsEstimated ? " gantt-segment-estimated" : "")}";
                                var segAriaLabel = $"{seg.Role} segment: {seg.SegmentStart:dd MMM} to {seg.SegmentEnd:dd MMM}{(seg.IsEstimated ? " (estimated)" : "")}";
                                <div class="@segCssClass"
                                     style="@segStyle; top: @(laneIndex * LaneHeight + 2)px;"
                                     data-tooltip="@segTooltip"
                                     tabindex="0"
                                     aria-label="@segAriaLabel"
                                     data-testid="gantt-segment-@task.TaskId-@seg.Role">
                                    <span class="gantt-segment-label">@seg.Role@(seg.IsEstimated ? "*" : "")</span>
                                </div>
                            }

                            @if (hiddenCount > 0)
                            {
                                var hiddenRoles = string.Join(", ", segments.Skip(MaxVisibleLanes).Select(s => s.Role));
                                <span class="gantt-overflow-indicator" title="@hiddenRoles"
                                      data-testid="gantt-overflow-@task.TaskId">+@hiddenCount</span>
                            }

                            <span class="gantt-bar-label">@task.Duration d</span>
                        </div>

                        @if (task.StrictDate.HasValue)
                        {
                            var strictPct = GetDatePercent(task.StrictDate.Value);
                            var delta = (task.StrictDate.Value - task.PlannedFinish!.Value).Days;
                            var deltaClass = delta >= 0 ? "gantt-strict-ok" : "gantt-strict-overdue";
                            <div class="gantt-strict-marker @deltaClass" style="left: @Pct(strictPct)%;"
                                 title="Deadline: @task.StrictDate.Value.ToString("dd MMM yyyy") (@(delta >= 0 ? $"{delta}d buffer" : $"{Math.Abs(delta)}d overdue"))"
                                 data-testid="gantt-strict-@task.TaskId">
                                <span class="gantt-strict-flag">@(delta >= 0 ? $"+{delta}d" : $"{delta}d")</span>
                            </div>
                        }
                    }
                    else
                    {
                        <span class="text-muted small">Not scheduled</span>
                    }
                </div>
            </div>
        </Virtualize>
        </div>

        <!-- Today marker -->
        @{
            var todayPct = GetDatePercent(DateTime.Today);
            if (todayPct >= 0 && todayPct <= 100)
            {
                <div class="gantt-today-line" style="left: calc(240px + (100% - 240px) * @Pct(todayPct) / 100);"
                     data-testid="gantt-today" title="Today: @DateTime.Today.ToString("yyyy-MM-dd")">
                </div>
            }
        }
    </div>
}

@code {
    private const int MaxVisibleLanes = 6;
    private const int LaneHeight = 18;   // Height per role lane
    private const int LanePadding = 6;   // Top+bottom padding in shell

    private List<TaskItem> scheduledTasks = new();
    private int totalTaskCount;
    private int excludedTaskCount;
    private Dictionary<string, IReadOnlyList<GanttRoleSegmentDto>> segmentsByTask = new(StringComparer.OrdinalIgnoreCase);
    private DateTime planStart;
    private DateTime planEnd;
    private int totalDays;
    private bool isRefreshing = false;
    private bool isLoaded = false;
    private string? loadError;
    private bool showCriticalPath = false;
    private HashSet<string> criticalPathTaskIds = new();
    private HashSet<string> visibleRoles = new(DomainConstants.ResourceRole.PipelineOrder, StringComparer.OrdinalIgnoreCase);
    private string workingWeekCode = DomainConstants.WorkingWeek.SunThu;
    private ToastNotification toast = default!;
    private List<MonthMarker> _cachedMonthMarkers = new();
    private List<WeekMarker> _cachedWeekMarkers = new();

    protected override async Task OnInitializedAsync()
    {
        // Load settings to get working week config
        var settingsResult = await Mediator.Send(new GetSettingsQuery());
        if (settingsResult.IsSuccess && !string.IsNullOrEmpty(settingsResult.Value.GlobalWorkingWeek))
            workingWeekCode = settingsResult.Value.GlobalWorkingWeek;

        try
        {
            await LoadData();
        }
        catch (Exception ex)
        {
            loadError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isLoaded = true;
        }
    }

    private async Task LoadData()
    {
        loadError = null;

        var result = await Mediator.Send(new GetTasksQuery());
        if (!result.IsSuccess)
        {
            loadError = "Failed to load tasks. Please try refreshing.";
            return;
        }

        var allTasks = result.Value;
        totalTaskCount = allTasks.Count;

        // Only show tasks with a planned start and finish
        scheduledTasks = allTasks
            .Where(t => t.PlannedStart.HasValue && t.PlannedFinish.HasValue)
            .OrderBy(t => t.PlannedStart)
            .ThenBy(t => t.SchedulingRank)
            .ToList();

        excludedTaskCount = totalTaskCount - scheduledTasks.Count;

        // Load role-based segments
        var segResult = await Mediator.Send(new GetGanttSegmentsQuery());
        if (!segResult.IsSuccess)
        {
            loadError = "Failed to load Gantt segments. Please try refreshing.";
            return;
        }

        var allSegments = segResult.Value;
        segmentsByTask = allSegments.ToDictionary(s => s.TaskId, s => s.Segments, StringComparer.OrdinalIgnoreCase);

        if (scheduledTasks.Any())
        {
            planStart = scheduledTasks.Min(t => t.PlannedStart!.Value).Date;
            planEnd = scheduledTasks.Max(t => t.PlannedFinish!.Value).Date;

            // Extend range to include strict dates
            var maxStrict = allTasks
                .Where(t => t.StrictDate.HasValue)
                .Select(t => t.StrictDate!.Value)
                .DefaultIfEmpty(planEnd)
                .Max();
            if (maxStrict > planEnd)
                planEnd = maxStrict;

            // Add a small buffer
            planStart = planStart.AddDays(-2);
            planEnd = planEnd.AddDays(5);
            totalDays = (int)(planEnd - planStart).TotalDays;
            if (totalDays < 1) totalDays = 1;

            // Pre-compute markers (M5 cache)
            _cachedMonthMarkers = ComputeMonthMarkers();
            _cachedWeekMarkers = ComputeWeekMarkers();
        }
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        try
        {
            var result = await Mediator.Send(new RunSchedulerCommand());
            if (result.IsSuccess)
            {
                await LoadData();
                toast.Show(result.Value ?? "Schedule refreshed.");
            }
            else
            {
                toast.Show($"Scheduler failed: {result.Error}", "error");
            }
        }
        catch (Exception ex)
        {
            toast.Show($"Scheduler error: {ex.Message}", "error");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private IReadOnlyList<GanttRoleSegmentDto> GetSegmentsForTask(string taskId)
        => segmentsByTask.GetValueOrDefault(taskId) ?? Array.Empty<GanttRoleSegmentDto>();

    private double GetDatePercent(DateTime date)
    {
        if (totalDays <= 0) return 0;
        var dayOffset = (date.Date - planStart).TotalDays;
        return Math.Round(dayOffset / totalDays * 100, 2);
    }

    private string GetBarStyle(TaskItem task, int shellHeight, DateTime effectiveEnd)
    {
        if (!task.PlannedStart.HasValue || !task.PlannedFinish.HasValue)
            return "display: none;";

        var leftPct = GetDatePercent(task.PlannedStart.Value);
        var rightPct = GetDatePercent(effectiveEnd);
        var widthPct = Math.Max(rightPct - leftPct, 0.5); // minimum visible width

        return FormattableString.Invariant($"left: {leftPct}%; width: {widthPct}%; height: {shellHeight}px;");
    }

    /// <summary>
    /// Computes position of a role segment relative to the shell bar (parent).
    /// Returns left/width as percentages of the shell bar.
    /// </summary>
    private string GetSegmentStyle(TaskItem task, GanttRoleSegmentDto segment, DateTime effectiveEnd)
    {
        if (!task.PlannedStart.HasValue || !task.PlannedFinish.HasValue)
            return "display: none;";

        var taskStart = task.PlannedStart.Value;
        var taskEnd = effectiveEnd;

        var taskSpan = (taskEnd - taskStart).TotalDays;
        if (taskSpan < 1) taskSpan = 1;

        var segLeftDays = (segment.SegmentStart - taskStart).TotalDays;
        var segWidthDays = (segment.SegmentEnd - segment.SegmentStart).TotalDays + 1;

        var leftPct = Math.Max(0, Math.Round(segLeftDays / taskSpan * 100, 2));
        var widthPct = Math.Max(1, Math.Round(segWidthDays / taskSpan * 100, 2));
        // Clamp to not overflow
        if (leftPct + widthPct > 100) widthPct = 100 - leftPct;
        // Guarantee minimum visible width
        if (widthPct < 1) widthPct = 1;

        return FormattableString.Invariant($"left: {leftPct}%; width: {widthPct}%");
    }

    private string GetStatusClass(TaskItem task)
    {
        // Risk takes precedence
        if (task.DeliveryRisk == DomainConstants.DeliveryRisk.Late)
            return "gantt-status-late";
        if (task.DeliveryRisk == DomainConstants.DeliveryRisk.AtRisk)
            return "gantt-status-atrisk";

        return task.Status switch
        {
            var s when s == DomainConstants.TaskStatus.Completed => "gantt-status-completed",
            var s when s == DomainConstants.TaskStatus.InProgress => "gantt-status-inprogress",
            _ => "gantt-status-notstarted"
        };
    }

    private List<MonthMarker> GetMonthMarkers() => _cachedMonthMarkers;

    private List<MonthMarker> ComputeMonthMarkers()
    {
        var markers = new List<MonthMarker>();
        if (totalDays <= 0) return markers;

        var current = new DateTime(planStart.Year, planStart.Month, 1);
        while (current <= planEnd)
        {
            var monthEnd = current.AddMonths(1).AddDays(-1);
            if (monthEnd > planEnd) monthEnd = planEnd;

            var start = current < planStart ? planStart : current;
            var leftPct = GetDatePercent(start);
            var rightPct = GetDatePercent(monthEnd);

            markers.Add(new MonthMarker
            {
                Label = current.ToString("MMM yyyy"),
                LeftPct = Math.Round(leftPct, 2),
                WidthPct = Math.Round(Math.Max(rightPct - leftPct, 1), 2)
            });

            current = current.AddMonths(1);
        }

        return markers;
    }

    private static string Truncate(string text, int maxLength)
        => text.Length <= maxLength ? text : text[..(maxLength - 1)] + "\u2026";

    /// <summary>Format a double for CSS using invariant culture (defense-in-depth).</summary>
    private static string Pct(double val) => val.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private void NavigateToTask(string taskId)
    {
        NavigationManager.NavigateTo($"/tasks/{taskId}");
    }

    private void OnGanttKeyDown(KeyboardEventArgs e, string taskId)
    {
        if (e.Key is "Enter" or " ")
            NavigateToTask(taskId);
    }

    private void ToggleRole(string role)
    {
        if (visibleRoles.Contains(role))
        {
            // Don't allow hiding all roles
            if (visibleRoles.Count > 1)
                visibleRoles.Remove(role);
        }
        else
        {
            visibleRoles.Add(role);
        }
    }

    private void ToggleCriticalPath()
    {
        showCriticalPath = !showCriticalPath;
        if (showCriticalPath)
        {
            ComputeCriticalPath();
            if (criticalPathTaskIds.Count == 0)
            {
                toast.Show("No critical path found — tasks may not have dependency chains.");
            }
        }
    }

    private void ComputeCriticalPath()
    {
        criticalPathTaskIds.Clear();
        if (!scheduledTasks.Any()) return;

        var taskMap = scheduledTasks.ToDictionary(t => t.TaskId);
        var memo = new Dictionary<string, (int length, List<string> path)>();
        var visiting = new HashSet<string>(); // cycle guard

        (int length, List<string> path) GetLongestPath(string taskId)
        {
            if (memo.TryGetValue(taskId, out var cached)) return cached;
            if (!visiting.Add(taskId)) return (0, new List<string>()); // cycle detected

            var task = taskMap.GetValueOrDefault(taskId);
            if (task == null) { visiting.Remove(taskId); return (0, new List<string>()); }

            var deps = string.IsNullOrWhiteSpace(task.DependsOnTaskIds)
                ? Array.Empty<string>()
                : task.DependsOnTaskIds.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            int maxLen = 0;
            var bestPath = new List<string>();

            foreach (var dep in deps)
            {
                var (len, path) = GetLongestPath(dep);
                if (len > maxLen)
                {
                    maxLen = len;
                    bestPath = new List<string>(path);
                }
            }

            bestPath.Add(taskId);
            var taskDuration = (task.Duration ?? 0) > 0 ? task.Duration!.Value : (int)task.TotalEstimationDays;
            var result = (maxLen + taskDuration, bestPath);
            memo[taskId] = result;
            visiting.Remove(taskId);
            return result;
        }

        var longestPath = scheduledTasks
            .Select(t => GetLongestPath(t.TaskId))
            .OrderByDescending(r => r.length)
            .FirstOrDefault();

        criticalPathTaskIds = new HashSet<string>(longestPath.path);
    }

    private bool IsCriticalTask(TaskItem task)
    {
        return showCriticalPath && criticalPathTaskIds.Contains(task.TaskId);
    }

    private record MonthMarker
    {
        public string Label { get; init; } = "";
        public double LeftPct { get; init; }
        public double WidthPct { get; init; }
    }

    private record WeekMarker
    {
        public string Label { get; init; } = "";
        public string DateRange { get; init; } = "";
        public string FullLabel { get; init; } = "";
        public double LeftPct { get; init; }
        public double WidthPct { get; init; }
    }

    private List<WeekMarker> GetWeekMarkers() => _cachedWeekMarkers;

    private List<WeekMarker> ComputeWeekMarkers()
    {
        var markers = new List<WeekMarker>();
        if (totalDays <= 0) return markers;

        var weekStartDay = DomainConstants.WorkingWeek.GetWeekStartDay(workingWeekCode);

        // Find first week-start day on or after planStart
        var current = planStart;
        while (current.DayOfWeek != weekStartDay)
            current = current.AddDays(1);

        int weekNumber = 1;
        while (current <= planEnd)
        {
            var weekEnd = current.AddDays(6);
            if (weekEnd > planEnd) weekEnd = planEnd;

            var leftPct = GetDatePercent(current);
            var rightPct = GetDatePercent(weekEnd);

            var dateRange = $"{current:dd MMM} - {weekEnd:dd MMM}";

            markers.Add(new WeekMarker
            {
                Label = $"W{weekNumber}",
                DateRange = dateRange,
                FullLabel = $"Week {weekNumber} ({dateRange})",
                LeftPct = Math.Round(leftPct, 2),
                WidthPct = Math.Round(Math.Max(rightPct - leftPct, 0.5), 2)
            });

            weekNumber++;
            current = current.AddDays(7);
        }

        return markers;
    }
}
