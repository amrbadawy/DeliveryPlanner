@page "/gantt"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Tasks.Queries
@using SoftwareDeliveryPlanner.Application.Planning.Commands
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Domain
@inject IMediator Mediator
@inject NavigationManager NavigationManager

<PageTitle>Gantt Chart</PageTitle>

<!-- ── Toast (shared component) ───────────────────────────── -->
<ToastNotification @ref="toast" TestId="gantt-toast" />

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-bar-chart-steps me-2"></i>Gantt Chart</h3>
        <p class="page-subtitle">Visual timeline of task scheduling and progress</p>
    </div>
    <div>
        <button class="btn @(showCriticalPath ? "btn-danger" : "btn-outline-danger") me-2" @onclick="ToggleCriticalPath" data-testid="gantt-critical-path-toggle">
            <i class="bi bi-lightning"></i> Critical Path
        </button>
        <button class="btn btn-outline-secondary" @onclick="RefreshData" disabled="@isRefreshing" data-testid="gantt-refresh">
            @if (isRefreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

@if (!isLoaded)
{
    <SkeletonLoader Variant="block" TestId="gantt-skeleton" />
}
else if (!scheduledTasks.Any())
{
    <div class="empty-state" data-testid="gantt-empty">
        <div class="empty-icon"><i class="bi bi-bar-chart-steps"></i></div>
        <h5>No scheduled tasks</h5>
        <p>Click Refresh to run the scheduler and generate the Gantt chart.</p>
        <button class="btn btn-outline-secondary" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
}
else
{
    <div class="mb-2 text-muted" data-testid="gantt-range">
        Plan range: <strong>@planStart.ToString("yyyy-MM-dd")</strong> to <strong>@planEnd.ToString("yyyy-MM-dd")</strong>
        (@totalDays days)
    </div>

    <!-- Legend -->
    <div class="d-flex gap-3 mb-3" data-testid="gantt-legend">
        <span><span class="badge gantt-bar-completed">&nbsp;&nbsp;</span> Completed</span>
        <span><span class="badge gantt-bar-inprogress">&nbsp;&nbsp;</span> In Progress</span>
        <span><span class="badge gantt-bar-notstarted">&nbsp;&nbsp;</span> Not Started</span>
        <span><span class="badge gantt-bar-atrisk">&nbsp;&nbsp;</span> At Risk</span>
        <span><span class="badge gantt-bar-late">&nbsp;&nbsp;</span> Late</span>
        @if (showCriticalPath)
        {
            <span><span class="badge gantt-bar-critical">&nbsp;&nbsp;</span> Critical Path</span>
        }
    </div>

    <!-- Month headers -->
    <div class="gantt-container" data-testid="gantt-chart">
        <div class="gantt-header">
            <div class="gantt-label-col"><strong>Task</strong></div>
            <div class="gantt-timeline-col">
                <div class="gantt-months">
                    @foreach (var month in GetMonthMarkers())
                    {
                        <div class="gantt-month" style="left: @month.LeftPct%; width: @month.WidthPct%;">
                            @month.Label
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Task rows -->
        @foreach (var task in scheduledTasks)
        {
            var barStyle = GetBarStyle(task);
            var barClass = GetBarColorClass(task);
            var tooltip = $"{task.TaskId}: {task.ServiceName}\n" +
                          $"Start: {task.PlannedStart?.ToString("yyyy-MM-dd")}\n" +
                          $"Finish: {task.PlannedFinish?.ToString("yyyy-MM-dd")}\n" +
                          $"Duration: {task.Duration} days\n" +
                          $"Status: {task.Status}\n" +
                          $"Risk: {task.DeliveryRisk}";

            <div class="gantt-row" data-testid="gantt-row-@task.TaskId">
                <div class="gantt-label-col clickable-row" title="@task.ServiceName"
                     role="button" tabindex="0"
                     @onclick="() => NavigateToTask(task.TaskId)"
                     @onkeydown="(e) => OnGanttKeyDown(e, task.TaskId)">
                    <span class="gantt-task-id">@task.TaskId</span>
                    <span class="gantt-task-name">@Truncate(task.ServiceName, 18)</span>
                </div>
                <div class="gantt-timeline-col">
                    @if (task.PlannedStart.HasValue && task.PlannedFinish.HasValue)
                    {
                        <div class="gantt-bar @barClass @(IsCriticalTask(task) ? "gantt-bar-critical" : "")" style="@barStyle" title="@tooltip"
                             role="button" tabindex="0"
                             @onclick="() => NavigateToTask(task.TaskId)" @onclick:stopPropagation
                             @onkeydown="(e) => OnGanttKeyDown(e, task.TaskId)" @onkeydown:stopPropagation
                             data-testid="gantt-bar-@task.TaskId">
                            <span class="gantt-bar-label">@task.Duration d</span>
                        </div>

                        @if (task.StrictDate.HasValue)
                        {
                            var strictPct = GetDatePercent(task.StrictDate.Value);
                            <div class="gantt-strict-marker" style="left: @strictPct%;"
                                 title="Strict: @task.StrictDate.Value.ToString("yyyy-MM-dd")"
                                 data-testid="gantt-strict-@task.TaskId">
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(task.DependsOnTaskIds))
                        {
                            <span class="gantt-dep-indicator" title="Depends on: @task.DependsOnTaskIds"><i class="bi bi-link-45deg"></i></span>
                        }
                    }
                    else
                    {
                        <span class="text-muted small">Not scheduled</span>
                    }
                </div>
            </div>
        }

        <!-- Today marker -->
        @{
            var todayPct = GetDatePercent(DateTime.Today);
            if (todayPct >= 0 && todayPct <= 100)
            {
                <div class="gantt-today-line" style="left: calc(200px + (@todayPct% * (100% - 200px) / 100));"
                     data-testid="gantt-today" title="Today: @DateTime.Today.ToString("yyyy-MM-dd")">
                </div>
            }
        }
    </div>
}

@code {
    private List<TaskItem> scheduledTasks = new();
    private DateTime planStart;
    private DateTime planEnd;
    private int totalDays;
    private bool isRefreshing = false;
    private bool isLoaded = false;
    private bool showCriticalPath = false;
    private HashSet<string> criticalPathTaskIds = new();
    private ToastNotification toast = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        isLoaded = true;
    }

    private async Task LoadData()
    {
        var result = await Mediator.Send(new GetTasksQuery());
        var allTasks = result.Value;

        // Only show tasks with a planned start and finish
        scheduledTasks = allTasks
            .Where(t => t.PlannedStart.HasValue && t.PlannedFinish.HasValue)
            .OrderBy(t => t.PlannedStart)
            .ThenBy(t => t.SchedulingRank)
            .ToList();

        if (scheduledTasks.Any())
        {
            planStart = scheduledTasks.Min(t => t.PlannedStart!.Value).Date;
            planEnd = scheduledTasks.Max(t => t.PlannedFinish!.Value).Date;

            // Extend range to include strict dates
            var maxStrict = allTasks
                .Where(t => t.StrictDate.HasValue)
                .Select(t => t.StrictDate!.Value)
                .DefaultIfEmpty(planEnd)
                .Max();
            if (maxStrict > planEnd)
                planEnd = maxStrict;

            // Add a small buffer
            planStart = planStart.AddDays(-2);
            planEnd = planEnd.AddDays(5);
            totalDays = (int)(planEnd - planStart).TotalDays;
            if (totalDays < 1) totalDays = 1;
        }
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        try
        {
            var result = await Mediator.Send(new RunSchedulerCommand());
            await LoadData();
            toast.Show("Schedule refreshed.");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private double GetDatePercent(DateTime date)
    {
        if (totalDays <= 0) return 0;
        var dayOffset = (date.Date - planStart).TotalDays;
        return Math.Round(dayOffset / totalDays * 100, 2);
    }

    private string GetBarStyle(TaskItem task)
    {
        if (!task.PlannedStart.HasValue || !task.PlannedFinish.HasValue)
            return "display: none;";

        var leftPct = GetDatePercent(task.PlannedStart.Value);
        var rightPct = GetDatePercent(task.PlannedFinish.Value);
        var widthPct = Math.Max(rightPct - leftPct, 0.5); // minimum visible width

        return $"left: {leftPct}%; width: {widthPct}%;";
    }

    private string GetBarColorClass(TaskItem task)
    {
        // Color by risk first (Late/AtRisk take precedence for visual warnings)
        if (task.DeliveryRisk == DomainConstants.DeliveryRisk.Late)
            return "gantt-bar-late";
        if (task.DeliveryRisk == DomainConstants.DeliveryRisk.AtRisk)
            return "gantt-bar-atrisk";

        // Otherwise color by status
        return task.Status switch
        {
            var s when s == DomainConstants.TaskStatus.Completed => "gantt-bar-completed",
            var s when s == DomainConstants.TaskStatus.InProgress => "gantt-bar-inprogress",
            _ => "gantt-bar-notstarted"
        };
    }

    private List<MonthMarker> GetMonthMarkers()
    {
        var markers = new List<MonthMarker>();
        if (totalDays <= 0) return markers;

        var current = new DateTime(planStart.Year, planStart.Month, 1);
        while (current <= planEnd)
        {
            var monthEnd = current.AddMonths(1).AddDays(-1);
            if (monthEnd > planEnd) monthEnd = planEnd;

            var start = current < planStart ? planStart : current;
            var leftPct = GetDatePercent(start);
            var rightPct = GetDatePercent(monthEnd);

            markers.Add(new MonthMarker
            {
                Label = current.ToString("MMM yyyy"),
                LeftPct = Math.Round(leftPct, 2),
                WidthPct = Math.Round(Math.Max(rightPct - leftPct, 1), 2)
            });

            current = current.AddMonths(1);
        }

        return markers;
    }

    private static string Truncate(string text, int maxLength)
        => text.Length <= maxLength ? text : text[..(maxLength - 1)] + "…";

    private void NavigateToTask(string taskId)
    {
        NavigationManager.NavigateTo($"/tasks/{taskId}");
    }

    private void OnGanttKeyDown(KeyboardEventArgs e, string taskId)
    {
        if (e.Key is "Enter" or " ")
            NavigateToTask(taskId);
    }

    private void ToggleCriticalPath()
    {
        showCriticalPath = !showCriticalPath;
        if (showCriticalPath)
            ComputeCriticalPath();
    }

    private void ComputeCriticalPath()
    {
        criticalPathTaskIds.Clear();
        if (!scheduledTasks.Any()) return;

        var taskMap = scheduledTasks.ToDictionary(t => t.TaskId);
        var memo = new Dictionary<string, (int length, List<string> path)>();

        (int length, List<string> path) GetLongestPath(string taskId)
        {
            if (memo.TryGetValue(taskId, out var cached)) return cached;

            var task = taskMap.GetValueOrDefault(taskId);
            if (task == null) return (0, new List<string>());

            var deps = string.IsNullOrWhiteSpace(task.DependsOnTaskIds)
                ? Array.Empty<string>()
                : task.DependsOnTaskIds.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            int maxLen = 0;
            var bestPath = new List<string>();

            foreach (var dep in deps)
            {
                var (len, path) = GetLongestPath(dep);
                if (len > maxLen)
                {
                    maxLen = len;
                    bestPath = new List<string>(path);
                }
            }

            bestPath.Add(taskId);
            var taskDuration = (task.Duration ?? 0) > 0 ? task.Duration!.Value : (int)task.DevEstimation;
            var result = (maxLen + taskDuration, bestPath);
            memo[taskId] = result;
            return result;
        }

        var longestPath = scheduledTasks
            .Select(t => GetLongestPath(t.TaskId))
            .OrderByDescending(r => r.length)
            .FirstOrDefault();

        criticalPathTaskIds = new HashSet<string>(longestPath.path);
    }

    private bool IsCriticalTask(TaskItem task)
    {
        return showCriticalPath && criticalPathTaskIds.Contains(task.TaskId);
    }

    private record MonthMarker
    {
        public string Label { get; init; } = "";
        public double LeftPct { get; init; }
        public double WidthPct { get; init; }
    }
}
