@page "/forecast"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Planning.Queries
@using SoftwareDeliveryPlanner.Application.Abstractions
@using SoftwareDeliveryPlanner.Application.Settings.Queries
@using SoftwareDeliveryPlanner.Domain
@using SoftwareDeliveryPlanner.Domain.Services
@inject IMediator Mediator

<PageTitle>Utilization Forecast</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 page-header">
    <div>
        <h3 class="mb-1"><i class="bi bi-bar-chart-line me-2"></i>Utilization Forecast</h3>
        <p class="page-subtitle">Projected resource utilization over the next 26 weeks</p>
    </div>
    <div>
        <button class="btn btn-outline-secondary" @onclick="LoadData" disabled="@isLoading" data-testid="forecast-refresh">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-clockwise"></i>
            }
            Refresh
        </button>
    </div>
</div>

@if (isLoading)
{
    <SkeletonLoader Variant="table" Rows="10" Columns="5" TestId="forecast-skeleton" />
}
else if (forecast is null || !forecast.Weeks.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5" data-testid="forecast-empty">
            <i class="bi bi-bar-chart text-muted" style="font-size:3rem;"></i>
            <h5 class="mt-3">No forecast data available</h5>
            <p class="text-muted">Run the scheduler to generate utilization data.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0" data-testid="forecast-table">
                <thead class="table-light">
                    <tr>
                        <th>Week</th>
                        <th>Capacity (h)</th>
                        <th>Allocated (h)</th>
                        <th>Utilization %</th>
                        <th>Free (h)</th>
                        <th>Overallocated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var week in forecast.Weeks)
                    {
                        var utilClass = week.UtilizationPct >= 90 ? "text-danger fw-semibold"
                                      : week.UtilizationPct >= 70 ? "text-warning"
                                      : "text-success";
                        var wn = WeekNumberCalculator.GetWeekOfYear(week.WeekStart, weekNumberingCode, workingWeekCode);
                        var weekEnd = week.WeekStart.AddDays(6);
                        <tr data-testid="forecast-row-@week.WeekStart.ToString("yyyy-MM-dd")">
                            <td>
                                <div class="fw-semibold">W@wn</div>
                                <div class="text-muted small">@week.WeekStart.ToString("dd MMM") - @weekEnd.ToString("dd MMM")</div>
                            </td>
                            <td>@week.TotalCapacityHours.ToString("F1")</td>
                            <td>@week.AllocatedHours.ToString("F1")</td>
                            <td>
                                <span class="@utilClass">@week.UtilizationPct.ToString("F1")%</span>
                                <div class="progress mt-1" style="height:4px;">
                                    <div class="progress-bar @(week.UtilizationPct >= 90 ? "bg-danger" : week.UtilizationPct >= 70 ? "bg-warning" : "bg-success")"
                                         style="width:@(Math.Min(week.UtilizationPct, 100).ToString("F0"))%"></div>
                                </div>
                            </td>
                            <td>@week.FreeHours.ToString("F1")</td>
                            <td>
                                @if (week.OverallocatedResources > 0)
                                {
                                    <span class="badge bg-danger">@week.OverallocatedResources</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private UtilizationForecastDto? forecast;
    private bool isLoading = true;
    private string workingWeekCode = DomainConstants.WorkingWeek.SunThu;
    private string weekNumberingCode = DomainConstants.WeekNumbering.Default;

    protected override async Task OnInitializedAsync()
    {
        var settingsResult = await Mediator.Send(new GetSettingsQuery());
        if (settingsResult.IsSuccess)
        {
            if (!string.IsNullOrEmpty(settingsResult.Value.GlobalWorkingWeek))
                workingWeekCode = settingsResult.Value.GlobalWorkingWeek;
            if (!string.IsNullOrEmpty(settingsResult.Value.WeekNumbering))
                weekNumberingCode = settingsResult.Value.WeekNumbering;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var result = await Mediator.Send(new GetUtilizationForecastQuery(26));
            forecast = result.IsSuccess ? result.Value : null;
        }
        finally
        {
            isLoading = false;
        }
    }
}
