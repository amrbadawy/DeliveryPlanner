@page "/tasks/{TaskId}"
@using MediatR
@using SoftwareDeliveryPlanner.Application.Tasks.Queries
@using SoftwareDeliveryPlanner.Application.Tasks.Commands
@using SoftwareDeliveryPlanner.Application.Abstractions
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Domain
@using SoftwareDeliveryPlanner.Application.TaskNotes.Commands
@using SoftwareDeliveryPlanner.Application.TaskNotes.Queries
@using SoftwareDeliveryPlanner.Application.Resources.Queries
@using FluentValidation
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject SoftwareDeliveryPlanner.Web.Services.AutoScheduleService autoSchedule

<PageTitle>Task Details - @TaskId</PageTitle>

@if (isLoading)
{
    <SkeletonLoader Variant="block" TestId="task-details-skeleton" />
}
else if (task == null)
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-file-earmark-x"></i></div>
        <h5>Task not found</h5>
        <p>The task "@TaskId" does not exist or may have been deleted.</p>
        <button class="btn btn-secondary" @onclick="GoBack" data-testid="task-details-back">
            <i class="bi bi-arrow-left me-1"></i> Back to Tasks
        </button>
    </div>
}
else
{
    <div class="page-header mb-4 d-flex justify-content-between align-items-start gap-2">
        <h3 class="mb-1"><i class="bi bi-file-earmark-text me-2"></i>@task.ServiceName</h3>
        <button class="btn btn-outline-warning" @onclick="NavigateToEditTask" data-testid="task-details-edit">
            <i class="bi bi-pencil me-1"></i>Edit
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3" data-testid="task-details-card">
        <div class="card-header bg-transparent">
            <strong>@task.ServiceName</strong>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Service Name</dt>
                <dd class="col-sm-9" data-testid="td-service-name">@task.ServiceName</dd>
                
                <dt class="col-sm-3">Total Estimation (days)</dt>
                <dd class="col-sm-9" data-testid="td-dev-estimation">@task.TotalEstimationDays</dd>

                <dt class="col-sm-3">Priority</dt>
                <dd class="col-sm-9" data-testid="td-priority">
                    @if (BadgeHelpers.ShowPriorityBadge(task.Priority))
                    {
                        <span class="badge @BadgeHelpers.PriorityBadgeClass(task.Priority)">P@task.Priority</span>
                    }
                    else
                    {
                        @task.Priority
                    }
                </dd>

                <dt class="col-sm-3">Strict Date</dt>
                <dd class="col-sm-9" data-testid="td-strict-date">@(task.StrictDate?.ToString("yyyy-MM-dd") ?? "None")</dd>
                
                <dt class="col-sm-3">Dependencies</dt>
                <dd class="col-sm-9" data-testid="td-depends-on">@(string.IsNullOrWhiteSpace(task.DependsOnTaskIds) ? "None" : task.DependsOnTaskIds)</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9" data-testid="td-status">
                    <span class="badge @BadgeHelpers.StatusBg(task.Status)">
                        @task.Status
                    </span>
                </dd>

                <dt class="col-sm-3">Risk</dt>
                <dd class="col-sm-9" data-testid="td-risk">
                    <span class="badge @BadgeHelpers.RiskBadgeClass(task.DeliveryRisk)">
                        @task.DeliveryRisk
                    </span>
                </dd>

                <dt class="col-sm-3">Planned Start</dt>
                <dd class="col-sm-9" data-testid="td-planned-start">@(task.PlannedStart?.ToString("yyyy-MM-dd") ?? "N/A")</dd>

                <dt class="col-sm-3">Planned Finish</dt>
                <dd class="col-sm-9" data-testid="td-planned-finish">@(task.PlannedFinish?.ToString("yyyy-MM-dd") ?? "N/A")</dd>

                <dt class="col-sm-3">Duration (days)</dt>
                <dd class="col-sm-9" data-testid="td-duration">@task.Duration</dd>
            </dl>
        </div>
        <div class="card-footer">
            <button class="btn btn-secondary" @onclick="GoBack" data-testid="task-details-back-bottom"><i class="bi bi-arrow-left me-1"></i> Back to Tasks</button>
        </div>
    </div>

    @if (task != null && (isUnscheduled || uncoveredRoles.Count > 0))
    {
        <div class="alert alert-warning d-flex align-items-start mb-3" data-testid="task-detail-warnings">
            <i class="bi bi-exclamation-triangle-fill me-2 mt-1"></i>
            <div>
                @if (isUnscheduled)
                {
                    <div data-testid="task-detail-unscheduled-warning">
                        <strong>Unscheduled:</strong> This task has no planned dates and will not appear in the delivery plan.
                    </div>
                }
                @if (uncoveredRoles.Count > 0)
                {
                    <div data-testid="task-detail-resource-gap-warning">
                        <strong>Resource gap:</strong> No active resources available for
                        @string.Join(", ", uncoveredRoles.Select(r => $"{r} ({DomainConstants.ResourceRole.GetDisplayName(r)})")).
                    </div>
                }
            </div>
        </div>
    }

    <!-- Effort Breakdown -->
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h4 class="mb-0"><i class="bi bi-bar-chart-steps me-2"></i>Effort Breakdown</h4>
        <button class="btn btn-sm btn-outline-warning" @onclick="OpenEffortModal" data-testid="task-effort-edit">
            <i class="bi bi-pencil-square me-1"></i>Edit Effort Breakdown
        </button>
    </div>
    @if (task!.EffortBreakdown.Any())
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="table-responsive">
                <table class="table table-striped table-sm mb-0" data-testid="td-effort-breakdown">
                    <thead class="table-light">
                        <tr>
                            <th>Role</th>
                            <th>Est. (days)</th>
                            <th>Max FTE</th>
                            <th>Overlap %</th>
                            <th>Min Seniority</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var sortedEntries = task.EffortBreakdown.OrderBy(e => e.SortOrder).ToList();
                            var minSortOrder = sortedEntries.Count > 0 ? sortedEntries[0].SortOrder : 0;
                        }
                        @foreach (var eb in sortedEntries)
                        {
                            var isInlineFirst = eb.SortOrder == minSortOrder;
                            var isRequired = DomainConstants.ResourceRole.RequiredRoles.Contains(eb.Role);

                            if (inlineEditingRole == eb.Role && inlineEditEntry != null)
                            {
                                <!-- Edit row -->
                                <tr data-testid="td-effort-row-@eb.Role" class="table-warning">
                                    <td>
                                        <span class="badge role-badge role-badge-@eb.Role.ToLowerInvariant() me-1">@eb.Role</span>
                                        <small class="text-muted">@DomainConstants.ResourceRole.GetDisplayName(eb.Role)</small>
                                        @if (isRequired)
                                        {
                                            <span class="text-danger ms-1" title="Required role">*</span>
                                        }
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" min="0.5" step="0.5"
                                               @bind="inlineEditEntry.EstimationDays"
                                               disabled="@isSavingInline"
                                               data-testid="effort-inline-days-@eb.Role" />
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" min="0.1" step="0.5"
                                               @bind="inlineEditEntry.MaxFte"
                                               disabled="@isSavingInline"
                                               data-testid="effort-inline-maxfte-@eb.Role" />
                                    </td>
                                    <td>
                                        @if (isInlineFirst)
                                        {
                                            <span class="text-muted">&mdash;</span>
                                        }
                                        else
                                        {
                                            <input type="number" class="form-control form-control-sm" min="0" max="100" step="5"
                                                   @bind="inlineEditEntry.OverlapPct"
                                                   disabled="@isSavingInline"
                                                   data-testid="effort-inline-overlap-@eb.Role" />
                                        }
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                @bind="inlineEditEntry.MinSeniority"
                                                disabled="@isSavingInline"
                                                data-testid="effort-inline-seniority-@eb.Role">
                                            <option value="">Any</option>
                                            <option value="@DomainConstants.Seniority.Junior">Junior</option>
                                            <option value="@DomainConstants.Seniority.Mid">Mid</option>
                                            <option value="@DomainConstants.Seniority.Senior">Senior</option>
                                            <option value="@DomainConstants.Seniority.Principal">Principal</option>
                                        </select>
                                    </td>
                                    <td class="text-nowrap">
                                        <button class="btn btn-sm btn-primary me-1"
                                                @onclick="SaveInlineEdit"
                                                disabled="@isSavingInline"
                                                title="Save"
                                                data-testid="effort-inline-save-@eb.Role">
                                            @if (isSavingInline)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-check-lg"></i>
                                            }
                                        </button>
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="CancelInlineEdit"
                                                disabled="@isSavingInline"
                                                title="Cancel"
                                                data-testid="effort-inline-cancel-@eb.Role">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </td>
                                </tr>
                                @if (!string.IsNullOrWhiteSpace(inlineEditError))
                                {
                                    <tr>
                                        <td colspan="6" class="p-1 border-0">
                                            <div class="alert alert-danger py-1 px-2 mb-0 small"
                                                 data-testid="effort-inline-error-@eb.Role">@inlineEditError</div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <!-- Read-only row -->
                                <tr data-testid="td-effort-row-@eb.Role">
                                    <td><span class="badge role-badge role-badge-@eb.Role.ToLowerInvariant() me-1">@eb.Role</span><small class="text-muted">@DomainConstants.ResourceRole.GetDisplayName(eb.Role)</small></td>
                                    <td>@eb.EstimationDays</td>
                                    <td>@eb.MaxFte</td>
                                    <td>@eb.OverlapPct%</td>
                                    <td>@(eb.MinSeniority ?? "Any")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => OpenInlineEdit(eb.Role)"
                                                title="Edit this row"
                                                data-testid="effort-inline-edit-@eb.Role">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-3">
            <i class="bi bi-bar-chart-steps display-6 text-muted"></i>
            <p class="text-muted mt-2">No effort breakdown defined.</p>
        </div>
    }

    <!-- Assigned Resources -->
    <h4 class="mt-4 mb-3"><i class="bi bi-people me-2"></i>Assigned Resources</h4>
    @if (isAllocationsLoading)
    {
        <div class="text-center py-3">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
                <span class="visually-hidden">Loading resources...</span>
            </div>
        </div>
    }
    else if (!allocations.Any())
    {
        <div class="text-center py-3">
            <i class="bi bi-people display-6 text-muted"></i>
            <p class="text-muted mt-2">No resources allocated. Run the scheduler to assign developers.</p>
        </div>
    }
    else
    {
        <div class="row g-3 mb-3" data-testid="task-allocations">
            @foreach (var alloc in allocations)
            {
                <div class="col-md-4" data-testid="task-allocation-@alloc.ResourceId">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-person-circle fs-4 text-primary"></i>
                                <div>
                                    <a href="/resources/@alloc.ResourceId" class="fw-bold text-decoration-none" data-testid="alloc-link-@alloc.ResourceId">@alloc.ResourceName</a>
                                    <div class="small text-muted"><span class="badge role-badge role-badge-@alloc.Role.ToLowerInvariant() me-1">@alloc.Role</span><span class="badge bg-secondary bg-opacity-25 text-secondary">@alloc.Team</span></div>
                                </div>
                            </div>
                            <div class="small">
                                <span class="text-muted">Availability:</span> @alloc.AvailabilityPct.ToString("F0")%
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <h4 class="mt-4 mb-3"><i class="bi bi-calendar-range me-2"></i>Assignment Timeline</h4>
    @if (isTimelineLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
                <span class="visually-hidden">Loading timeline...</span>
            </div>
            <p class="text-muted mt-2 small">Loading timeline...</p>
        </div>
    }
    else if (timeline == null || !timeline.Days.Any())
    {
        <div class="text-center py-4">
            <i class="bi bi-calendar-x display-6 text-muted"></i>
            <p class="text-muted mt-2">No timeline data available for this task. It may not be scheduled yet.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-bordered table-sm mb-0" data-testid="task-timeline-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 15%">Date</th>
                            <th style="width: 20%">Status</th>
                            <th style="width: 65%">Assigned Resources</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var day in timeline.Days)
                        {
                            <tr class="@(day.IsWorkingDay ? "" : "table-secondary")">
                                <td>@day.DateDisplay</td>
                                <td>@day.StatusText</td>
                                <td>
                                    @if (day.AssignedResources.Any())
                                    {
                                        @foreach (var res in day.AssignedResources)
                                        {
                                            <a href="/resources/@res.ResourceId"
                                               class="badge role-badge role-badge-@res.Role.ToLowerInvariant() me-1 text-decoration-none"
                                                data-testid="timeline-res-@res.ResourceId">@res.ResourceName · @res.AllocationPct.ToString("F0")%</a>
                                        }
                                    }
                                    else if (day.IsWorkingDay)
                                    {
                                        <span class="text-muted">None</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Notes Section -->
    <h4 class="mt-4 mb-3"><i class="bi bi-sticky me-2"></i>Notes</h4>
    @if (isNotesLoading)
    {
        <div class="text-center py-3">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
                <span class="visually-hidden">Loading notes...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-3" data-testid="task-notes-section">
            <div class="card-body">
                <div class="input-group mb-3">
                    <input class="form-control" placeholder="Add a note..." @bind="newNoteText" @onkeydown="HandleNoteKeyDown" data-testid="task-note-input" />
                    <button class="btn btn-primary" @onclick="AddNote" disabled="@isAddingNote" data-testid="task-note-add">
                        @if (isAddingNote)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {
                            <i class="bi bi-plus-lg"></i>
                        }
                        Add
                    </button>
                </div>
                @if (!notes.Any())
                {
                    <p class="text-muted text-center mb-0">No notes yet.</p>
                }
                else
                {
                    @foreach (var note in notes.OrderByDescending(n => n.CreatedAt))
                    {
                        <div class="d-flex justify-content-between align-items-start border-bottom py-2" data-testid="task-note-@note.Id">
                            <div>
                                <div>@note.NoteText</div>
                                <small class="text-muted">@note.Author · @note.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                            </div>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteNote(note.Id)" data-testid="task-note-delete-@note.Id">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
    }
}

@if (showEffortModal)
{
    <div class="modal d-block modal-backdrop-custom" role="dialog" aria-modal="true" aria-labelledby="task-effort-modal-title" data-testid="task-effort-modal">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="task-effort-modal-title">Edit Effort Breakdown</h5>
                    <button type="button" class="btn-close" @onclick="CloseEffortModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(effortModalError))
                    {
                        <div class="alert alert-danger" data-testid="task-effort-error">@effortModalError</div>
                    }

                    <table class="table table-sm table-bordered mb-2">
                        <thead class="table-light">
                            <tr>
                                <th>Role</th>
                                <th style="width:120px">Days</th>
                                <th style="width:100px">Max FTE</th>
                                <th style="width:120px">Overlap %</th>
                                <th style="width:130px">Min Seniority</th>
                                <th style="width:50px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in effortEntries)
                            {
                                var isRequired = DomainConstants.ResourceRole.RequiredRoles.Contains(entry.Role);
                                var isFirst = effortEntries.IndexOf(entry) == 0;
                                <tr data-testid="effort-edit-row-@entry.Role">
                                    <td>
                                        <span class="badge role-badge role-badge-@entry.Role.ToLowerInvariant() me-1">@entry.Role</span>
                                        <small class="text-muted">@DomainConstants.ResourceRole.GetDisplayName(entry.Role)</small>
                                        @if (isRequired)
                                        {
                                            <span class="text-danger ms-1">*</span>
                                        }
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" min="0.5" step="0.5"
                                               @bind="entry.EstimationDays" data-testid="effort-edit-days-@entry.Role" />
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" min="0.1" step="0.5"
                                               @bind="entry.MaxFte" data-testid="effort-edit-maxfte-@entry.Role" />
                                    </td>
                                    <td>
                                        @if (isFirst)
                                        {
                                            <span class="text-muted">&mdash;</span>
                                        }
                                        else
                                        {
                                            <input type="number" class="form-control form-control-sm" min="0" max="100" step="5"
                                                   @bind="entry.OverlapPct" data-testid="effort-edit-overlap-@entry.Role" />
                                        }
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm" @bind="entry.MinSeniority" data-testid="effort-edit-seniority-@entry.Role">
                                            <option value="">Any</option>
                                            <option value="@DomainConstants.Seniority.Junior">Junior</option>
                                            <option value="@DomainConstants.Seniority.Mid">Mid</option>
                                            <option value="@DomainConstants.Seniority.Senior">Senior</option>
                                            <option value="@DomainConstants.Seniority.Principal">Principal</option>
                                        </select>
                                    </td>
                                    <td>
                                        @if (!isRequired)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveEffortEntry(entry)"
                                                    data-testid="effort-edit-remove-@entry.Role"><i class="bi bi-x"></i></button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @{ var availableRoles = DomainConstants.ResourceRole.PipelineOrder.Where(r => !effortEntries.Any(e => e.Role == r)).ToList(); }
                    @if (availableRoles.Any())
                    {
                        <div class="d-flex gap-2 align-items-center">
                            <select class="form-select form-select-sm" style="width:auto" @bind="selectedRoleToAdd" data-testid="effort-edit-add-role-select">
                                <option value="">Add role...</option>
                                @foreach (var role in availableRoles)
                                {
                                    <option value="@role">@role &mdash; @DomainConstants.ResourceRole.GetDisplayName(role)</option>
                                }
                            </select>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddEffortEntry"
                                    disabled="@string.IsNullOrEmpty(selectedRoleToAdd)" data-testid="effort-edit-add-btn">
                                <i class="bi bi-plus me-1"></i>Add
                            </button>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveEffortBreakdown" disabled="@isSavingEffort" data-testid="task-effort-save">
                        @if (isSavingEffort)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Save
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseEffortModal" data-testid="task-effort-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

<ToastNotification @ref="toast" TestId="task-details-toast" />

@code {
    private ToastNotification toast = null!;
    [Parameter]
    public string TaskId { get; set; } = string.Empty;

    private TaskItem? task;
    private TaskTimelineDto? timeline;
    private bool isLoading = true;
    private bool isTimelineLoading = true;
    private List<TaskNote> notes = new();
    private string newNoteText = string.Empty;
    private bool isAddingNote = false;
    private bool isNotesLoading = true;
    private List<TaskAllocationDto> allocations = new();
    private bool isAllocationsLoading = true;

    // Plan readiness warnings
    private List<TeamMember> allResources = new();
    private bool isUnscheduled;
    private List<string> uncoveredRoles = new();
    private bool showEffortModal = false;
    private bool isSavingEffort = false;
    private string effortModalError = string.Empty;
    private string selectedRoleToAdd = string.Empty;
    private List<EffortEntryModel> effortEntries = new();

    // ── Inline per-row editing ────────────────────────────────────────────────
    private string? inlineEditingRole = null;
    private EffortEntryModel? inlineEditEntry = null;
    private string inlineEditError = string.Empty;
    private bool isSavingInline = false;

    private sealed class EffortEntryModel
    {
        public string Role { get; set; } = string.Empty;
        public double EstimationDays { get; set; }
        public double MaxFte { get; set; } = 1.0;
        public double OverlapPct { get; set; }
        public string? MinSeniority { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTaskData();
        await LoadResourcesAndComputeWarnings();
        await LoadTimelineData();
        await LoadNotesData();
        await LoadAllocationsData();
    }

    private async Task LoadTaskData()
    {
        var result = await Mediator.Send(new GetTaskByIdQuery(TaskId));
        if (result.IsSuccess)
            task = result.Value;
        isLoading = false;
    }

    private async Task LoadResourcesAndComputeWarnings()
    {
        if (task == null) return;

        var resResult = await Mediator.Send(new GetResourcesQuery());
        if (resResult.IsSuccess)
            allResources = resResult.Value;

        isUnscheduled = !task.PlannedStart.HasValue || !task.PlannedFinish.HasValue;

        // Skip gap computation if resource load failed — avoid false positives
        if (!resResult.IsSuccess)
        {
            uncoveredRoles = new();
            return;
        }

        var activeByRole = allResources
            .Where(r => r.Active == DomainConstants.ActiveStatus.Yes)
            .GroupBy(r => r.Role, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);

        uncoveredRoles = task.EffortBreakdown
            .Where(eb =>
            {
                if (!activeByRole.TryGetValue(eb.Role, out var candidates) || candidates.Count == 0)
                    return true;

                if (!string.IsNullOrEmpty(eb.MinSeniority)
                    && DomainConstants.Seniority.Rank.TryGetValue(eb.MinSeniority, out var requiredRank))
                {
                    return !candidates.Any(r =>
                        DomainConstants.Seniority.Rank.TryGetValue(r.SeniorityLevel, out var rRank) && rRank >= requiredRank);
                }

                return false;
            })
            .Select(eb => eb.Role)
            .ToList();
    }

    private async Task LoadTimelineData()
    {
        var timelineResult = await Mediator.Send(new GetTaskTimelineQuery(TaskId));
        if (timelineResult.IsSuccess)
            timeline = timelineResult.Value;
        isTimelineLoading = false;
    }

    private async Task LoadNotesData()
    {
        if (task != null)
        {
            var notesResult = await Mediator.Send(new GetTaskNotesQuery(TaskId));
            if (notesResult.IsSuccess)
                notes = notesResult.Value;
        }
        isNotesLoading = false;
    }

    private async Task LoadAllocationsData()
    {
        var allocResult = await Mediator.Send(new GetTaskAllocationsQuery(TaskId));
        if (allocResult.IsSuccess)
            allocations = allocResult.Value;
        isAllocationsLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/tasks");
    }

    private void NavigateToEditTask()
    {
        NavigationManager.NavigateTo($"/tasks?editTaskId={Uri.EscapeDataString(TaskId)}");
    }

    private void OpenEffortModal()
    {
        if (task == null)
            return;

        // Cancel any active inline row edit before opening the modal
        CancelInlineEdit();

        effortModalError = string.Empty;
        selectedRoleToAdd = string.Empty;
        effortEntries = task.EffortBreakdown
            .OrderBy(e => e.SortOrder)
            .Select(e => new EffortEntryModel
            {
                Role = e.Role,
                EstimationDays = e.EstimationDays,
                MaxFte = e.MaxFte,
                OverlapPct = e.OverlapPct,
                MinSeniority = e.MinSeniority
            })
            .ToList();

        showEffortModal = true;
    }

    private void CloseEffortModal()
    {
        showEffortModal = false;
        effortModalError = string.Empty;
        selectedRoleToAdd = string.Empty;
    }

    // ── Inline per-row edit ───────────────────────────────────────────────────

    private void OpenInlineEdit(string role)
    {
        if (task == null) return;

        // Discard any existing inline edit without saving
        CancelInlineEdit();

        // Close the modal if it happens to be open
        if (showEffortModal) CloseEffortModal();

        var entry = task.EffortBreakdown
            .FirstOrDefault(e => string.Equals(e.Role, role, StringComparison.OrdinalIgnoreCase));
        if (entry == null) return;

        inlineEditEntry = new EffortEntryModel
        {
            Role = entry.Role,
            EstimationDays = entry.EstimationDays,
            MaxFte = entry.MaxFte,
            OverlapPct = entry.OverlapPct,
            MinSeniority = entry.MinSeniority
        };
        inlineEditingRole = role;
    }

    private void CancelInlineEdit()
    {
        inlineEditingRole = null;
        inlineEditEntry = null;
        inlineEditError = string.Empty;
    }

    private async Task SaveInlineEdit()
    {
        if (task == null || inlineEditEntry == null || inlineEditingRole == null) return;

        // ── Client-side validation ────────────────────────────────────────────
        if (inlineEditEntry.EstimationDays <= 0)
        {
            inlineEditError = "Estimation days must be greater than zero.";
            return;
        }
        if (inlineEditEntry.MaxFte <= 0)
        {
            inlineEditError = "Max FTE must be greater than zero.";
            return;
        }
        var isFirst = task.EffortBreakdown
            .OrderBy(e => e.SortOrder)
            .First().Role
            .Equals(inlineEditingRole, StringComparison.OrdinalIgnoreCase);
        if (!isFirst && (inlineEditEntry.OverlapPct < 0 || inlineEditEntry.OverlapPct > 100))
        {
            inlineEditError = "Overlap percentage must be between 0 and 100.";
            return;
        }

        isSavingInline = true;
        inlineEditError = string.Empty;

        try
        {
            // Build the full breakdown list, replacing only the edited entry
            var breakdown = task.EffortBreakdown
                .OrderBy(e => e.SortOrder)
                .Select(e => string.Equals(e.Role, inlineEditingRole, StringComparison.OrdinalIgnoreCase)
                    ? new EffortBreakdownInput(
                        inlineEditEntry.Role,
                        inlineEditEntry.EstimationDays,
                        inlineEditEntry.OverlapPct,
                        inlineEditEntry.MaxFte,
                        string.IsNullOrWhiteSpace(inlineEditEntry.MinSeniority) ? null : inlineEditEntry.MinSeniority)
                    : new EffortBreakdownInput(
                        e.Role,
                        e.EstimationDays,
                        e.OverlapPct,
                        e.MaxFte,
                        e.MinSeniority))
                .ToList();

            var command = new UpdateTaskEffortBreakdownCommand(TaskId, breakdown, autoSchedule.IsEnabled);
            await Mediator.Send(command);

            await LoadTaskData();
            await LoadResourcesAndComputeWarnings();
            isTimelineLoading = true;
            await LoadTimelineData();
            isAllocationsLoading = true;
            await LoadAllocationsData();

            CancelInlineEdit();
            toast.Show("Effort breakdown updated.");
        }
        catch (ValidationException ex)
        {
            inlineEditError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            inlineEditError = ex.Message;
        }
        finally
        {
            isSavingInline = false;
        }
    }

    private void AddEffortEntry()
    {
        if (!string.IsNullOrEmpty(selectedRoleToAdd) && !effortEntries.Any(e => e.Role == selectedRoleToAdd))
        {
            effortEntries.Add(new EffortEntryModel { Role = selectedRoleToAdd, EstimationDays = 1, OverlapPct = 0, MaxFte = 1.0 });
            effortEntries = effortEntries.OrderBy(e => DomainConstants.ResourceRole.GetPipelineSortOrder(e.Role)).ToList();
            selectedRoleToAdd = string.Empty;
        }
    }

    private void RemoveEffortEntry(EffortEntryModel entry)
    {
        if (!DomainConstants.ResourceRole.RequiredRoles.Contains(entry.Role))
            effortEntries.Remove(entry);
    }

    private async Task SaveEffortBreakdown()
    {
        if (task == null)
            return;

        isSavingEffort = true;
        effortModalError = string.Empty;

        try
        {
            var command = new UpdateTaskEffortBreakdownCommand(
                TaskId,
                effortEntries.Select(e => new EffortBreakdownInput(
                    e.Role,
                    e.EstimationDays,
                    e.OverlapPct,
                    e.MaxFte,
                    string.IsNullOrWhiteSpace(e.MinSeniority) ? null : e.MinSeniority)).ToList(),
                autoSchedule.IsEnabled);

            await Mediator.Send(command);

            await LoadTaskData();
            await LoadResourcesAndComputeWarnings();
            isTimelineLoading = true;
            await LoadTimelineData();
            isAllocationsLoading = true;
            await LoadAllocationsData();

            CloseEffortModal();
            toast.Show("Effort breakdown updated successfully.");
        }
        catch (ValidationException ex)
        {
            effortModalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            effortModalError = ex.Message;
        }
        finally
        {
            isSavingEffort = false;
        }
    }

    private async Task HandleNoteKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await AddNote();
    }

    private async Task AddNote()
    {
        if (string.IsNullOrWhiteSpace(newNoteText)) return;
        isAddingNote = true;
        try
        {
            await Mediator.Send(new AddTaskNoteCommand(TaskId, newNoteText, "User"));
            var notesResult = await Mediator.Send(new GetTaskNotesQuery(TaskId));
            if (notesResult.IsSuccess)
                notes = notesResult.Value;
            newNoteText = string.Empty;
            toast.Show("Note added successfully.");
        }
        catch (ValidationException ex)
        {
            toast.Show(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), "danger");
        }
        finally
        {
            isAddingNote = false;
        }
    }

    private async Task DeleteNote(int noteId)
    {
        try
        {
            await Mediator.Send(new DeleteTaskNoteCommand(noteId));
            var notesResult = await Mediator.Send(new GetTaskNotesQuery(TaskId));
            if (notesResult.IsSuccess)
                notes = notesResult.Value;
            toast.Show("Note deleted.");
        }
        catch (Exception ex)
        {
            toast.Show(ex.Message, "danger");
        }
    }
}
