@using System.Text.Json
@using SoftwareDeliveryPlanner.Domain
@using SoftwareDeliveryPlanner.Domain.Models
@using SoftwareDeliveryPlanner.Application.SavedViews.Commands
@using SoftwareDeliveryPlanner.Application.SavedViews.Queries
@using SoftwareDeliveryPlanner.Web.Services
@using MediatR
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject TaskFilterState Filter
@inject IMediator Mediator
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

@*
  Persistent left filter sidebar with multi-select chips.
  - Search input composes with chip dimensions.
  - Chips are OR-within-dimension and AND-across-dimensions.
  - URL query is kept in sync by TaskFilterState.
  - Sidebar is collapsible; collapsed state is local UI only.
*@

<aside class="task-filter-sidebar @(isCollapsed ? "collapsed" : "")" data-testid="task-filter-sidebar" aria-label="Filter tasks">
    <div class="task-filter-sidebar-header">
        <button type="button" class="task-filter-toggle"
                @onclick="ToggleCollapsedAsync"
                aria-expanded="@((!isCollapsed).ToString().ToLowerInvariant())"
                title="@(isCollapsed ? "Expand filters" : "Collapse filters")"
                data-testid="task-filter-toggle">
            <i class="bi @(isCollapsed ? "bi-funnel" : "bi-funnel-fill")"></i>
            @if (!isCollapsed)
            {
                <span class="task-filter-title">Filters</span>
            }
            @if (Filter.ActiveCount > 0)
            {
                <span class="task-filter-badge" data-testid="task-filter-active-count">@Filter.ActiveCount</span>
            }
        </button>
        @if (!isCollapsed && Filter.IsAnyActive)
        {
            <button type="button" class="task-filter-clear-all"
                    @onclick="ClearAll"
                    title="Clear all filters"
                    data-testid="task-filter-clear-all">
                <i class="bi bi-x-lg"></i> Clear
            </button>
        }
    </div>

    @if (!isCollapsed)
    {
        <div class="task-filter-sidebar-body">
            <!-- Search -->
            <section class="task-filter-section">
                <label for="task-filter-search" class="task-filter-section-label">Search</label>
                <input id="task-filter-search"
                       class="form-control form-control-sm"
                       type="search"
                       placeholder="ID, name, or phase..."
                       value="@Filter.SearchTerm"
                       @oninput="OnSearchInput"
                       data-testid="task-filter-search" />
            </section>

            <!-- Status -->
            <section class="task-filter-section">
                <div class="task-filter-section-label">Status</div>
                <div class="task-filter-chip-group" role="group" aria-label="Filter by status">
                    @foreach (var (code, display) in StatusChips)
                    {
                        var active = Filter.SelectedStatuses.Contains(code);
                        <button type="button"
                                class="task-filter-chip @(active ? "active" : "")"
                                aria-pressed="@active.ToString().ToLowerInvariant()"
                                @onclick="() => Filter.ToggleStatus(code)"
                                data-testid="@($"task-filter-chip-status-{code.ToLowerInvariant()}")">
                            @display
                        </button>
                    }
                </div>
            </section>

            <!-- Risk -->
            <section class="task-filter-section">
                <div class="task-filter-section-label">Delivery risk</div>
                <div class="task-filter-chip-group" role="group" aria-label="Filter by risk">
                    @foreach (var (code, display, swatch) in RiskChips)
                    {
                        var active = Filter.SelectedRisks.Contains(code);
                        <button type="button"
                                class="task-filter-chip task-filter-chip-risk task-filter-chip-risk-@swatch @(active ? "active" : "")"
                                aria-pressed="@active.ToString().ToLowerInvariant()"
                                @onclick="() => Filter.ToggleRisk(code)"
                                data-testid="@($"task-filter-chip-risk-{code.ToLowerInvariant()}")">
                            @display
                        </button>
                    }
                </div>
            </section>

            <!-- Priority -->
            <section class="task-filter-section">
                <div class="task-filter-section-label">Priority</div>
                <div class="task-filter-chip-group" role="group" aria-label="Filter by priority">
                    @foreach (var (code, display) in PriorityChips)
                    {
                        var active = Filter.SelectedPriorityBuckets.Contains(code);
                        <button type="button"
                                class="task-filter-chip @(active ? "active" : "")"
                                aria-pressed="@active.ToString().ToLowerInvariant()"
                                @onclick="() => Filter.TogglePriorityBucket(code)"
                                data-testid="@($"task-filter-chip-priority-{code.ToLowerInvariant()}")">
                            @display
                        </button>
                    }
                </div>
            </section>

            <!-- Role (effort breakdown) -->
            <section class="task-filter-section">
                <div class="task-filter-section-label">Role</div>
                <div class="task-filter-chip-group" role="group" aria-label="Filter by role">
                    @foreach (var role in DomainConstants.ResourceRole.PipelineOrder)
                    {
                        var active = Filter.SelectedRoles.Contains(role);
                        <button type="button"
                                class="task-filter-chip task-filter-chip-role @(active ? "active" : "")"
                                aria-pressed="@active.ToString().ToLowerInvariant()"
                                @onclick="() => Filter.ToggleRole(role)"
                                data-testid="@($"task-filter-chip-role-{role.ToLowerInvariant()}")">
                            <span class="task-filter-chip-swatch gantt-role-@role.ToLowerInvariant()"></span>
                            @DomainConstants.ResourceRole.GetDisplayName(role)
                        </button>
                    }
                </div>
            </section>

            <!-- Phase -->
            @if (AvailablePhases is { Count: > 0 })
            {
                <section class="task-filter-section">
                    <div class="task-filter-section-label">Phase</div>
                    <div class="task-filter-chip-group" role="group" aria-label="Filter by phase">
                        @foreach (var phase in AvailablePhases)
                        {
                            var active = Filter.SelectedPhases.Contains(phase);
                            <button type="button"
                                    class="task-filter-chip @(active ? "active" : "")"
                                    aria-pressed="@active.ToString().ToLowerInvariant()"
                                    @onclick="() => Filter.TogglePhase(phase)"
                                    data-testid="@($"task-filter-chip-phase-{SanitizeId(phase)}")">
                                @(string.IsNullOrEmpty(phase) ? "(no phase)" : phase)
                            </button>
                        }
                    </div>
                </section>
            }

            <!-- Dependency state -->
            <section class="task-filter-section">
                <div class="task-filter-section-label">Dependencies</div>
                <div class="task-filter-chip-group" role="group" aria-label="Filter by dependency state">
                    @foreach (var (code, display) in DepStateChips)
                    {
                        var active = Filter.SelectedDependencyStates.Contains(code);
                        <button type="button"
                                class="task-filter-chip @(active ? "active" : "")"
                                aria-pressed="@active.ToString().ToLowerInvariant()"
                                @onclick="() => Filter.ToggleDependencyState(code)"
                                data-testid="@($"task-filter-chip-dep-{code.ToLowerInvariant()}")">
                            @display
                        </button>
                    }
                </div>
            </section>

            <!-- Saved views -->
            <section class="task-filter-section task-filter-saved-views" data-testid="task-filter-saved-views">
                <div class="task-filter-section-label">Saved views</div>
                @if (savedViews.Count == 0)
                {
                    <div class="task-filter-empty" data-testid="task-filter-saved-views-empty">No saved views.</div>
                }
                else
                {
                    <ul class="task-filter-saved-list">
                        @foreach (var view in savedViews)
                        {
                            <li class="task-filter-saved-item" data-testid="@($"task-filter-saved-view-{view.Id}")">
                                @if (editingViewId == view.Id)
                                {
                                    <input type="text"
                                           class="form-control form-control-sm task-filter-saved-rename-input"
                                           maxlength="100"
                                           value="@editingViewName"
                                           @oninput="@(e => editingViewName = e.Value?.ToString() ?? string.Empty)"
                                           @onkeydown="OnRenameKeyDown"
                                           data-testid="@($"task-filter-saved-view-rename-input-{view.Id}")" />
                                }
                                else
                                {
                                    <button type="button"
                                            class="task-filter-saved-apply"
                                            title="Apply this saved view"
                                            @onclick="() => ApplyView(view)"
                                            data-testid="@($"task-filter-saved-view-apply-{view.Id}")">
                                        <i class="bi bi-bookmark-check"></i> @view.Name
                                    </button>
                                }
                                @if (editingViewId == view.Id)
                                {
                                    <button type="button"
                                            class="task-filter-saved-edit"
                                            title="Save renamed view"
                                            @onclick="SaveRenameAsync"
                                            disabled="@(!CanRename)"
                                            data-testid="@($"task-filter-saved-view-rename-save-{view.Id}")">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button type="button"
                                            class="task-filter-saved-edit"
                                            title="Cancel rename"
                                            @onclick="CancelRename"
                                            data-testid="@($"task-filter-saved-view-rename-cancel-{view.Id}")">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="task-filter-saved-edit"
                                            title="Rename this saved view"
                                            @onclick="() => BeginRename(view)"
                                            data-testid="@($"task-filter-saved-view-rename-{view.Id}")">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                }
                                <button type="button"
                                        class="task-filter-saved-default @(view.IsDefault ? "active" : string.Empty)"
                                        title="@(view.IsDefault ? "Unset default view" : "Set as default view")"
                                        @onclick="() => ToggleDefaultAsync(view)"
                                        data-testid="@($"task-filter-saved-view-default-{view.Id}")">
                                    <i class="bi @(view.IsDefault ? "bi-star-fill" : "bi-star")"></i>
                                </button>
                                <button type="button"
                                        class="task-filter-saved-edit"
                                        title="Copy share link for this saved view"
                                        @onclick="() => CopyShareLinkAsync(view)"
                                        data-testid="@($"task-filter-saved-view-copy-{view.Id}")">
                                    <i class="bi bi-link-45deg"></i>
                                </button>
                                <button type="button"
                                        class="task-filter-saved-delete"
                                        title="Delete this saved view"
                                        @onclick="() => RequestDeleteView(view)"
                                        data-testid="@($"task-filter-saved-view-delete-{view.Id}")">
                                    <i class="bi bi-x"></i>
                                </button>
                            </li>
                        }
                    </ul>
                }

                <div class="task-filter-saved-form">
                    <input type="text"
                           class="form-control form-control-sm"
                           placeholder="Save current as..."
                           maxlength="100"
                           value="@newViewName"
                           @oninput="@(e => newViewName = e.Value?.ToString() ?? string.Empty)"
                           @onkeydown="OnSaveKeyDown"
                           disabled="@(!Filter.IsAnyActive)"
                           data-testid="task-filter-saved-view-name" />
                    <button type="button"
                            class="btn btn-sm btn-primary"
                            @onclick="SaveCurrentView"
                            disabled="@(!CanSave)"
                            data-testid="task-filter-saved-view-save">
                        Save
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(saveError))
                {
                    <div class="task-filter-error" data-testid="task-filter-saved-view-error">@saveError</div>
                }
                @if (!string.IsNullOrEmpty(renameError))
                {
                    <div class="task-filter-error" data-testid="task-filter-saved-view-rename-error">@renameError</div>
                }

                <div class="task-filter-saved-io">
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            @onclick="ExportViewsAsync"
                            disabled="@(savedViews.Count == 0)"
                            title="Download all saved views for this page as JSON"
                            data-testid="task-filter-saved-views-export">
                        <i class="bi bi-download"></i> Export
                    </button>
                    <label class="btn btn-sm btn-outline-secondary task-filter-saved-import-label"
                           title="Import saved views from a JSON file"
                           data-testid="task-filter-saved-views-import-label">
                        <i class="bi bi-upload"></i> Import
                        <InputFile OnChange="OnImportFileSelected"
                                   accept=".json,application/json"
                                   data-testid="task-filter-saved-views-import" />
                    </label>
                </div>
                @if (!string.IsNullOrEmpty(ioMessage))
                {
                    <div class="task-filter-info" data-testid="task-filter-saved-views-io-message">@ioMessage</div>
                }
                @if (!string.IsNullOrEmpty(ioError))
                {
                    <div class="task-filter-error" data-testid="task-filter-saved-views-io-error">@ioError</div>
                }
            </section>
        </div>
    }
</aside>

@if (_pendingDeleteView is not null)
{
    <ConfirmDialog Visible="true"
                   TestId="task-filter-saved-view-delete-modal"
                   Title="Delete saved view"
                   Message="@($"Delete '{_pendingDeleteView.Name}'? This cannot be undone.")"
                   IsProcessing="_deleteProcessing"
                   OnConfirm="OnDeleteConfirmedAsync"
                   OnCancel="OnDeleteCancelled" />
}

@code {
    /// <summary>Page key — TaskFilterState.PageKeyTasks or TaskFilterState.PageKeyGantt.</summary>
    [Parameter, EditorRequired] public string PageKey { get; set; } = TaskFilterState.PageKeyTasks;

    /// <summary>Distinct phases discovered in the page's data set.</summary>
    [Parameter] public IReadOnlyList<string>? AvailablePhases { get; set; }

    private bool isCollapsed;
    private List<SavedView> savedViews = new();
    private string newViewName = string.Empty;
    private string? saveError;
    private string? ownerKey;
    private string? ioMessage;
    private string? ioError;
    private int? editingViewId;
    private string editingViewName = string.Empty;
    private string? renameError;
    private DotNetObjectReference<TaskFilterSidebar>? selfRef;
    private bool appliedViewFromUrl;
    private bool appliedDefaultFromSavedView;

    // Confirm-delete state
    private SavedView? _pendingDeleteView;
    private bool _deleteProcessing;

    // Auto-dismiss timer for ioMessage
    private Timer? _ioDismissTimer;

    private string CollapseKey => $"sdp-task-filter-collapsed-{PageKey}";

    /// <summary>Hard cap on a single imported file (1 MiB) — guards against accidentally selecting a huge non-JSON file.</summary>
    private const long MaxImportBytes = 1 * 1024 * 1024;

    private static readonly JsonSerializerOptions ExportSerializerOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    private static readonly JsonSerializerOptions ImportSerializerOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    private bool CanSave =>
        Filter.IsAnyActive
        && !string.IsNullOrWhiteSpace(newViewName)
        && newViewName.Trim().Length <= 100;

    private bool CanRename =>
        editingViewId.HasValue
        && !string.IsNullOrWhiteSpace(editingViewName)
        && editingViewName.Trim().Length <= 100;

    private static readonly (string Code, string Display)[] StatusChips =
    {
        (DomainConstants.TaskStatus.NotStarted, "Not Started"),
        (DomainConstants.TaskStatus.InProgress, "In Progress"),
        (DomainConstants.TaskStatus.Completed, "Completed"),
    };

    private static readonly (string Code, string Display, string Swatch)[] RiskChips =
    {
        (DomainConstants.DeliveryRisk.OnTrack, "On Track", "ontrack"),
        (DomainConstants.DeliveryRisk.AtRisk, "At Risk", "atrisk"),
        (DomainConstants.DeliveryRisk.Late, "Late", "late"),
    };

    private static readonly (string Code, string Display)[] PriorityChips =
    {
        (TaskFilterState.PriorityBuckets.High, "High (1–3)"),
        (TaskFilterState.PriorityBuckets.Medium, "Medium (4–6)"),
        (TaskFilterState.PriorityBuckets.Low, "Low (7–10)"),
    };

    private static readonly (string Code, string Display)[] DepStateChips =
    {
        (TaskFilterState.DependencyStates.HasDependencies, "Has dependencies"),
        (TaskFilterState.DependencyStates.NoDependencies, "Independent"),
    };

    protected override void OnInitialized()
    {
        Filter.Bind(PageKey);
        Filter.OnChange += OnFilterChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        ownerKey = await Filter.GetOwnerKeyAsync();
        await ReloadSavedViewsAsync();

        var appliedFromUrl = TryApplyViewFromUrl();
        if (!appliedFromUrl)
            await TryApplyDefaultViewAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        selfRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("TaskFilterSidebarKeyboard.bind", selfRef);

        // Restore persisted collapsed state. Done here (not OnInitializedAsync)
        // because JS localStorage is not available during server-side prerender.
        var wasCollapsed = await JS.InvokeAsync<bool>("TaskFilterSidebarStorage.getCollapsed", CollapseKey);
        if (wasCollapsed != isCollapsed)
        {
            isCollapsed = wasCollapsed;
            StateHasChanged();
        }
    }

    private async Task ReloadSavedViewsAsync()
    {
        var result = await Mediator.Send(new ListSavedViewsQuery(PageKey, ownerKey));
        savedViews = result.IsSuccess ? result.Value : new List<SavedView>();

        if (!appliedViewFromUrl)
            TryApplyViewFromUrl();
    }

    private async Task SaveCurrentView()
    {
        saveError = null;
        renameError = null;
        SetIoMessage(null);
        ioError = null;
        if (!CanSave) return;

        var payload = Filter.SerializeCurrentAsPayload();
        var cmd = new UpsertSavedViewCommand(newViewName.Trim(), PageKey, payload, ownerKey);
        var result = await Mediator.Send(cmd);
        if (!result.IsSuccess)
        {
            saveError = result.Error.Message;
            return;
        }
        newViewName = string.Empty;
        await ReloadSavedViewsAsync();
    }

    private async Task OnSaveKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveCurrentView();
    }

    private void ApplyView(SavedView view)
    {
        renameError = null;
        Filter.ApplyPayload(view.PayloadJson);
    }

    private void BeginRename(SavedView view)
    {
        renameError = null;
        editingViewId = view.Id;
        editingViewName = view.Name;
    }

    private void CancelRename()
    {
        editingViewId = null;
        editingViewName = string.Empty;
        renameError = null;
    }

    private async Task SaveRenameAsync()
    {
        renameError = null;
        SetIoMessage(null);
        ioError = null;
        if (!CanRename || editingViewId is null)
            return;

        var result = await Mediator.Send(new RenameSavedViewCommand(editingViewId.Value, editingViewName.Trim()));
        if (!result.IsSuccess)
        {
            renameError = result.Error.Message;
            return;
        }

        await ReloadSavedViewsAsync();
        CancelRename();
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveRenameAsync();
        else if (e.Key == "Escape")
            CancelRename();
    }

    private void RequestDeleteView(SavedView view)
    {
        _pendingDeleteView = view;
        _deleteProcessing = false;
    }

    private void OnDeleteCancelled()
    {
        _pendingDeleteView = null;
        _deleteProcessing = false;
    }

    private async Task OnDeleteConfirmedAsync()
    {
        if (_pendingDeleteView is null) return;
        _deleteProcessing = true;
        SetIoMessage(null);
        ioError = null;

        var view = _pendingDeleteView;
        var result = await Mediator.Send(new DeleteSavedViewCommand(view.Id));
        _deleteProcessing = false;
        _pendingDeleteView = null;

        if (result.IsSuccess)
        {
            if (view.IsDefault)
                appliedDefaultFromSavedView = false;
            await ReloadSavedViewsAsync();
        }
    }

    private bool TryApplyViewFromUrl()
    {
        if (appliedViewFromUrl || savedViews.Count == 0)
            return false;

        var uri = new Uri(Navigation.Uri);
        var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var viewParam = q["view"];
        if (string.IsNullOrWhiteSpace(viewParam))
        {
            appliedViewFromUrl = true;
            return false;
        }

        var matchByName = savedViews.FirstOrDefault(v => string.Equals(v.Name, viewParam, StringComparison.OrdinalIgnoreCase));
        if (matchByName is not null)
        {
            ApplyView(matchByName);
            SetIoMessage($"Applied saved view '{matchByName.Name}' from URL.");
            appliedViewFromUrl = true;
            return true;
        }

        if (int.TryParse(viewParam, out var id))
        {
            var matchById = savedViews.FirstOrDefault(v => v.Id == id);
            if (matchById is not null)
            {
                ApplyView(matchById);
                SetIoMessage($"Applied saved view '{matchById.Name}' from URL.");
                appliedViewFromUrl = true;
                return true;
            }
        }

        appliedViewFromUrl = true;
        return false;
    }

    private async Task TryApplyDefaultViewAsync()
    {
        if (appliedDefaultFromSavedView || savedViews.Count == 0)
            return;

        var uri = new Uri(Navigation.Uri);
        var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (!string.IsNullOrWhiteSpace(q["view"]))
            return;

        // Respect explicit URL filters/search and user interactions.
        if (Filter.IsAnyActive)
            return;

        var defaultView = savedViews.FirstOrDefault(v => v.IsDefault);
        if (defaultView is null)
            return;

        ApplyView(defaultView);
        SetIoMessage($"Applied default saved view '{defaultView.Name}'.");
        appliedDefaultFromSavedView = true;
    }

    private async Task ToggleDefaultAsync(SavedView view)
    {
        SetIoMessage(null);
        ioError = null;
        saveError = null;
        renameError = null;

        var result = await Mediator.Send(new SetDefaultSavedViewCommand(view.Id, !view.IsDefault));
        if (!result.IsSuccess)
        {
            ioError = result.Error.Message;
            return;
        }

        appliedDefaultFromSavedView = false;
        await ReloadSavedViewsAsync();

        SetIoMessage(result.Value.IsDefault
            ? $"'{result.Value.Name}' set as default view."
            : $"'{result.Value.Name}' is no longer the default view.");
    }

    private async Task CopyShareLinkAsync(SavedView view)
    {
        ioError = null;
        SetIoMessage(null);
        var uri = new Uri(Navigation.Uri);
        var path = uri.GetLeftPart(UriPartial.Path);
        var final = new UriBuilder(path)
        {
            Query = $"view={Uri.EscapeDataString(view.Name)}"
        }.Uri.ToString();

        try
        {
            await JS.InvokeVoidAsync("TaskFilterSidebarClipboard.copyText", final);
            SetIoMessage("Share link copied to clipboard.");
        }
        catch
        {
            ioError = "Unable to copy link automatically. You can copy it from the browser address bar after applying the view.";
        }
    }

    private void OnFilterChanged() => InvokeAsync(StateHasChanged);

    private void OnSearchInput(ChangeEventArgs e) => Filter.SearchTerm = e.Value?.ToString() ?? string.Empty;

    private async Task ToggleCollapsedAsync()
    {
        isCollapsed = !isCollapsed;
        try
        {
            await JS.InvokeVoidAsync("TaskFilterSidebarStorage.setCollapsed", CollapseKey, isCollapsed);
        }
        catch
        {
            // JS may not be available during prerender; best-effort only.
        }
    }

    [JSInvokable]
    public async Task OnSidebarShortcut(string action)
    {
        if (string.Equals(action, "TOGGLE", StringComparison.Ordinal))
        {
            await ToggleCollapsedAsync();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(action, "FOCUS", StringComparison.Ordinal))
        {
            if (isCollapsed)
            {
                isCollapsed = false;
                await InvokeAsync(StateHasChanged);
            }

            await JS.InvokeVoidAsync("TaskFilterSidebarKeyboard.focusSearch");
        }
    }

    private void ClearAll() => Filter.Clear();

    private static string SanitizeId(string value) =>
        string.IsNullOrWhiteSpace(value) ? "none"
        : new string(value.ToLowerInvariant().Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray());

    /// <summary>
    /// Sets ioMessage and (re)starts the 5 s auto-dismiss timer.
    /// Passing null cancels any pending timer and clears the message.
    /// </summary>
    private void SetIoMessage(string? msg)
    {
        _ioDismissTimer?.Dispose();
        _ioDismissTimer = null;
        ioMessage = msg;
        if (msg is not null)
        {
            _ioDismissTimer = new Timer(_ =>
            {
                ioMessage = null;
                _ioDismissTimer?.Dispose();
                _ioDismissTimer = null;
                InvokeAsync(StateHasChanged);
            }, null, 5_000, Timeout.Infinite);
        }
    }

    public async ValueTask DisposeAsync()
    {
        Filter.OnChange -= OnFilterChanged;
        _ioDismissTimer?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("TaskFilterSidebarKeyboard.unbind");
        }
        catch
        {
            // Circuit may already be torn down; best-effort cleanup only.
        }
        selfRef?.Dispose();
    }

    private async Task ExportViewsAsync()
    {
        ioError = null;
        SetIoMessage(null);
        if (savedViews.Count == 0)
            return;

        var dto = new SavedViewsExportDto(
            PageKey,
            DateTime.UtcNow,
            savedViews
                .Select(v => new SavedViewExportItem(v.Name, v.PayloadJson))
                .ToList());

        var json = JsonSerializer.Serialize(dto, ExportSerializerOptions);
        var fileName = $"saved-views-{PageKey}-{DateTime.UtcNow:yyyyMMdd-HHmmss}.json";

        try
        {
            await JS.InvokeVoidAsync("BlazorDownloadFile", fileName, json, "application/json");
            SetIoMessage($"Exported {savedViews.Count} view(s).");
        }
        catch (Exception ex)
        {
            ioError = $"Export failed: {ex.Message}";
        }
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        ioError = null;
        SetIoMessage(null);

        var file = e.File;
        if (file is null) return;

        if (file.Size > MaxImportBytes)
        {
            ioError = $"File is too large (>{MaxImportBytes / 1024} KB).";
            return;
        }

        string raw;
        try
        {
            await using var stream = file.OpenReadStream(MaxImportBytes);
            using var reader = new StreamReader(stream);
            raw = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            ioError = $"Could not read file: {ex.Message}";
            return;
        }

        SavedViewsExportDto? dto;
        try
        {
            dto = JsonSerializer.Deserialize<SavedViewsExportDto>(raw, ImportSerializerOptions);
        }
        catch (JsonException ex)
        {
            ioError = $"Invalid JSON: {ex.Message}";
            return;
        }

        if (dto is null || dto.Views is null || dto.Views.Count == 0)
        {
            ioError = "File contains no saved views.";
            return;
        }

        // Page-scope guard: only import views whose pageKey matches the current page.
        // Honours the per-page scoping the rest of the feature enforces and prevents
        // cross-page leakage when a user accidentally imports a Tasks export on Gantt.
        var targetPage = (PageKey ?? string.Empty).Trim().ToLowerInvariant();
        var filePageKey = dto.PageKey?.Trim().ToLowerInvariant();

        if (!string.IsNullOrEmpty(filePageKey) && filePageKey != targetPage)
        {
            ioError = $"This file was exported for '{dto.PageKey}'; current page is '{PageKey}'. Import on the matching page.";
            return;
        }

        var importedCount = 0;
        var skippedCount = 0;
        var errorCount = 0;

        foreach (var item in dto.Views)
        {
            if (string.IsNullOrWhiteSpace(item.Name) || string.IsNullOrWhiteSpace(item.Payload))
            {
                skippedCount++;
                continue;
            }

            // Validate payload is parseable JSON before sending to the orchestrator.
            try
            {
                using var _ = JsonDocument.Parse(item.Payload);
            }
            catch (JsonException)
            {
                skippedCount++;
                continue;
            }

            var cmd = new UpsertSavedViewCommand(item.Name.Trim(), PageKey ?? string.Empty, item.Payload, ownerKey);
            var result = await Mediator.Send(cmd);
            if (result.IsSuccess) importedCount++;
            else errorCount++;
        }

        await ReloadSavedViewsAsync();

        var parts = new List<string> { $"Imported {importedCount} view(s)" };
        if (skippedCount > 0) parts.Add($"skipped {skippedCount} invalid");
        if (errorCount > 0) parts.Add($"{errorCount} failed");
        SetIoMessage(string.Join(", ", parts) + ".");
    }

    /// <summary>Top-level shape of the export file. Camel-cased on the wire.</summary>
    private sealed record SavedViewsExportDto(
        string PageKey,
        DateTime ExportedAt,
        List<SavedViewExportItem> Views);

    /// <summary>One saved view inside the export. Payload is the raw filter JSON — stored as-is.</summary>
    private sealed record SavedViewExportItem(string Name, string Payload);
}
